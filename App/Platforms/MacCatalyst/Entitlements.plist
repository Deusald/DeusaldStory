<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <!-- See https://aka.ms/maui-publish-app-store#add-entitlements for more information about adding entitlements.-->
    <dict>
        <!-- App Sandbox must be enabled to distribute a MacCatalyst app through the Mac App Store. -->
        <key>com.apple.security.app-sandbox</key>
        <true/>
        <!-- When App Sandbox is enabled, this value is required to open outgoing network connections. -->
        <key>com.apple.security.network.client</key>
        <true/>
        <!-- Required so the folder/file pickers (UIDocumentPickerViewController) can grant access to
             user-selected locations under the sandbox. Without this the picker deadlocks and no
             window ever appears. -->
        <key>com.apple.security.files.user-selected.read-write</key>
        <true/>
        <!-- Allows persisting security-scoped bookmarks so a chosen project folder stays accessible
             across launches. -->
        <key>com.apple.security.files.bookmarks.app-scope</key>
        <true/>
    </dict>
</plist>


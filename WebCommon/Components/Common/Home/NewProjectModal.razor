@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@Loc.T(Localization.Home.NewProject.title)</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            @* ── Project name ──────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Home.NewProject.projectName)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@Loc.T(Localization.Home.NewProject.projectNamePlaceholder)"
                       value="@_Name"
                       @oninput="OnNameInput"
                       maxlength="100"/>
            </div>

            @* ── Slug ──────────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Home.NewProject.slug)
                    <span class="modal-label-hint">@Loc.T(Localization.Home.NewProject.slugHint)</span>
                </label>
                <input class="modal-input modal-input-mono"
                       type="text"
                       placeholder="@Loc.T(Localization.Home.NewProject.slugPlaceholder)"
                       @bind="_Slug"
                       @bind:event="oninput"
                       maxlength="80"/>
                @if (!string.IsNullOrEmpty(_Slug) && !IsValidSlug(_Slug))
                {
                    <div class="modal-field-error">@Loc.T(Localization.Home.NewProject.slugValidationError)</div>
                }
            </div>

            @* ── Localization project ──────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Home.NewProject.localizationProject)
                    <span class="modal-label-hint">@((MarkupString)Loc.T(Localization.Home.NewProject.localizationProjectHint))</span>
                </label>
                <LocalizationProjectField @bind-Selected="_SelectedLoc"/>
            </div>

            @* ── Description ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Common.Fields.description)
                    <span class="modal-label-hint">@Loc.T(Localization.Common.Fields.optional)</span>
                </label>
                <textarea class="modal-input modal-textarea"
                          placeholder="@Loc.T(Localization.Home.NewProject.descriptionPlaceholder)"
                          @bind="_Description"
                          @bind:event="oninput"
                          rows="2"
                          maxlength="500"></textarea>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @Loc.T(Localization.Home.NewProject.createProject)
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<NewProjectArgs> OnConfirm { get; set; }
    [Parameter] public EventCallback                 OnCancel  { get; set; }

    // ── State ──────────────────────────────────────────────────────────────

    private bool           _Visible;
    private string         _Name        = "";
    private string         _Slug        = "";
    private string         _Description = "";
    private LocProjectRef? _SelectedLoc;

    // ── Public API ─────────────────────────────────────────────────────────

    public void Show()
    {
        _Name        = "";
        _Slug        = "";
        _Description = "";
        _SelectedLoc = null;
        _Visible     = true;
        StateHasChanged();
    }

    // ── Validation ─────────────────────────────────────────────────────────

    private bool _CanConfirm =>
        !string.IsNullOrWhiteSpace(_Name) &&
        !string.IsNullOrWhiteSpace(_Slug) &&
        IsValidSlug(_Slug)                &&
        _SelectedLoc != null;

    private static bool IsValidSlug(string s) =>
        !string.IsNullOrEmpty(s) && Regex.IsMatch(s, @"^[a-z0-9]+(-[a-z0-9]+)*$");

    // ── Handlers ───────────────────────────────────────────────────────────

    private void OnNameInput(ChangeEventArgs e)
    {
        _Name = e.Value?.ToString() ?? "";
        // Auto-generate slug only while the user hasn't manually edited it
        _Slug = GenerateSlug(_Name);
    }

    private static string GenerateSlug(string name) =>
        Regex.Replace(
            Regex.Replace(name.ToLowerInvariant().Trim(), @"[^a-z0-9\s-]", ""),
            @"\s+", "-").Trim('-');

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;
        await OnConfirm.InvokeAsync(new NewProjectArgs(
            _Name.Trim(),
            _Slug.Trim(),
            _Description.Trim(),
            _SelectedLoc!.Reference));
    }

    private async Task Cancel()
    {
        _Visible = false;
        await OnCancel.InvokeAsync();
    }

    /// <summary>Result passed back to the parent when the user confirms.</summary>
    public record NewProjectArgs(
        string Name,
        string Slug,
        string Description,
        string LocalizationReference);

}

@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ILocalizationProjectPicker _Picker

<div class="lpf-root">
    @if (_Picker.CanBrowse)
    {
        @* Desktop: browse to a localization project folder *@
        @if (Selected is null)
        {
            <button class="lpf-browse" @onclick="Browse">
                <i class="bi bi-folder2-open"></i> @Loc.T(Localization.Home.LocalizationField.browse)
            </button>
        }
        else
        {
            <div class="lpf-selected">
                <div class="lpf-selected-info">
                    <span class="lpf-selected-name">@Selected.Name</span>
                    <span class="lpf-selected-meta">@Loc.T(Localization.Home.LocalizationField.meta, new Dictionary<string, object> { ["count"] = Selected.LanguageCount, ["main"] = Selected.MainLanguageId })</span>
                </div>
                <button class="lpf-change" @onclick="Browse">@Loc.T(Localization.Home.LocalizationField.change)</button>
            </div>
        }
        @if (_Error is not null)
        {
            <div class="lpf-error">@_Error</div>
        }
    }
    else
    {
        @* Web: pick from the localization projects stored in this browser *@
        @if (_Loading)
        {
            <div class="lpf-loading"><span class="spinner"></span> @Loc.T(Localization.Home.LocalizationField.loading)</div>
        }
        else if (_List.Count == 0)
        {
            <div class="lpf-empty">@((MarkupString)Loc.T(Localization.Home.LocalizationField.noneInBrowser))</div>
        }
        else
        {
            <div class="lpf-list">
                @foreach (LocProjectRef loc in _List)
                {
                    LocProjectRef item   = loc;
                    bool          active = Selected?.Reference == item.Reference;
                    <button class="lpf-item @(active ? "active" : "")" @onclick="() => Select(item)">
                        <div class="lpf-item-info">
                            <span class="lpf-item-name">@item.Name</span>
                            <span class="lpf-item-meta">@Loc.T(Localization.Home.LocalizationField.meta, new Dictionary<string, object> { ["count"] = item.LanguageCount, ["main"] = item.MainLanguageId })</span>
                        </div>
                        @if (active)
                        {
                            <i class="bi bi-check2 lpf-item-check"></i>
                        }
                    </button>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public LocProjectRef?                Selected        { get; set; }
    [Parameter] public EventCallback<LocProjectRef?> SelectedChanged { get; set; }

    private IReadOnlyList<LocProjectRef> _List = [];
    private bool                         _Loading;
    private string?                      _Error;

    protected override async Task OnInitializedAsync()
    {
        if (_Picker.CanBrowse) return;
        _Loading = true;
        _List    = await _Picker.ListAsync();
        _Loading = false;
    }

    private async Task Browse()
    {
        _Error = null;
        try
        {
            if (await _Picker.BrowseAsync() is { } picked)
                await SelectedChanged.InvokeAsync(picked);
        }
        catch (Exception ex)
        {
            _Error = Loc.T(Localization.Home.LocalizationField.notValid, new Dictionary<string, object> { ["error"] = ex.Message });
        }
    }

    private Task Select(LocProjectRef item) => SelectedChanged.InvokeAsync(item);
}

@namespace DeusaldStoryWeb.Components.Common
@inject ProjectStateService _ProjectState

<div class="ins-root">

    @if (Node is null)
    {
        <div class="ins-empty">
            <i class="bi bi-boxes"></i>
            <div class="ins-empty-title">No node selected</div>
            <div class="ins-empty-sub">Select a node in the graph to inspect and edit its contents.</div>
        </div>
    }
    else
    {
        @* ── Header ──────────────────────────────────────────────────── *@
        <div class="ins-header">
            <div class="ins-header-top">
                <span class="ins-kind" style="color:@StoryStyle.NodeColor(Node.Kind)">
                    <span class="ins-kind-dot" style="background:@StoryStyle.NodeColor(Node.Kind)"></span>
                    @StoryStyle.NodeLabel(Node.Kind)
                </span>
            </div>
            @* Skip the title when it only repeats the kind label above (e.g. SmartFormat / FlowText / Exit). *@
            @if (!StoryStyle.IsRedundantTitle(Node.Kind, Node.Title))
            {
                <div class="ins-title">@Node.Title</div>
            }
            @if (!string.IsNullOrEmpty(Node.Subtitle))
            {
                <div class="ins-subtitle">@Node.Subtitle</div>
            }
        </div>

        @* ── Body ────────────────────────────────────────────────────── *@
        <div class="ins-body">

            @* SmartFormat / FlowText carry no config of their own — surface the text wired into them. *@
            @if (ConnectedText is string connected)
            {
                <div class="ins-section-head">
                    <span class="ins-section-label">Connected text</span>
                </div>
                <div class="ins-text">@(string.IsNullOrWhiteSpace(connected) ? "(nothing connected)" : connected)</div>
            }

            @if (!string.IsNullOrEmpty(Node.Thumb))
            {
                <div class="ins-thumb">
                    <img src="data:image/png;base64,@Node.Thumb" alt="@Node.Title"/>
                </div>
            }

            @if (Node.Inputs.Count > 0)
            {
                <div class="ins-section-head">
                    <span class="ins-section-label">Inputs</span>
                    <span class="ins-section-count">@Node.Inputs.Count</span>
                </div>
                @foreach (EdPort port in Node.Inputs)
                {
                    <div class="ins-port">
                        <span class="ins-port-dot" style="background:@StoryStyle.PortColor(port.Type)"></span>
                        <span class="ins-port-name">@PortName(port)</span>
                        <span class="ins-port-type">@PortTypeLabel(port.Type)</span>
                    </div>
                }
            }

            @if (Node.Outputs.Count > 0)
            {
                <div class="ins-section-head">
                    <span class="ins-section-label">Outputs</span>
                    <span class="ins-section-count">@Node.Outputs.Count</span>
                </div>
                @foreach (EdPort port in Node.Outputs)
                {
                    <div class="ins-port">
                        <span class="ins-port-dot" style="background:@StoryStyle.PortColor(port.Type)"></span>
                        <span class="ins-port-name">@PortName(port)</span>
                        <span class="ins-port-type">@PortTypeLabel(port.Type)</span>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public EdNode?        Node  { get; set; }
    /// <summary>The logic node whose inner graph the selected node lives in (null in a container graph); used to resolve wired-in text.</summary>
    [Parameter] public StoryLogicNode? Logic { get; set; }

    /// <summary>
    /// For a SmartFormat / FlowText node, the text resolved from whatever is wired into its Text input (the format
    /// string for SmartFormat, the formatted result for FlowText). Null for every other kind — those show no text row.
    /// </summary>
    private string? ConnectedText
    {
        get
        {
            if (Logic is null || Node is null) return null;
            if (Node.Kind is not (StoryNodeKind.SmartFormat or StoryNodeKind.FlowText)) return null;
            EdPort? textIn = Node.Inputs.Find(p => p.Type == PortType.Text);
            if (textIn is null) return null;
            return StoryLogicRenderer.ResolvePortText(_ProjectState.CurrentProject!, _ProjectState.CurrentLocalization, Logic, textIn.Id);
        }
    }

    private static string PortName(EdPort port) => string.IsNullOrEmpty(port.Name) ? "(unnamed)" : port.Name;

    private static string PortTypeLabel(PortType type) => type switch
    {
        PortType.VFlow     => "Variable Flow",
        PortType.LFlow     => "Logic Flow",
        PortType.Text      => "Text",
        PortType.Icon      => "Icon",
        PortType.Variable  => "Variable",
        PortType.CVariable => "Constant Variable",
        _                  => "Flow"
    };
}

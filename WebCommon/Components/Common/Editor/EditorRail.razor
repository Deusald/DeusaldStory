@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@* ─────────────────────────────────────────────────────────────────────────
   Left tool rail. Placeholder navigation matching the design mock — the
   panels these switch between do not exist yet, so clicking only sets the
   active tool. Wire each to real editor panels as they land.
   ───────────────────────────────────────────────────────────────────────── *@

<div class="edr-root">

    @* ── Primary: story graph ────────────────────────────────────────── *@
    <button class="edr-btn edr-primary @(_Active == Tool.Graph ? "active" : "")"
            title="@Loc.T(Localization.Editor.Rail.storyGraph)" @onclick="() => Select(Tool.Graph)">
        <i class="bi bi-bezier2"></i>
    </button>

    <div class="edr-sep"></div>

    @* ── Tools ───────────────────────────────────────────────────────── *@
    @foreach ((Tool tool, string icon, Guid label) in _Tools)
    {
        Tool t = tool;
        <button class="edr-btn @(_Active == t ? "active" : "")"
                title="@Loc.T(label)" @onclick="() => Select(t)">
            <i class="bi @icon"></i>
        </button>
    }

    <div class="edr-spacer"></div>

    @* ── Bottom: diagnostics ─────────────────────────────────────────── *@
    <button class="edr-btn @(_Active == Tool.Problems ? "active" : "")"
            title="@Loc.T(Localization.Editor.Rail.problems)" @onclick="() => Select(Tool.Problems)">
        <i class="bi bi-exclamation-triangle"></i>
    </button>

</div>

@code {
    /// <summary>The panels the rail switches between. <see cref="Graph"/>, <see cref="Media"/>,
    /// <see cref="Localization"/>, <see cref="Variables"/>, <see cref="Blocks"/> and <see cref="Problems"/> each have a
    /// real panel today.</summary>
    public enum Tool { Graph, Localization, Variables, Blocks, Media, Problems }

    /// <summary>Raised when the user picks a tool, so the editor can swap the centre panel.</summary>
    [Parameter] public EventCallback<Tool> OnToolSelected { get; set; }

    private Tool _Active = Tool.Graph;

    // Middle tool stack (order mirrors the mock).
    private static readonly (Tool Tool, string Icon, Guid Label)[] _Tools =
    [
        (Tool.Localization, "bi-globe",     Localization.Editor.Rail.localization),
        (Tool.Variables,    "bi-braces",    Localization.Editor.Rail.variables),
        (Tool.Blocks,       "bi-diagram-3", Localization.Editor.Rail.blueprints),
        (Tool.Media,        "bi-image",     Localization.Editor.Rail.media)
    ];

    private async Task Select(Tool tool)
    {
        _Active = tool;
        await OnToolSelected.InvokeAsync(tool);
    }

    /// <summary>Sets the highlighted tool without raising <see cref="OnToolSelected"/> — for programmatic navigation.</summary>
    public void SetActive(Tool tool)
    {
        _Active = tool;
        StateHasChanged();
    }
}

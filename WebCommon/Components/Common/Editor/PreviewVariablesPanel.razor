@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Shown in the inspector column while a logic node is in Preview mode. Lists
   the variables referenced by the node's Get Variable nodes and lets the author
   tweak each value; changes flow into the shared Values dictionary and raise
   ValuesChanged so the LogicPreview re-renders its SmartFormat output.
   ───────────────────────────────────────────────────────────────────────── *@

<div class="pvp-root">

    <div class="pvp-header">
        <span class="pvp-kind">
            <span class="pvp-kind-dot"></span>
            @(Gamebook ? Loc.T(Localization.Editor.Panels.PreviewVariables.kindGamebook) : Loc.T(Localization.Editor.Panels.PreviewVariables.kindVariables))
        </span>
        <div class="pvp-title">@(Gamebook ? Loc.T(Localization.Editor.Panels.PreviewVariables.generatedSectionsTitle) : Loc.T(Localization.Editor.Panels.PreviewVariables.previewValuesTitle))</div>
        <div class="pvp-subtitle">
            @(Gamebook
                ? Loc.T(Localization.Editor.Panels.PreviewVariables.gamebookSubtitle)
                : Loc.T(Localization.Editor.Panels.PreviewVariables.valuesSubtitle))
        </div>
    </div>

    @{
        List<PreviewVar> vars = Gamebook ? new List<PreviewVar>() : ReferencedVariables();
    }
    <div class="pvp-body">
        @if (Gamebook)
        {
            <div class="pvp-empty">
                <i class="bi bi-book"></i>
                <span>@Loc.T(Localization.Editor.Panels.PreviewVariables.gamebookEmpty)</span>
            </div>
        }
        else if (vars.Count == 0)
        {
            <div class="pvp-empty">
                <i class="bi bi-braces"></i>
                <span>@Loc.T(Localization.Editor.Panels.PreviewVariables.noVariablesEmpty)</span>
            </div>
        }
        else
        {
            @foreach (PreviewVar v in vars)
            {
                PreviewVar variable = v;
                <div class="pvp-field">
                    <label class="pvp-label">@(string.IsNullOrWhiteSpace(variable.Name) ? Loc.T(Localization.Common.Placeholders.unnamed) : variable.Name)</label>
                    @if (variable.Values.Count > 0)
                    {
                        <select class="modal-input"
                                value="@PreviewValue(variable)"
                                @onchange="e => OnValueChanged(variable.Id, e)">
                            @foreach (string val in variable.Values)
                            {
                                <option value="@val">@(string.IsNullOrEmpty(val) ? Loc.T(Localization.Common.Placeholders.empty) : val)</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input class="modal-input" type="text"
                               value="@PreviewValue(variable)"
                               @oninput="e => OnValueChanged(variable.Id, e)"/>
                    }
                    @if (!string.IsNullOrWhiteSpace(variable.Description))
                    {
                        <div class="pvp-hint">@variable.Description</div>
                    }
                </div>
            }
        }
    </div>

</div>

@code {
    [Parameter] public StoryLogicNode            Logic         { get; set; } = default!;
    [Parameter] public Dictionary<Guid, string>  Values        { get; set; } = new();
    [Parameter] public EventCallback             ValuesChanged { get; set; }

    /// <summary>
    /// The project <see cref="Logic"/> belongs to — the preview session's own. It must be the one the renderer reads,
    /// so every value is seeded under a key the renderer actually looks up.
    /// </summary>
    [Parameter] public StoryProject Project { get; set; } = default!;

    /// <summary>Gamebook preview: sections are pre-generated, so the panel shows a note instead of editable values.</summary>
    [Parameter] public bool Gamebook { get; set; }

    /// <summary>A tweakable preview value row (a referenced global variable or an incoming declared variable).</summary>
    private sealed record PreviewVar(Guid Id, string Name, string Description, List<string> Values);

    protected override void OnParametersSet()
    {
        // Seeding fills the shared values dictionary; the sibling LogicPreview has already rendered against the
        // pre-seed (empty) values, so notify the parent to re-render it with the freshly seeded defaults.
        if (!Gamebook && SeedValues())
            ValuesChanged.InvokeAsync();
    }

    /// <summary>
    /// The variables this logic node previews: those its Get Variable nodes reference (built-ins excluded — they follow
    /// the render), plus the incoming declared variables handed in by an upstream Single-path node, so the reader can
    /// pick a value and the text never renders as null.
    /// </summary>
    private List<PreviewVar> ReferencedVariables()
    {
        Dictionary<Guid, PreviewVar> map = new();
        foreach (StoryGetVariableNode n in Logic.GetVariableNodes)
            if (Variable(n.SelectedVariableId) is StoryVariable v)
                map[v.Id] = new PreviewVar(v.Id, v.Name, v.Description, StoryVariableValues.PossibleValues(v));

        List<PreviewVar> ordered = map.Values.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase).ToList();

        foreach (StoryDeclaredVariable d in StorySelectionResolver.IncomingVariables(Project, Logic))
            ordered.Add(new PreviewVar(d.Id, string.IsNullOrWhiteSpace(d.Name) ? Loc.T(Localization.Editor.Panels.PreviewVariables.incoming) : d.Name, "", d.PossibleValues));

        return ordered;
    }

    /// <summary>Ensures every referenced variable has a value (defaulting to its first possible value); returns whether any were added.</summary>
    private bool SeedValues()
    {
        bool added = false;
        foreach (PreviewVar v in ReferencedVariables())
            if (!Values.ContainsKey(v.Id))
            {
                Values[v.Id] = v.Values.FirstOrDefault() ?? "";
                added        = true;
            }
        return added;
    }

    private string PreviewValue(PreviewVar v) =>
        Values.TryGetValue(v.Id, out string? val) ? val : v.Values.FirstOrDefault() ?? "";

    private StoryVariable? Variable(Guid id) =>
        id != Guid.Empty && Project.Variables.TryGetValue(id, out StoryVariable? v) ? v : null;

    private async Task OnValueChanged(Guid variableId, ChangeEventArgs e)
    {
        Values[variableId] = e.Value?.ToString() ?? "";
        await ValuesChanged.InvokeAsync();
    }
}

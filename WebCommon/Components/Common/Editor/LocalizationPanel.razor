@namespace DeusaldStoryWeb.Components.Common
@inject ProjectStateService _ProjectState
@implements IDisposable

@* ─────────────────────────────────────────────────────────────────────────
   Read-only browser for the story's linked localization project, shown from
   the rail's Localization tool. Three columns: categories browse on the left,
   keys of the selected category (filtered live by the search box) in the
   middle, and every translation of the selected key on the right. Mirrors
   LocalizationKeyPickerModal but never selects — it only lets the author look
   keys and their translations up. Refresh re-reads the linked project, the
   same action the top bar offers.
   ───────────────────────────────────────────────────────────────────────── *@

<div class="lop-root">

    <div class="lop-head">
        <div class="lop-head-text">
            <div class="lop-head-title">
                <i class="bi bi-globe"></i>
                <span>Localization</span>
            </div>
            <div class="lop-head-sub">Browse the linked localization project's keys and translations.</div>
        </div>
        <div class="lop-head-actions">
            <button class="lop-refresh" @onclick="Relink" title="Link a different localization project">
                <i class="bi bi-link-45deg"></i>
                <span>Re-link</span>
            </button>
            @if (_Loc is not null)
            {
                <button class="lop-refresh" @onclick="Refresh" disabled="@_Refreshing" title="Refresh localization keys">
                    <i class="bi bi-arrow-clockwise @(_Refreshing ? "lop-spin" : "")"></i>
                    <span>Refresh</span>
                </button>
            }
        </div>
    </div>

    @if (_Loc is null)
    {
        <div class="lop-empty">
            <i class="bi bi-translate"></i>
            <span>No localization project is linked to this story.</span>
            <button class="lop-refresh" @onclick="Relink">
                <i class="bi bi-link-45deg"></i>
                <span>Link a project</span>
            </button>
        </div>
    }
    else
    {
        <div class="lop-search">
            <i class="bi bi-search"></i>
            <input class="modal-input"
                   type="text"
                   placeholder="Search keys by name, description or tag…"
                   @bind="_Search"
                   @bind:event="oninput"/>
        </div>

        <div class="lop-cols">

            @* Categories *@
            <div class="lop-cats">
                <button class="lop-cat @(_CategoryId is null ? "active" : "")"
                        @onclick="() => SelectCategory(null)">
                    <i class="bi bi-collection"></i> All keys
                    <span class="lop-cat-count">@_Loc.Keys.Count</span>
                </button>
                @foreach ((LocCategory cat, int depth) in FlatCategories())
                {
                    LocCategory c = cat;
                    <button class="lop-cat @(_CategoryId == c.Id ? "active" : "")"
                            style="padding-left:@(10 + depth * 14)px"
                            @onclick="() => SelectCategory(c.Id)">
                        <i class="bi bi-folder2"></i> @c.Name
                        <span class="lop-cat-count">@KeysInCategory(c.Id)</span>
                    </button>
                }
            </div>

            @* Keys *@
            <div class="lop-keys">
                @{
                    List<LocLocalizationKey> keys = FilteredKeys().ToList();
                }
                @if (keys.Count == 0)
                {
                    <div class="lop-keys-empty">No keys match.</div>
                }
                else
                {
                    @foreach (LocLocalizationKey key in keys)
                    {
                        LocLocalizationKey k = key;
                        <button class="lop-key @(_SelectedKeyId == k.Id ? "selected" : "")"
                                @onclick="() => _SelectedKeyId = k.Id">
                            <div class="lop-key-name">@k.KeyName</div>
                            @{
                                string preview = MainText(k);
                            }
                            @if (!string.IsNullOrEmpty(preview))
                            {
                                <div class="lop-key-text">@preview</div>
                            }
                        </button>
                    }
                }
            </div>

            @* Translations of the selected key *@
            <div class="lop-trans">
                @if (SelectedKey is not LocLocalizationKey sel)
                {
                    <div class="lop-trans-empty">
                        <i class="bi bi-card-text"></i>
                        <span>Select a key to see its translations.</span>
                    </div>
                }
                else
                {
                    <div class="lop-trans-head">
                        <div class="lop-trans-key">@sel.KeyName</div>
                        @if (!string.IsNullOrEmpty(sel.Description))
                        {
                            <div class="lop-trans-desc">@sel.Description</div>
                        }
                        @if (sel.Tags.Count > 0)
                        {
                            <div class="lop-tags">
                                @foreach (string tag in sel.Tags)
                                {
                                    <span class="lop-tag">@tag</span>
                                }
                            </div>
                        }
                    </div>

                    <div class="lop-trans-list">
                        @foreach (string lang in Languages())
                        {
                            LocKeyTranslation? tr = sel.Translations.Find(t => t.LanguageId == lang);
                            bool               isMain = lang == _Loc.Metadata.MainLanguageId;
                            <div class="lop-trans-row">
                                <div class="lop-trans-lang">
                                    <span class="lop-lang-code">@lang</span>
                                    @if (isMain)
                                    {
                                        <span class="lop-lang-main">main</span>
                                    }
                                    <span class="lop-status lop-status-@StatusClass(tr)">@StatusLabel(tr)</span>
                                </div>
                                @if (string.IsNullOrEmpty(tr?.Text))
                                {
                                    <div class="lop-trans-text lop-trans-text-empty">— no translation —</div>
                                }
                                else
                                {
                                    <div class="lop-trans-text">@tr.Text</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    }

</div>

<RelinkLocalizationModal @ref="_RelinkModal" OnConfirm="OnRelinkConfirmed"/>

@code {
    /// <summary>Raised when the user hits Refresh, so the editor can re-project the graph with any new keys.</summary>
    [Parameter] public EventCallback OnRefresh { get; set; }

    private RelinkLocalizationModal? _RelinkModal;

    private string _Search = "";
    private Guid?  _CategoryId;   // null = All
    private Guid   _SelectedKeyId;
    private bool   _Refreshing;

    private LocProject?         _Loc         => _ProjectState.CurrentLocalization;
    private LocLocalizationKey? SelectedKey  => _Loc?.Keys.Find(k => k.Id == _SelectedKeyId);

    protected override void OnInitialized() =>
        _ProjectState.ProjectDataChanged += OnDataChanged;

    private void SelectCategory(Guid? id) => _CategoryId = id;

    private async Task Refresh()
    {
        _Refreshing = true;
        try   { await OnRefresh.InvokeAsync(); }
        finally { _Refreshing = false; }
    }

    /// <summary>Opens the picker to link a different localization project to this story.</summary>
    private void Relink() =>
        _RelinkModal?.Show(_ProjectState.CurrentProject?.Metadata.Name ?? "This story", projectMissing: false);

    /// <summary>Points the story at the picked localization project and re-projects the graph with the new keys.</summary>
    private async Task OnRelinkConfirmed(LocProjectRef reference)
    {
        if (await _ProjectState.RelinkCurrentLocalizationAsync(reference.Reference))
        {
            _SelectedKeyId = Guid.Empty;
            _CategoryId    = null;
            await OnRefresh.InvokeAsync();
        }
    }

    /// <summary>Every language in the project, main language first, then the rest alphabetically.</summary>
    private IEnumerable<string> Languages()
    {
        if (_Loc is null) yield break;
        string main = _Loc.Metadata.MainLanguageId;
        if (!string.IsNullOrEmpty(main) && _Loc.Metadata.Languages.Contains(main))
            yield return main;
        foreach (string lang in _Loc.Metadata.Languages
                                    .Where(l => l != main)
                                    .OrderBy(l => l, StringComparer.OrdinalIgnoreCase))
            yield return lang;
    }

    /// <summary>Categories flattened depth-first (root → children), each with its indent depth.</summary>
    private IEnumerable<(LocCategory Cat, int Depth)> FlatCategories()
    {
        if (_Loc is null) yield break;

        IEnumerable<(LocCategory, int)> Walk(Guid? parent, int depth)
        {
            foreach (LocCategory cat in _Loc.Categories
                                            .Where(c => c.ParentCategoryId == parent)
                                            .OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
            {
                yield return (cat, depth);
                foreach ((LocCategory, int) child in Walk(cat.Id, depth + 1))
                    yield return child;
            }
        }

        foreach ((LocCategory, int) item in Walk(null, 0))
            yield return item;
    }

    private int KeysInCategory(Guid categoryId) =>
        _Loc?.Keys.Count(k => k.CategoryId == categoryId) ?? 0;

    /// <summary>Keys of the selected category (or all), then filtered by the search text.</summary>
    private IEnumerable<LocLocalizationKey> FilteredKeys()
    {
        if (_Loc is null) return Enumerable.Empty<LocLocalizationKey>();

        IEnumerable<LocLocalizationKey> keys = _Loc.Keys;
        if (_CategoryId is Guid cid)
            keys = keys.Where(k => k.CategoryId == cid);

        string term = _Search.Trim();
        if (term.Length > 0)
            keys = keys.Where(k =>
                k.KeyName.Contains(term, StringComparison.OrdinalIgnoreCase)     ||
                k.Description.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                k.Tags.Any(t => t.Contains(term, StringComparison.OrdinalIgnoreCase)));

        return keys.OrderBy(k => k.KeyName, StringComparer.OrdinalIgnoreCase);
    }

    /// <summary>The key's main-language text (empty when it has no source translation).</summary>
    private string MainText(LocLocalizationKey key)
    {
        string? main = _Loc?.Metadata.MainLanguageId;
        if (string.IsNullOrEmpty(main)) return "";
        return key.Translations.Find(t => t.LanguageId == main)?.Text ?? "";
    }

    private static string StatusLabel(LocKeyTranslation? tr) => tr?.Status switch
    {
        TranslationStatus.Approved  => "approved",
        TranslationStatus.Suggested => "suggested",
        _                           => "untranslated"
    };

    private static string StatusClass(LocKeyTranslation? tr) => tr?.Status switch
    {
        TranslationStatus.Approved  => "approved",
        TranslationStatus.Suggested => "suggested",
        _                           => "untranslated"
    };

    private void OnDataChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => _ProjectState.ProjectDataChanged -= OnDataChanged;
}

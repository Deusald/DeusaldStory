@namespace DeusaldStoryWeb.Components.Common

@* ─────────────────────────────────────────────────────────────────────────
   Edits a Condition node: its name, a "negate" toggle, and the boolean
   condition built from the constant variables wired into its Variables input
   (reusing the same recursive ExitConditionEditor as the Exit node). When the
   condition holds (after optional negation) the story injects the block wired
   from the node's "Condition true" output, up to its paired End condition.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box cfm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">Condition</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body cfm-body">

            <div class="cfm-field">
                <label class="cfm-label">Name</label>
                <input class="modal-input" type="text" placeholder="Condition name…"
                       @bind="_Name" @bind:event="oninput"/>
            </div>

            <label class="cfm-negate">
                <input type="checkbox" @bind="_Negate"/>
                <span>Negate — enter the block when the condition is <b>false</b></span>
            </label>

            @if (_AvailableVars.Count == 0)
            {
                <div class="modal-note">
                    <i class="bi bi-info-circle"></i>
                    <span>Wire one or more <b>constant</b> variables into this node's <b>Variables</b> input, then reopen
                          this dialog to build the condition. An empty condition is always true.</span>
                </div>
            }
            else
            {
                <div class="modal-note">
                    <i class="bi bi-info-circle"></i>
                    <span>The block runs when this condition holds@(_Negate ? " (inverted by Negate)" : ""). Only constant
                          variables are offered, so it renders the same in the App and the Gamebook.</span>
                </div>
            }

            <ExitConditionEditor Expr="_Condition" Vars="_AvailableVars" OnChanged="StateHasChanged"/>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm">Save changes</button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<ConditionFlowArgs> OnConfirm { get; set; }

    private bool                         _Visible;
    private Guid                         _NodeId;
    private string                       _Name          = "";
    private bool                         _Negate;
    private StoryConditionExpr           _Condition     = new() { Kind = StoryConditionExprKind.Group };
    private List<(Guid Id, string Name)> _AvailableVars = new();

    /// <summary>Opens the modal to edit <paramref name="node"/>. <paramref name="availableVars"/> are the constant
    /// variables wired into the node's Variables input (empty when none are wired yet).</summary>
    public void ShowEdit(StoryConditionFlowNode node, List<(Guid Id, string Name)> availableVars)
    {
        _NodeId        = node.Id;
        _Name          = node.Name;
        _Negate        = node.Negate;
        _AvailableVars = availableVars;
        _Condition     = node.Condition?.Clone() ?? new StoryConditionExpr { Kind = StoryConditionExprKind.Group };
        _Visible       = true;
        StateHasChanged();
    }

    private async Task Confirm()
    {
        _Visible = false;
        await OnConfirm.InvokeAsync(new ConditionFlowArgs(_NodeId, _Name.Trim(), _Condition, _Negate));
    }

    private void Cancel() => _Visible = false;

    public record ConditionFlowArgs(Guid NodeId, string Name, StoryConditionExpr Condition, bool Negate);
}

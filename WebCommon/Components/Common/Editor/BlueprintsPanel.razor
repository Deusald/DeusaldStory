@namespace DeusaldStoryWeb.Components.Common
@using DeusaldStoryCommon
@inject ProjectStateService _ProjectState
@inject UiLocalizationService Loc
@implements IDisposable

@* ─────────────────────────────────────────────────────────────────────────
   Blueprint library, shown from the rail's Blueprints tool. Create reusable
   Container / Logic / Function definitions, rename or delete them, open a
   definition to edit it (edits apply to every instance), and edit a function's
   signature. Instances are placed onto the graph from the node palette.
   ───────────────────────────────────────────────────────────────────────── *@

<div class="bpp-root">

    <div class="bpp-head">
        <div class="bpp-head-title">
            <i class="bi bi-diagram-3"></i>
            <span>@Loc.T(Localization.Editor.Panels.Blueprints.title)</span>
        </div>
        <div class="bpp-head-sub">@Loc.T(Localization.Editor.Panels.Blueprints.subtitle)</div>
    </div>

    <div class="bpp-new">
        <input class="modal-input" type="text" placeholder="@Loc.T(Localization.Editor.Panels.Blueprints.newNamePlaceholder)"
               @bind="_NewName" @bind:event="oninput" maxlength="100"/>
        <button class="modal-btn modal-btn-ghost" disabled="@_CantCreate" @onclick="() => Create(StoryBlueprintKind.Container)">
            <i class="bi bi-collection"></i> @Loc.T(Localization.Editor.Panels.Blueprints.container)
        </button>
        <button class="modal-btn modal-btn-ghost" disabled="@_CantCreate" @onclick="() => Create(StoryBlueprintKind.Logic)">
            <i class="bi bi-diamond-half"></i> @Loc.T(Localization.Editor.Panels.Blueprints.logic)
        </button>
        <button class="modal-btn modal-btn-ghost" disabled="@_CantCreate" @onclick="() => Create(StoryBlueprintKind.Function)">
            <i class="bi bi-cpu"></i> @Loc.T(Localization.Editor.Panels.Blueprints.function)
        </button>
    </div>

    <div class="bpp-list">
        @if (Blueprints.Count == 0)
        {
            <div class="bpp-empty">@Loc.T(Localization.Editor.Panels.Blueprints.empty)</div>
        }
        @foreach (StoryBlueprint bp in Blueprints)
        {
            StoryBlueprint item = bp;
            <div class="bpp-item">
                <i class="bi @KindIcon(item.Kind) bpp-item-icon"></i>
                <input class="modal-input bpp-item-name"
                       value="@item.Name"
                       @onchange="e => Rename(item.Id, e.Value?.ToString() ?? string.Empty)"
                       maxlength="100"/>
                <span class="bpp-item-kind">@item.Kind</span>
                <span class="bpp-item-count">@Loc.T(Localization.Editor.Panels.Blueprints.instanceCount, new Dictionary<string, object> { ["count"] = InstanceCount(item) })</span>

                <button class="bpp-act" title="@Loc.T(Localization.Editor.Panels.Blueprints.openDefinition)" @onclick="() => OnOpen.InvokeAsync(item.Id)">
                    <i class="bi bi-box-arrow-in-right"></i>
                </button>
                @if (item.Kind == StoryBlueprintKind.Function)
                {
                    <button class="bpp-act" title="@Loc.T(Localization.Editor.Panels.Blueprints.editSignature)" @onclick="() => OnEditSignature.InvokeAsync(item.Id)">
                        <i class="bi bi-input-cursor"></i>
                    </button>
                }
                else
                {
                    <button class="bpp-act" title="@Loc.T(Localization.Editor.Panels.Blueprints.editProperties)" @onclick="() => OnEditProperties.InvokeAsync(item.Id)">
                        <i class="bi bi-sliders"></i>
                    </button>
                }
                @if (_ConfirmDelete == item.Id)
                {
                    <button class="bpp-act bpp-act-danger" title="@Loc.T(Localization.Editor.Panels.Blueprints.confirmDelete)" @onclick="() => Delete(item.Id)">
                        <i class="bi bi-check-lg"></i>
                    </button>
                    <button class="bpp-act" title="@Loc.T(Localization.Common.Buttons.cancel)" @onclick="() => _ConfirmDelete = Guid.Empty">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
                else
                {
                    <button class="bpp-act" title="@Loc.T(Localization.Common.Buttons.delete)" @onclick="() => _ConfirmDelete = item.Id">
                        <i class="bi bi-trash"></i>
                    </button>
                }
            </div>
        }
    </div>

</div>

@code {
    /// <summary>Raised to open a blueprint's shared definition for editing (drill-down).</summary>
    [Parameter] public EventCallback<Guid> OnOpen { get; set; }

    /// <summary>Raised to edit a Function blueprint's signature.</summary>
    [Parameter] public EventCallback<Guid> OnEditSignature { get; set; }

    /// <summary>Raised to edit a Container/Logic blueprint's properties (name, ports/exit mode, options).</summary>
    [Parameter] public EventCallback<Guid> OnEditProperties { get; set; }

    private string _NewName      = "";
    private Guid   _ConfirmDelete = Guid.Empty;

    private bool _CantCreate => string.IsNullOrWhiteSpace(_NewName);

    private List<StoryBlueprint> Blueprints =>
        _ProjectState.CurrentProject?.Blueprints.Values.OrderBy(b => b.Name).ToList() ?? new();

    protected override void OnInitialized() => _ProjectState.ProjectChanged += OnChanged;
    public void Dispose() => _ProjectState.ProjectChanged -= OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);

    private int InstanceCount(StoryBlueprint bp) =>
        bp.Kind == StoryBlueprintKind.Function
            ? _ProjectState.FunctionInstanceCount(bp.Id)
            : _ProjectState.BlueprintInstanceCount(bp.Id);

    private void Create(StoryBlueprintKind kind)
    {
        if (_CantCreate) return;
        string name = _NewName.Trim();
        switch (kind)
        {
            case StoryBlueprintKind.Container: _ProjectState.AddContainerBlueprint(name); break;
            case StoryBlueprintKind.Logic:     _ProjectState.AddLogicBlueprint(name);     break;
            case StoryBlueprintKind.Function:  _ProjectState.AddFunctionBlueprint(name);  break;
        }
        _NewName = "";
    }

    private void Rename(Guid id, string name)
    {
        if (_ProjectState.CurrentProject?.Blueprints.TryGetValue(id, out StoryBlueprint? bp) == true)
            _ProjectState.UpdateBlueprint(id, string.IsNullOrWhiteSpace(name) ? bp.Name : name.Trim(), bp.Description);
    }

    private void Delete(Guid id)
    {
        _ConfirmDelete = Guid.Empty;
        _ProjectState.DeleteBlueprint(id);
    }

    private static string KindIcon(StoryBlueprintKind k) => k switch
    {
        StoryBlueprintKind.Container => "bi-collection",
        StoryBlueprintKind.Logic     => "bi-diamond-half",
        StoryBlueprintKind.Function  => "bi-cpu",
        _                            => "bi-diagram-3"
    };
}

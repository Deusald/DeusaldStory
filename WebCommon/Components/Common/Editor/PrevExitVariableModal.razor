@namespace DeusaldStoryWeb.Components.Common

@* ─────────────────────────────────────────────────────────────────────────
   Edits the non-deletable "Prev Exit Variable" node inside a logic node: the
   local name the upstream Selection variable is exposed under, and an optional
   remap of each incoming exit name to a custom output value (fed to SmartFormat
   or any other variable input). Possible values come from the upstream node's
   exit points, resolved by the caller.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box pev-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">Edit selection variable</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body pev-body">

            @* ── Variable name ─────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    Variable name
                    <span class="modal-label-hint">the name this value is exposed under here</span>
                </label>
                <input class="modal-input"
                       type="text"
                       placeholder="Selection"
                       @bind="_VariableName"
                       @bind:event="oninput"
                       maxlength="60"/>
            </div>

            @* ── Remap toggle ──────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="nlm-check">
                    <input type="checkbox"
                           checked="@_RemapEnabled"
                           @onchange="e => _RemapEnabled = (bool)(e.Value ?? false)"/>
                    <span>
                        Remap values
                        <span class="modal-label-hint">emit a custom value per incoming exit instead of its name</span>
                    </span>
                </label>
            </div>

            @* ── Remap table ───────────────────────────────────────────── *@
            @if (_Rows.Count == 0)
            {
                <div class="pev-hint">Nothing is wired into this node's exit-variable input yet.</div>
            }
            else if (_RemapEnabled)
            {
                <div class="modal-field">
                    <label class="modal-label">Mapping</label>
                    <div class="pev-map">
                        @foreach (RemapRow row in _Rows)
                        {
                            RemapRow r = row;
                            <div class="pev-map-row">
                                <span class="pev-map-from" title="@r.ExitName">@r.ExitName</span>
                                <i class="bi bi-arrow-right pev-map-arrow"></i>
                                <input class="modal-input pev-map-to"
                                       type="text"
                                       placeholder="@r.ExitName"
                                       value="@r.Value"
                                       @oninput="e => r.Value = e.Value?.ToString() ?? string.Empty"
                                       maxlength="120"/>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="modal-field">
                    <label class="modal-label">Possible values</label>
                    <div class="pev-values">
                        @foreach (RemapRow row in _Rows)
                        {
                            <span class="pev-value">@row.ExitName</span>
                        }
                    </div>
                </div>
            }

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(string.IsNullOrWhiteSpace(_VariableName))">
                Save changes
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<PrevExitVariableArgs> OnConfirm { get; set; }

    private bool           _Visible;
    private string         _VariableName = "Selection";
    private bool           _RemapEnabled;
    private List<RemapRow> _Rows = new();

    /// <summary>
    /// Opens the modal for a logic node's Prev Exit Variable node. <paramref name="sourceExits"/> are the upstream
    /// node's exit points (id + name) — the possible incoming values; existing remaps pre-fill the rows.
    /// </summary>
    public void ShowEdit(StoryPrevExitVariableNode node, IEnumerable<(Guid Id, string Name)> sourceExits)
    {
        _VariableName = string.IsNullOrWhiteSpace(node.VariableName) ? "Selection" : node.VariableName;
        _RemapEnabled = node.RemapEnabled;
        _Rows = sourceExits.Select(e => new RemapRow
        {
            SourceExitId = e.Id,
            ExitName     = e.Name,
            Value        = node.Remaps.Find(r => r.SourceExitId == e.Id)?.Value is string v && v.Length > 0 ? v : e.Name
        }).ToList();
        _Visible = true;
        StateHasChanged();
    }

    private async Task Confirm()
    {
        if (string.IsNullOrWhiteSpace(_VariableName)) return;
        _Visible = false;

        List<StoryPrevExitRemap> remaps = _Rows
            .Select(r => new StoryPrevExitRemap { SourceExitId = r.SourceExitId, Value = r.Value.Trim() })
            .ToList();

        await OnConfirm.InvokeAsync(new PrevExitVariableArgs(_VariableName.Trim(), _RemapEnabled, remaps));
    }

    private void Cancel() => _Visible = false;

    private sealed class RemapRow
    {
        public Guid   SourceExitId { get; set; }
        public string ExitName     { get; set; } = "";
        public string Value        { get; set; } = "";
    }

    /// <summary>Result passed back to the parent.</summary>
    public record PrevExitVariableArgs(string VariableName, bool RemapEnabled, List<StoryPrevExitRemap> Remaps);
}

@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Read-only inspector for a selected Get / Set variable node, showing the
   global variable it targets. Editing is done from the node's right-click
   "Edit" (which reopens the modal).
   ───────────────────────────────────────────────────────────────────────── *@

<div class="vni-root">

    @if (SetNode is StorySetVariableNode set)
    {
        StoryVariable? target = StoryLogicFlow.SetTarget(_ProjectState.CurrentProject!, set);
        <div class="vni-head">
            <span class="vni-kind" style="color:@StoryStyle.NodeColor(StoryNodeKind.SetVariable)">
                <span class="vni-dot" style="background:@StoryStyle.NodeColor(StoryNodeKind.SetVariable)"></span>
                @Loc.T(Localization.Editor.Modals.VariableNodeInspector.setVariableKind)
            </span>
            <div class="vni-title">@(target is not null ? Name(target.Name) : Loc.T(Localization.Editor.Modals.VariableNodeInspector.noVariable))</div>
            @if (target is not null && !string.IsNullOrWhiteSpace(target.Description))
            {
                <div class="vni-desc">@target.Description</div>
            }
        </div>
        <div class="vni-body">
            @Meta(target)
            @if (target is { Scope: StoryVariableScope.Internal } iv && iv.InternalSubtype is StoryInternalSubtype.SmallNumber or StoryInternalSubtype.BigPublicNumber or StoryInternalSubtype.BigSecretNumber)
            {
                @Row(Loc.T(Localization.Common.Fields.newValue), AssignmentLabel(set.Assignment, set.SpecificValue, set.RandomMode))
            }
        </div>
    }
    else if (GetNode is StoryGetVariableNode get)
    {
        StoryVariable? target = StoryLogicFlow.GetTarget(_ProjectState.CurrentProject!, get);
        <div class="vni-head">
            <span class="vni-kind" style="color:@StoryStyle.NodeColor(StoryNodeKind.GetVariable)">
                <span class="vni-dot" style="background:@StoryStyle.NodeColor(StoryNodeKind.GetVariable)"></span>
                @Loc.T(Localization.Editor.Modals.VariableNodeInspector.getVariableKind)
            </span>
            <div class="vni-title">@(target is not null ? Name(target.Name) : Loc.T(Localization.Editor.Modals.VariableNodeInspector.noVariable))</div>
            @if (target is not null && !string.IsNullOrWhiteSpace(target.Description))
            {
                <div class="vni-desc">@target.Description</div>
            }
        </div>
        <div class="vni-body">
            @Meta(target)
        </div>
    }

</div>

@code {
    [Parameter] public StoryLogicNode? Logic  { get; set; }
    [Parameter] public Guid            NodeId { get; set; }

    private StorySetVariableNode? SetNode => Logic?.SetVariableNodes.Find(n => n.Id == NodeId);
    private StoryGetVariableNode? GetNode => Logic?.GetVariableNodes.Find(n => n.Id == NodeId);

    private RenderFragment Meta(StoryVariable? v) =>@<text>
        @if (v is { Scope: StoryVariableScope.Internal } iv)
        {
            @Row(Loc.T(Localization.Common.Fields.slot), StoryVariableSlots.Label(iv.InternalSubtype, iv.SlotIndex))
            @Row(Loc.T(Localization.Common.Fields.storage), TypeLabel(StoryVariableSlots.Bank(iv.InternalSubtype)))
        }
    </text>;

    private RenderFragment Row(string label, string value) =>@<div class="vni-row">
        <span class="vni-row-label">@label</span>
        <span class="vni-row-value">@value</span>
    </div>;

    private string Name(string name) => string.IsNullOrWhiteSpace(name) ? Loc.T(Localization.Common.Placeholders.unnamedVariable) : name;

    private string TypeLabel(StorageVariableType type) => type switch
    {
        StorageVariableType.Number => Loc.T(Localization.Editor.Modals.VariableNodeInspector.typeLabelNumber),
        StorageVariableType.Dial   => Loc.T(Localization.Common.Misc.dialRange),
        StorageVariableType.String => Loc.T(Localization.Common.Misc.stringWritten),
        _                          => type.ToString()
    };

    private string AssignmentLabel(NumberAssignment assignment, int specificValue, RandomMode randomMode) => assignment switch
    {
        NumberAssignment.Unset       => Loc.T(Localization.Editor.Modals.VariableNodeInspector.assignmentUnsetNoValue),
        NumberAssignment.SetSpecific => Loc.T(Localization.Editor.Modals.VariableNodeInspector.assignmentSetTo, new Dictionary<string, object> { ["value"] = specificValue }),
        NumberAssignment.Randomize   => $"{Loc.T(Localization.Common.Assignment.randomize)} · {Loc.T(randomMode == RandomMode.Pure ? Localization.Common.Assignment.randomModePure : Localization.Common.Assignment.randomModeSaved)}",
        _                            => assignment.ToString()
    };
}

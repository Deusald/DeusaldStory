@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Read-only inspector for a selected Register / Set / Unregister variable node,
   showing all of its stored configuration. Editing is done from the node's
   right-click "Edit" (which reopens the modal).
   ───────────────────────────────────────────────────────────────────────── *@

<div class="vni-root">

    @if (Register is StoryRegisterVariableNode reg)
    {
        <div class="vni-head">
            <span class="vni-kind" style="color:@StoryStyle.NodeColor(StoryNodeKind.RegisterVariable)">
                <span class="vni-dot" style="background:@StoryStyle.NodeColor(StoryNodeKind.RegisterVariable)"></span>
                @Loc.T(Localization.Editor.Modals.VariableNodeInspector.registerVariableKind)
            </span>
            <div class="vni-title">@Name(reg.Name)</div>
            @if (!string.IsNullOrWhiteSpace(reg.Description))
            {
                <div class="vni-desc">@reg.Description</div>
            }
        </div>

        <div class="vni-body">
            @Row(Loc.T(Localization.Common.Fields.slot), $"{StorageSlots.Label(reg.Type, reg.SlotIndex)}")
            @Row(Loc.T(Localization.Common.Fields.storage), TypeLabel(reg.Type))

            @if (reg.Type == StorageVariableType.Number)
            {
                @Row(Loc.T(Localization.Common.Fields.storedWith), reg.Mode == NumberStorageMode.Dice ? Loc.T(Localization.Common.StoredWith.dice) : Loc.T(Localization.Common.StoredWith.token))
                @Row(Loc.T(Localization.Common.Fields.values), ValueCountLabel(reg.ValueCount))
            }

            @if (reg.Type is StorageVariableType.Number or StorageVariableType.Dial)
            {
                @Row(Loc.T(Localization.Common.Fields.initialValue), AssignmentLabel(reg.Assignment, reg.SpecificValue))
                @if (ShowsSecret(reg.Type, reg.Mode))
                {
                    @Row(Loc.T(Localization.Common.Fields.secret), reg.Secret ? Loc.T(Localization.Common.Misc.yes) : Loc.T(Localization.Common.Misc.no))
                }
            }
        </div>
    }
    else if (SetNode is StorySetVariableNode set)
    {
        StoryRegisterVariableNode? target = EditorProjection.FindRegister(_ProjectState.CurrentProject!, set.RegisteredVariableId);
        <div class="vni-head">
            <span class="vni-kind" style="color:@StoryStyle.NodeColor(StoryNodeKind.SetVariable)">
                <span class="vni-dot" style="background:@StoryStyle.NodeColor(StoryNodeKind.SetVariable)"></span>
                @Loc.T(Localization.Editor.Modals.VariableNodeInspector.setVariableKind)
            </span>
            <div class="vni-title">@(target is not null ? Name(target.Name) : Loc.T(Localization.Editor.Modals.VariableNodeInspector.noVariable))</div>
        </div>
        <div class="vni-body">
            @if (target is not null)
            {
                @Row(Loc.T(Localization.Common.Fields.slot), StorageSlots.Label(target.Type, target.SlotIndex))
                @Row(Loc.T(Localization.Common.Fields.storage), TypeLabel(target.Type))
            }
            @Row(Loc.T(Localization.Common.Fields.newValue), AssignmentLabel(set.Assignment, set.SpecificValue))
            @if (target is not null && ShowsSecret(target.Type, target.Mode))
            {
                @Row(Loc.T(Localization.Common.Fields.secret), set.Secret ? Loc.T(Localization.Common.Misc.yes) : Loc.T(Localization.Common.Misc.no))
            }
        </div>
    }
    else if (Unregister is StoryUnregisterVariableNode unreg)
    {
        StoryRegisterVariableNode? target = EditorProjection.FindRegister(_ProjectState.CurrentProject!, unreg.RegisteredVariableId);
        <div class="vni-head">
            <span class="vni-kind" style="color:@StoryStyle.NodeColor(StoryNodeKind.UnregisterVariable)">
                <span class="vni-dot" style="background:@StoryStyle.NodeColor(StoryNodeKind.UnregisterVariable)"></span>
                @Loc.T(Localization.Editor.Modals.VariableNodeInspector.unregisterVariableKind)
            </span>
            <div class="vni-title">@(target is not null ? Name(target.Name) : Loc.T(Localization.Editor.Modals.VariableNodeInspector.noVariable))</div>
        </div>
        <div class="vni-body">
            @if (target is not null)
            {
                @Row(Loc.T(Localization.Common.Fields.slot), StorageSlots.Label(target.Type, target.SlotIndex))
                @Row(Loc.T(Localization.Common.Fields.storage), TypeLabel(target.Type))
            }
            <div class="vni-note">@Loc.T(Localization.Editor.Modals.VariableNodeInspector.unregisterNote)</div>
        </div>
    }

</div>

@code {
    [Parameter] public StoryLogicNode? Logic  { get; set; }
    [Parameter] public Guid            NodeId { get; set; }

    private StoryRegisterVariableNode?   Register   => Logic?.RegisterVariableNodes.Find(n => n.Id == NodeId);
    private StorySetVariableNode?        SetNode    => Logic?.SetVariableNodes.Find(n => n.Id == NodeId);
    private StoryUnregisterVariableNode? Unregister => Logic?.UnregisterVariableNodes.Find(n => n.Id == NodeId);

    private RenderFragment Row(string label, string value) =>@<div class="vni-row">
        <span class="vni-row-label">@label</span>
        <span class="vni-row-value">@value</span>
    </div>;

    private string Name(string name) => string.IsNullOrWhiteSpace(name) ? Loc.T(Localization.Common.Placeholders.unnamedVariable) : name;

    private string TypeLabel(StorageVariableType type) => type switch
    {
        StorageVariableType.Number => Loc.T(Localization.Editor.Modals.VariableNodeInspector.typeLabelNumber),
        StorageVariableType.Dial   => Loc.T(Localization.Common.Misc.dialRange),
        StorageVariableType.String => Loc.T(Localization.Common.Misc.stringWritten),
        _                          => type.ToString()
    };

    private string ValueCountLabel(NumberValueCount count) => count switch
    {
        NumberValueCount.One   => Loc.T(Localization.Common.ValueCounts.one),
        NumberValueCount.Two   => Loc.T(Localization.Common.ValueCounts.two),
        NumberValueCount.Three => Loc.T(Localization.Common.ValueCounts.three),
        NumberValueCount.Four  => Loc.T(Localization.Common.ValueCounts.four),
        NumberValueCount.Five  => Loc.T(Localization.Common.ValueCounts.five),
        NumberValueCount.Six   => Loc.T(Localization.Common.ValueCounts.six),
        _                      => count.ToString()
    };

    private string AssignmentLabel(NumberAssignment assignment, int specificValue) => assignment switch
    {
        NumberAssignment.Unset       => Loc.T(Localization.Editor.Modals.VariableNodeInspector.assignmentUnsetNoValue),
        NumberAssignment.SetSpecific => Loc.T(Localization.Editor.Modals.VariableNodeInspector.assignmentSetTo, new Dictionary<string, object> { ["value"] = specificValue }),
        NumberAssignment.Randomize   => Loc.T(Localization.Common.Assignment.randomize),
        _                            => assignment.ToString()
    };

    private static bool ShowsSecret(StorageVariableType type, NumberStorageMode mode) =>
        type == StorageVariableType.Dial || (type == StorageVariableType.Number && mode == NumberStorageMode.Token);
}

@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box npm-portal-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@Loc.T(Localization.Editor.Modals.LogicPortal.title)</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            <div class="npm-portal-hint">
                <i class="bi bi-box-arrow-in-right" style="color:var(--orange)"></i>
                @Loc.T(Localization.Editor.Modals.LogicPortal.hint)
            </div>

            @* ── Name ──────────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Common.Fields.name)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@Loc.T(Localization.Editor.Modals.LogicPortal.namePlaceholder)"
                       @bind="_Name"
                       @bind:event="oninput"
                       maxlength="100"/>
            </div>

            @* ── Description ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Common.Fields.description)
                    <span class="modal-label-hint">@Loc.T(Localization.Common.Fields.optional)</span>
                </label>
                <textarea class="modal-input npm-portal-textarea"
                          placeholder="@Loc.T(Localization.Editor.Modals.LogicPortal.descriptionPlaceholder)"
                          @bind="_Description"
                          @bind:event="oninput"
                          rows="2"
                          maxlength="500"></textarea>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @Loc.T(Localization.Common.Buttons.saveChanges)
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<LogicPortalNodeArgs> OnConfirm { get; set; }

    private bool   _Visible;
    private Guid   _PointId;
    private string _Name        = "";
    private string _Description = "";

    /// <summary>Opens the modal to rename / re-describe an existing logic portal, keyed by the clicked in/out point id.</summary>
    public void ShowEdit(Guid pointId, string name, string description)
    {
        _PointId     = pointId;
        _Name        = name;
        _Description = description;
        _Visible     = true;
        StateHasChanged();
    }

    private bool _CanConfirm => !string.IsNullOrWhiteSpace(_Name);

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;
        await OnConfirm.InvokeAsync(new LogicPortalNodeArgs(_PointId, _Name.Trim(), _Description.Trim()));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="PointId"/> is the clicked in/out point of the portal to rename.</summary>
    public record LogicPortalNodeArgs(Guid PointId, string Name, string Description);
}

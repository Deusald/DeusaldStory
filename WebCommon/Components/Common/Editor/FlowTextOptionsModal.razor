@namespace DeusaldStoryWeb.Components.Common

@* ─────────────────────────────────────────────────────────────────────────
   Edits a FlowText block's per-medium render flags. A FlowText node normally
   renders its text in both mediums; unchecking a medium here skips this block's
   text while rendering that medium (flow still passes through to the next node).
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box fto-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">FlowText options</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            <div class="modal-field">
                <label class="fto-check">
                    <input type="checkbox"
                           checked="@_RenderInApp"
                           @onchange="e => _RenderInApp = (bool)(e.Value ?? false)"/>
                    <span>
                        Render in App
                        <span class="modal-label-hint">show this block's text in the interactive app preview</span>
                    </span>
                </label>
            </div>

            <div class="modal-field">
                <label class="fto-check">
                    <input type="checkbox"
                           checked="@_RenderInGamebook"
                           @onchange="e => _RenderInGamebook = (bool)(e.Value ?? false)"/>
                    <span>
                        Render in Gamebook
                        <span class="modal-label-hint">show this block's text in the printed gamebook sections</span>
                    </span>
                </label>
            </div>

            <div class="modal-note">
                <i class="bi bi-info-circle"></i>
                <span>Unchecking a medium only hides this block's text there — flow still passes through to the next node.</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm">Save changes</button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<FlowTextArgs> OnConfirm { get; set; }

    private bool _Visible;
    private Guid _EditNodeId;
    private bool _RenderInApp      = true;
    private bool _RenderInGamebook = true;

    /// <summary>Opens the modal to edit an existing FlowText node's render flags.</summary>
    public void ShowEdit(StoryFlowTextNode node)
    {
        _EditNodeId       = node.Id;
        _RenderInApp      = node.RenderInApp;
        _RenderInGamebook = node.RenderInGamebook;
        _Visible          = true;
        StateHasChanged();
    }

    private async Task Confirm()
    {
        _Visible = false;
        await OnConfirm.InvokeAsync(new FlowTextArgs(_EditNodeId, _RenderInApp, _RenderInGamebook));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent — the edited node id plus its new per-medium render flags.</summary>
    public record FlowTextArgs(Guid EditNodeId, bool RenderInApp, bool RenderInGamebook);
}

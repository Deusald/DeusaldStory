@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@* ─────────────────────────────────────────────────────────────────────────
   Edits a FlowText block's per-medium render flags. A FlowText node normally
   renders its text in both mediums; unchecking a medium here skips this block's
   text while rendering that medium (flow still passes through to the next node).
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box fto-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@Loc.T(Localization.Editor.Modals.FlowTextOptions.title)</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Editor.Modals.FlowTextOptions.frameStyleLabel)</label>
                <select class="modal-input" @bind="_FrameStyle">
                    @foreach (StoryTextFrameStyle style in Enum.GetValues<StoryTextFrameStyle>())
                    {
                        <option value="@style">@StoryStyle.FrameLabel(style)</option>
                    }
                </select>
                <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.FlowTextOptions.frameStyleHint)</span>
            </div>

            <div class="modal-field">
                <label class="fto-check">
                    <input type="checkbox"
                           checked="@_RenderInApp"
                           @onchange="e => _RenderInApp = (bool)(e.Value ?? false)"/>
                    <span>
                        @Loc.T(Localization.Editor.Modals.FlowTextOptions.renderInAppLabel)
                        <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.FlowTextOptions.renderInAppHint)</span>
                    </span>
                </label>
            </div>

            <div class="modal-field">
                <label class="fto-check">
                    <input type="checkbox"
                           checked="@_RenderInGamebook"
                           @onchange="e => _RenderInGamebook = (bool)(e.Value ?? false)"/>
                    <span>
                        @Loc.T(Localization.Editor.Modals.FlowTextOptions.renderInGamebookLabel)
                        <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.FlowTextOptions.renderInGamebookHint)</span>
                    </span>
                </label>
            </div>

            <div class="modal-note">
                <i class="bi bi-info-circle"></i>
                <span>@Loc.T(Localization.Editor.Modals.FlowTextOptions.uncheckMediumHint)</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm">@Loc.T(Localization.Common.Buttons.saveChanges)</button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<FlowTextArgs> OnConfirm { get; set; }

    private bool                _Visible;
    private Guid                _EditNodeId;
    private bool                _RenderInApp      = true;
    private bool                _RenderInGamebook = true;
    private StoryTextFrameStyle _FrameStyle       = StoryTextFrameStyle.Normal;

    /// <summary>Opens the modal to edit an existing FlowText node's render flags and frame style.</summary>
    public void ShowEdit(StoryFlowTextNode node)
    {
        _EditNodeId       = node.Id;
        _RenderInApp      = node.RenderInApp;
        _RenderInGamebook = node.RenderInGamebook;
        _FrameStyle       = node.FrameStyle;
        _Visible          = true;
        StateHasChanged();
    }

    private async Task Confirm()
    {
        _Visible = false;
        await OnConfirm.InvokeAsync(new FlowTextArgs(_EditNodeId, _RenderInApp, _RenderInGamebook, _FrameStyle));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent — the edited node id plus its new per-medium render flags and frame style.</summary>
    public record FlowTextArgs(Guid EditNodeId, bool RenderInApp, bool RenderInGamebook, StoryTextFrameStyle FrameStyle);
}

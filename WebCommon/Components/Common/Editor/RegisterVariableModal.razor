@namespace DeusaldStoryWeb.Components.Common
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Register-variable node: defines a storage variable's
   identity (name, description, storage type), claims a physical slot, and sets
   how its initial value is assigned. Used by both the create and edit flows.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box rvm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? "Edit variable" : "Register variable")</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            @* ── Name ──────────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">Name</label>
                <input class="modal-input"
                       type="text"
                       placeholder="Secret treasure number"
                       @bind="_Name"
                       @bind:event="oninput"
                       maxlength="100"/>
            </div>

            @* ── Description ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    Description
                    <span class="modal-label-hint">optional</span>
                </label>
                <textarea class="modal-input rvm-textarea"
                          placeholder="What this variable represents in the story…"
                          @bind="_Description"
                          @bind:event="oninput"
                          rows="2"
                          maxlength="500"></textarea>
            </div>

            @* ── Storage type + slot ───────────────────────────────────── *@
            <div class="rvm-row">
                <div class="modal-field rvm-grow">
                    <label class="modal-label">Storage type</label>
                    <select class="modal-input" @bind="_Type">
                        <option value="@StorageVariableType.Number">Number (D6 / token)</option>
                        <option value="@StorageVariableType.Dial">Dial (−7…7)</option>
                        <option value="@StorageVariableType.String">String (written)</option>
                    </select>
                </div>
                <div class="modal-field rvm-grow">
                    <label class="modal-label">Slot</label>
                    <select class="modal-input" @bind="_SlotIndex">
                        @foreach (int i in AvailableSlots())
                        {
                            <option value="@i">@StorageSlots.Label(_Type, i)</option>
                        }
                    </select>
                </div>
            </div>

            @if (_Type == StorageVariableType.Number)
            {
                @* ── Number storage mode + value count ──────────────────── *@
                <div class="rvm-row">
                    <div class="modal-field rvm-grow">
                        <label class="modal-label">Stored with</label>
                        <select class="modal-input" @bind="_Mode">
                            <option value="@NumberStorageMode.Dice">D6 die</option>
                            <option value="@NumberStorageMode.Token">Number token</option>
                        </select>
                    </div>
                    <div class="modal-field rvm-grow">
                        <label class="modal-label">Values</label>
                        <select class="modal-input" @bind="_ValueCount">
                            <option value="@NumberValueCount.One">1 — presence flag</option>
                            <option value="@NumberValueCount.Two">2 — even / odd</option>
                            <option value="@NumberValueCount.Three">3 — 1&2 / 3&4 / 5&6</option>
                            <option value="@NumberValueCount.Four">4 — 1 / 2 / 3 / 4</option>
                            <option value="@NumberValueCount.Five">5 — 1 … 5</option>
                            <option value="@NumberValueCount.Six">6 — 1 … 6</option>
                        </select>
                    </div>
                </div>
            }

            @if (_Type is StorageVariableType.Number or StorageVariableType.Dial)
            {
                @* ── Assignment ────────────────────────────────────────── *@
                <div class="modal-field">
                    <label class="modal-label">Initial value</label>
                    <select class="modal-input" @bind="_Assignment">
                        <option value="@NumberAssignment.Unset">Leave unset (no instruction)</option>
                        <option value="@NumberAssignment.SetSpecific">Set to a specific value</option>
                        <option value="@NumberAssignment.Randomize">Randomize (roll / draw)</option>
                    </select>
                </div>

                @if (_Assignment == NumberAssignment.SetSpecific)
                {
                    <div class="modal-field">
                        <label class="modal-label">Value</label>
                        <input class="modal-input"
                               type="number"
                               min="@ValueMin"
                               max="@ValueMax"
                               @bind="_SpecificValue"
                               @bind:event="oninput"/>
                    </div>
                }

                @if (_Type == StorageVariableType.Dial ||
                    (_Type == StorageVariableType.Number && _Mode == NumberStorageMode.Token))
                {
                    <div class="modal-field">
                        <label class="rvm-check">
                            <input type="checkbox"
                                   checked="@_Secret"
                                   @onchange="e => _Secret = (bool)(e.Value ?? false)"/>
                            <span>
                                Secret
                                <span class="modal-label-hint">players set / draw it without learning the value until told</span>
                            </span>
                        </label>
                    </div>
                }
            }

            @if (_Type == StorageVariableType.String)
            {
                @* ── String value mode ─────────────────────────────────── *@
                <div class="modal-field">
                    <label class="modal-label">Value</label>
                    <select class="modal-input" @bind="_StringMode">
                        <option value="@StringValueMode.Unset">Leave unset (no instruction)</option>
                        <option value="@StringValueMode.Specific">Set a specific value</option>
                        <option value="@StringValueMode.PlayerInput">Player fills it in</option>
                    </select>
                </div>

                @if (_StringMode == StringValueMode.Specific)
                {
                    <div class="modal-field">
                        <label class="modal-label">Written value</label>
                        <input class="modal-input"
                               type="text"
                               placeholder="What the player writes on the slot"
                               @bind="_StringValue"
                               @bind:event="oninput"
                               maxlength="30"/>
                    </div>
                }

                @if (_StringMode == StringValueMode.PlayerInput)
                {
                    <div class="modal-field">
                        <label class="modal-label">Player enters</label>
                        <select class="modal-input" @bind="_StringInputKind">
                            <option value="@StringInputKind.Text">Text</option>
                            <option value="@StringInputKind.Number">Number</option>
                        </select>
                        <span class="modal-label-hint">
                            App shows an input field. Wire a Localization node into the node's Instruction port to tell
                            the player what to write, and into its Placeholder port to set the hint shown inside the field.
                            Reference this variable's slot in the instruction text as <code>@_SlotToken</code>.
                        </span>
                    </div>

                    <div class="modal-note">
                        <i class="bi bi-info-circle"></i>
                        <span>The checks below are enforced in the <b>App</b> only — the printed Gamebook cannot validate a written entry.</span>
                    </div>

                    @* ── Character-limit range ──────────────────────────── *@
                    <div class="rvm-row">
                        <div class="modal-field rvm-grow">
                            <label class="modal-label">Min length</label>
                            <input class="modal-input"
                                   type="number"
                                   min="0"
                                   max="@_MaxLength"
                                   @bind="_MinLength"
                                   @bind:event="oninput"/>
                        </div>
                        <div class="modal-field rvm-grow">
                            <label class="modal-label">Max length</label>
                            <input class="modal-input"
                                   type="number"
                                   min="1"
                                   max="500"
                                   @bind="_MaxLength"
                                   @bind:event="oninput"/>
                        </div>
                    </div>

                    @* ── Message shown when the entry length is out of range ── *@
                    <div class="modal-field">
                        <label class="modal-label">
                            Length error message
                            <span class="modal-label-hint">shown when the entry is outside the range</span>
                        </label>
                        <div class="rvm-keyrow">
                            <span class="rvm-keyname @(_LengthErrorKeyId == Guid.Empty ? "rvm-keyname-empty" : "")">@KeyLabel(_LengthErrorKeyId)</span>
                            <button class="modal-btn modal-btn-ghost rvm-keybtn" @onclick="PickLengthErrorKey">Pick key</button>
                            @if (_LengthErrorKeyId != Guid.Empty)
                            {
                                <button class="modal-btn modal-btn-ghost rvm-keybtn" @onclick="() => _LengthErrorKeyId = Guid.Empty">Clear</button>
                            }
                        </div>
                    </div>

                    @* ── Validation rule (reuses the exit auto-condition builder) ── *@
                    <div class="modal-field">
                        <label class="modal-label">
                            Validation rule
                            <span class="modal-label-hint">optional — the entry is accepted only when this holds</span>
                        </label>
                        <span class="modal-label-hint">
                            Compare <b>This entry</b> against another variable or a typed value — e.g. <b>This entry ≠ [Name]</b>
                            to force a value different from another variable. An empty rule accepts anything.
                        </span>
                        <div class="rvm-rule">
                            <ExitConditionEditor Expr="_ValidationRule" Vars="RuleVars()" OnChanged="StateHasChanged"/>
                        </div>
                    </div>

                    @if (_ValidationRule.Children.Count > 0)
                    {
                        <div class="modal-field">
                            <label class="modal-label">
                                Rule error message
                                <span class="modal-label-hint">shown when the rule is not met</span>
                            </label>
                            <div class="rvm-keyrow">
                                <span class="rvm-keyname @(_ValidationErrorKeyId == Guid.Empty ? "rvm-keyname-empty" : "")">@KeyLabel(_ValidationErrorKeyId)</span>
                                <button class="modal-btn modal-btn-ghost rvm-keybtn" @onclick="PickValidationErrorKey">Pick key</button>
                                @if (_ValidationErrorKeyId != Guid.Empty)
                                {
                                    <button class="modal-btn modal-btn-ghost rvm-keybtn" @onclick="() => _ValidationErrorKeyId = Guid.Empty">Clear</button>
                                }
                            </div>
                        </div>
                    }
                }
            }

            @* ── Preview value ──────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    Preview value
                    <span class="modal-label-hint">optional</span>
                </label>
                <input class="modal-input"
                       type="text"
                       placeholder="value shown when a Get variable reads this in the App preview"
                       @bind="_PreviewValue"
                       @bind:event="oninput"
                       maxlength="100"/>
                <span class="modal-label-hint">the App tracks the live value at play time; used by a Get variable node that leaves its own preview value blank</span>
            </div>

            @* ── Gamebook / App placement ───────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">Placement</label>
                <select class="modal-input" @bind="_Placement">
                    <option value="@StorageInstructionPlacement.Below">Below the text</option>
                    <option value="@StorageInstructionPlacement.Above">Above the text</option>
                </select>
                <span class="modal-label-hint">where the instruction / input field sits relative to the section text</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @(_IsEdit ? "Save changes" : "Register")
            </button>
        </div>

    </div>
}

@* Localization key picker for the validation messages — elevated so it stacks above this modal. *@
<LocalizationKeyPickerModal @ref="_KeyPicker" Elevated="true" OnConfirm="OnKeyPicked"/>

@code {
    [Parameter] public EventCallback<RegisterVariableArgs> OnConfirm { get; set; }

    /// <summary>Free slot indices per type at the target node, supplied when opening. Null for a type = list every slot.</summary>
    private IReadOnlyDictionary<StorageVariableType, IReadOnlyList<int>>? FreeSlots;

    private bool _Visible;
    private bool _IsEdit;
    private Guid _EditNodeId;

    private string              _Name        = "";
    private string              _Description = "";
    private StorageVariableType _Type        = StorageVariableType.Number;
    private int                 _SlotIndex;
    private NumberStorageMode   _Mode        = NumberStorageMode.Dice;
    private NumberValueCount    _ValueCount  = NumberValueCount.Six;
    private bool                _Secret;
    private NumberAssignment    _Assignment  = NumberAssignment.Unset;
    private int                 _SpecificValue;
    private Guid                _ConditionKeyId;

    private StorageInstructionPlacement _Placement;
    private StringValueMode             _StringMode;
    private string                      _StringValue = "";
    private StringInputKind             _StringInputKind;
    private string                      _PreviewValue = "";

    private int                _MinLength = 1;
    private int                _MaxLength = 30;
    private Guid               _LengthErrorKeyId;
    private StoryConditionExpr _ValidationRule = new() { Kind = StoryConditionExprKind.Group };
    private Guid               _ValidationErrorKeyId;

    private LocalizationKeyPickerModal? _KeyPicker;
    private KeyPickTarget               _PickTarget; // which validation message the key picker is currently choosing
    private enum KeyPickTarget { LengthError, ValidationError }

    /// <summary>Opens the modal to register a brand-new variable. <paramref name="freeSlots"/> restricts the slot list.</summary>
    public void Show(IReadOnlyDictionary<StorageVariableType, IReadOnlyList<int>>? freeSlots = null)
    {
        FreeSlots       = freeSlots;
        _IsEdit         = false;
        _EditNodeId     = Guid.Empty;
        _Name           = "";
        _Description    = "";
        _Type           = StorageVariableType.Number;
        _SlotIndex      = FirstFreeSlot(StorageVariableType.Number);
        _Mode           = NumberStorageMode.Dice;
        _ValueCount     = NumberValueCount.Six;
        _Secret         = false;
        _Assignment     = NumberAssignment.Unset;
        _SpecificValue  = 1;
        _ConditionKeyId = Guid.Empty;
        _Placement       = StorageInstructionPlacement.Below;
        _StringMode      = StringValueMode.Unset;
        _StringValue     = "";
        _StringInputKind = StringInputKind.Text;
        _PreviewValue    = "";
        _MinLength            = 1;
        _MaxLength            = 30;
        _LengthErrorKeyId     = Guid.Empty;
        _ValidationRule       = new() { Kind = StoryConditionExprKind.Group };
        _ValidationErrorKeyId = Guid.Empty;
        _Visible        = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Register-variable node. <paramref name="freeSlots"/> restricts the slot list.</summary>
    public void ShowEdit(StoryRegisterVariableNode node, IReadOnlyDictionary<StorageVariableType, IReadOnlyList<int>>? freeSlots = null)
    {
        FreeSlots       = freeSlots;
        _IsEdit         = true;
        _EditNodeId     = node.Id;
        _Name           = node.Name;
        _Description    = node.Description;
        _Type           = node.Type;
        _SlotIndex      = node.SlotIndex;
        _Mode           = node.Mode;
        _ValueCount     = node.ValueCount;
        _Secret         = node.Secret;
        _Assignment     = node.Assignment;
        _SpecificValue  = node.SpecificValue;
        _ConditionKeyId = node.ConditionKeyId;
        _Placement       = node.Placement;
        _StringMode      = node.StringMode;
        _StringValue     = node.StringValue;
        _StringInputKind = node.StringInputKind;
        _PreviewValue    = node.PreviewValue;
        _MinLength            = node.MinLength;
        _MaxLength            = node.MaxLength;
        _LengthErrorKeyId     = node.LengthErrorKeyId;
        _ValidationRule       = node.ValidationRule?.Clone() ?? new StoryConditionExpr { Kind = StoryConditionExprKind.Group };
        _ValidationErrorKeyId = node.ValidationErrorKeyId;
        _Visible        = true;
        StateHasChanged();
    }

    // The value the currently-edited node already sits on is always offered even if "occupied" by itself.
    private IEnumerable<int> AvailableSlots()
    {
        List<int> slots = new();
        if (FreeSlots is not null && FreeSlots.TryGetValue(_Type, out IReadOnlyList<int>? free))
            slots.AddRange(free);
        else
            for (int i = 0; i < StorageSlots.Count(_Type); ++i) slots.Add(i);

        if (_IsEdit && !slots.Contains(_SlotIndex)) slots.Add(_SlotIndex);
        slots.Sort();
        if (slots.Count == 0) slots.Add(_SlotIndex);
        return slots;
    }

    private int FirstFreeSlot(StorageVariableType type) => AvailableSlotsFor(type).FirstOrDefault();

    private IEnumerable<int> AvailableSlotsFor(StorageVariableType type)
    {
        if (FreeSlots is not null && FreeSlots.TryGetValue(type, out IReadOnlyList<int>? free) && free.Count > 0)
            return free;
        return Enumerable.Range(0, StorageSlots.Count(type));
    }

    private int ValueMin => _Type == StorageVariableType.Dial ? -7 : 1;
    private int ValueMax => _Type == StorageVariableType.Dial ? 7  : StorageSlots.ToNumber(_ValueCount);

    // ── Player-input String validation helpers ─────────────────────────────

    /// <summary>The operands the validation rule can reference: "This entry" plus every other registered variable.</summary>
    private List<(Guid Id, string Name)> RuleVars()
    {
        List<(Guid, string)> vars = new() { (StorageValidation.ThisEntryRef, "This entry") };
        if (_ProjectState.CurrentProject is not null)
            foreach (StoryLogicNode logic in _ProjectState.CurrentProject.LogicNodes.Values)
                foreach (StoryRegisterVariableNode reg in logic.RegisterVariableNodes.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase))
                    if (reg.Id != _EditNodeId)
                        vars.Add((reg.Id, $"{(string.IsNullOrWhiteSpace(reg.Name) ? "(unnamed)" : reg.Name)} [{StorageSlots.Label(reg.Type, reg.SlotIndex)}]"));
        return vars;
    }

    /// <summary>The localization key's display name, or a placeholder when none is picked.</summary>
    private string KeyLabel(Guid keyId)
    {
        if (keyId == Guid.Empty) return "Default message";
        return _ProjectState.CurrentLocalization?.Keys.Find(k => k.Id == keyId)?.KeyName ?? "(missing key)";
    }

    private void PickLengthErrorKey()
    {
        _PickTarget = KeyPickTarget.LengthError;
        _KeyPicker?.Show(Guid.Empty, _LengthErrorKeyId);
    }

    private void PickValidationErrorKey()
    {
        _PickTarget = KeyPickTarget.ValidationError;
        _KeyPicker?.Show(Guid.Empty, _ValidationErrorKeyId);
    }

    private void OnKeyPicked(LocalizationKeyPickerModal.LocalizationPickResult result)
    {
        if (_PickTarget == KeyPickTarget.LengthError) _LengthErrorKeyId     = result.KeyId;
        else                                          _ValidationErrorKeyId = result.KeyId;
        StateHasChanged();
    }

    private bool _CanConfirm => !string.IsNullOrWhiteSpace(_Name);

    /// <summary>The <c>{token}</c> the instruction text uses to inject this variable's slot pill (mirrors <c>StoryLogicRenderer.SlotTokenName</c>).</summary>
    private string _SlotToken => "{" + (string.IsNullOrWhiteSpace(_Name) ? "<name>" : _Name.Trim()) + "Slot}";

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;

        int specific = Math.Clamp(_SpecificValue, ValueMin, ValueMax);

        int maxLen = Math.Clamp(_MaxLength, 1, 500);
        int minLen = Math.Clamp(_MinLength, 0, maxLen);

        await OnConfirm.InvokeAsync(new RegisterVariableArgs(
            _EditNodeId,
            _Name.Trim(),
            _Description.Trim(),
            _Type,
            _SlotIndex,
            _Mode,
            _ValueCount,
            _Secret,
            _Assignment,
            specific,
            _ConditionKeyId,
            _Placement,
            _StringMode,
            _StringValue.Trim(),
            _StringInputKind,
            _PreviewValue.Trim(),
            minLen,
            maxLen,
            _LengthErrorKeyId,
            _ValidationRule.Children.Count > 0 ? _ValidationRule.Clone() : null,
            _ValidationErrorKeyId));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record RegisterVariableArgs(
        Guid                        EditNodeId,
        string                      Name,
        string                      Description,
        StorageVariableType         Type,
        int                         SlotIndex,
        NumberStorageMode           Mode,
        NumberValueCount            ValueCount,
        bool                        Secret,
        NumberAssignment            Assignment,
        int                         SpecificValue,
        Guid                        ConditionKeyId,
        StorageInstructionPlacement Placement,
        StringValueMode             StringMode,
        string                      StringValue,
        StringInputKind             StringInputKind,
        string                      PreviewValue,
        int                         MinLength,
        int                         MaxLength,
        Guid                        LengthErrorKeyId,
        StoryConditionExpr?         ValidationRule,
        Guid                        ValidationErrorKeyId);
}

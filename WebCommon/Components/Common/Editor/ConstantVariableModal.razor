@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Constant Variable node: a named constant value wired into a
   SmartFormat variables input to format text with a fixed
   value. The value is constant, so it never dimensions Gamebook sections.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box cvm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.ConstantVariable.editTitle) : Loc.T(Localization.Editor.Modals.ConstantVariable.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Common.Fields.name)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@Loc.T(Localization.Editor.Modals.ConstantVariable.tokenNamePlaceholder)"
                       @bind="_Name"
                       @bind:event="oninput"
                       maxlength="100"/>
                <span class="modal-label-hint">@((MarkupString)Loc.T(Localization.Editor.Modals.ConstantVariable.tokenNameHint))</span>
            </div>

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Common.Fields.value)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@Loc.T(Localization.Editor.Modals.ConstantVariable.valuePlaceholder)"
                       @bind="_Value"
                       @bind:event="oninput"
                       maxlength="200"/>
            </div>

            <div class="modal-note">
                <i class="bi bi-info-circle"></i>
                <span>@((MarkupString)Loc.T(Localization.Editor.Modals.ConstantVariable.note))</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(string.IsNullOrWhiteSpace(_Name))">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : Loc.T(Localization.Editor.Modals.ConstantVariable.addButton))
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<ConstantVariableArgs> OnConfirm { get; set; }

    private bool   _Visible;
    private bool   _IsEdit;
    private Guid   _EditNodeId;
    private string _Name  = "";
    private string _Value = "";

    /// <summary>Opens the modal to create a new Constant Variable node.</summary>
    public void Show()
    {
        _IsEdit     = false;
        _EditNodeId = Guid.Empty;
        _Name       = "";
        _Value      = "";
        _Visible    = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Constant Variable node.</summary>
    public void ShowEdit(StoryConstantVariableNode node)
    {
        _IsEdit     = true;
        _EditNodeId = node.Id;
        _Name       = node.Name;
        _Value      = node.Value;
        _Visible    = true;
        StateHasChanged();
    }

    private async Task Confirm()
    {
        if (string.IsNullOrWhiteSpace(_Name)) return;
        _Visible = false;
        await OnConfirm.InvokeAsync(new ConstantVariableArgs(_EditNodeId, _Name.Trim(), _Value.Trim()));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record ConstantVariableArgs(Guid EditNodeId, string Name, string Value);
}

@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Comment note — a free-text annotation the author places on
   a graph to explain how things connect. It has no ports and is ignored during
   playback. The same modal is used inside a container's graph and inside a
   logic node's inner graph.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box ncm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.Comment.editTitle) : Loc.T(Localization.Editor.Modals.Comment.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Editor.Modals.Comment.noteLabel)</label>
                <textarea class="modal-input ncm-text"
                          rows="5"
                          placeholder="@Loc.T(Localization.Editor.Modals.Comment.notePlaceholder)"
                          @bind="_Text"
                          @bind:event="oninput"></textarea>
            </div>

            <div class="modal-note">
                <i class="bi bi-info-circle"></i>
                <span>@Loc.T(Localization.Editor.Modals.Comment.noteHint)</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : Loc.T(Localization.Editor.Modals.Comment.addButton))
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<CommentArgs> OnConfirm { get; set; }

    private bool   _Visible;
    private bool   _IsEdit;
    private Guid   _EditNodeId;
    private string _Text = "";

    /// <summary>Opens the modal to create a new Comment note.</summary>
    public void Show()
    {
        _IsEdit     = false;
        _EditNodeId = Guid.Empty;
        _Text       = "";
        _Visible    = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Comment note.</summary>
    public void ShowEdit(Guid nodeId, string text)
    {
        _IsEdit     = true;
        _EditNodeId = nodeId;
        _Text       = text;
        _Visible    = true;
        StateHasChanged();
    }

    private async Task Confirm()
    {
        _Visible = false;
        await OnConfirm.InvokeAsync(new CommentArgs(_EditNodeId, _Text.Trim()));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record CommentArgs(Guid EditNodeId, string Text);
}

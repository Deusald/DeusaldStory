@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   The App preview: renders a logic node's output as a screen — the localized
   title (Entry's Title input) as a heading with the connected icon and, when
   connected, a smaller subtitle beneath it, then the ordered sequence of text
   blocks produced by walking the flow spine. Content is resolved for the
   External Variable values the author tweaks in the inspector (passed in via
   Values), shared with the Gamebook preview through StoryLogicRenderer.

   A Dark/Light toggle flips only the inner window between the dark theme and a
   paper-like light theme; it also decides which side of a Light/Dark switch node
   is shown. A "Click here to continue…" button per exit jumps the preview on to
   the next logic node (OnContinue).
   ───────────────────────────────────────────────────────────────────────── *@

<div class="lpv-root">

    <div class="lpv-toolbar">
        <div class="lpv-toggle">
            <button class="lpv-toggle-btn @(_Paper ? "" : "active")" @onclick="() => SetPaper(false)">
                <i class="bi bi-moon-stars-fill"></i> @Loc.T(Localization.Editor.Preview.Logic.themeDark)
            </button>
            <button class="lpv-toggle-btn @(_Paper ? "active" : "")" @onclick="() => SetPaper(true)">
                <i class="bi bi-sun-fill"></i> @Loc.T(Localization.Editor.Preview.Logic.themeLight)
            </button>
        </div>
    </div>

    <div class="lpv-screen @(_Paper ? "paper" : "")">

        @if (Logic.GamebookInstructions)
        {
            @* This node has no player-facing screen in the app — it runs silently and only prints a
               generated instruction section in the Gamebook. Badge it so the author knows. *@
            <div class="lpv-gb-badge">
                <i class="bi bi-gear-fill"></i> @Loc.T(Localization.Editor.Preview.Logic.gamebookInstructionsBadge)
            </div>
        }

        <div class="lpv-head">
            @if (_Rendered.IconData is not null)
            {
                <div class="lpv-icon">
                    <img src="data:image/png;base64,@_Rendered.IconData" alt="@Loc.T(Localization.Editor.Preview.iconAlt)"/>
                </div>
            }
            <div class="lpv-titles">
                @if (string.IsNullOrEmpty(_Rendered.Title))
                {
                    <div class="lpv-title lpv-placeholder">@Loc.T(Localization.Editor.Preview.noTitleConnected)</div>
                }
                else
                {
                    <div class="lpv-title">@SafeHtml(_Rendered.Title)</div>
                }
                @if (!string.IsNullOrEmpty(_Rendered.Subtitle))
                {
                    <div class="lpv-subtitle">@SafeHtml(_Rendered.Subtitle)</div>
                }
            </div>
        </div>

        @{
            int  pageCount = Math.Max(1, _Rendered.Pages.Count);
            int  pageIndex = Math.Clamp(_Page, 0, pageCount - 1);
            bool lastPage  = pageIndex >= pageCount - 1;
            StoryLogicRenderer.RenderedPage page = pageIndex < _Rendered.Pages.Count ? _Rendered.Pages[pageIndex] : new();
            bool nodeHasBlocks = _Rendered.Pages.Any(p => p.Blocks.Count > 0);
        }

        @if (pageCount > 1)
        {
            <div class="lpv-page-tag">@Loc.T(Localization.Editor.Preview.Logic.pageTag, new Dictionary<string, object> { ["page"] = pageIndex + 1, ["total"] = pageCount })</div>
        }

        @* Player-input String fields sit above the text when so placed. Number/Dial/specific values store silently. *@
        @foreach (StorageInstruction field in page.Above)
        {
            @InputField(field)
        }

        @if (!nodeHasBlocks)
        {
            <div class="lpv-block lpv-placeholder">@Loc.T(Localization.Editor.Preview.Logic.noTextBlocks)</div>
        }
        else
        {
            @foreach (StoryLogicRenderer.RenderedBlock block in page.Blocks)
            {
                @if (string.IsNullOrEmpty(block.Text))
                {
                    <div class="lpv-block lpv-placeholder">@Loc.T(Localization.Editor.Preview.Logic.emptyText)</div>
                }
                else
                {
                    StoryTextFrameStyle style = block.FrameStyle;
                    <div class="lpv-block @FrameClass(style)">
                        @if (StoryStyle.FrameIcon(style) is { Length: > 0 } frameIcon)
                        {
                            <i class="lpv-block-icon bi @frameIcon" title="@StoryStyle.FrameLabel(style)"></i>
                        }
                        <span class="lpv-block-text">@SafeHtml(block.Text)</span>
                    </div>
                }
            }
        }

        @foreach (StorageInstruction field in page.Below)
        {
            @InputField(field)
        }

        @if (!lastPage)
        {
            @* A Split-for-App break — advance to the next page of this same node (title/subtitle/icon stay). *@
            <div class="lpv-continue">
                <button class="lpv-continue-btn" @onclick="() => _Page = pageIndex + 1">
                    <span>@_ContinueLabel</span>
                    <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        }
        else if (_Rendered.Choices.Count > 0)
        {
            @* Choice buttons — each advances the preview along that choice's continuation. *@
            <div class="lpv-continue">
                @foreach (StoryLogicRenderer.RenderedChoice c in _Rendered.Choices)
                {
                    StoryLogicRenderer.RenderedChoice choice = c;
                    <button class="lpv-continue-btn"
                            disabled="@(choice.OuterFlowOut == Guid.Empty)"
                            @onclick="() => OnContinue.InvokeAsync(choice)">
                        <span>@(string.IsNullOrEmpty(choice.Text) ? _ContinueLabel : SafeHtml(choice.Text))</span>
                        <i class="bi bi-arrow-right"></i>
                    </button>
                }
            </div>
        }
        else
        {
            @* No choices — the Exit node needs at least one continuation. *@
            <div class="lpv-continue">
                <button class="lpv-continue-btn" disabled>
                    <span class="lpv-placeholder">@Loc.T(Localization.Editor.Preview.Logic.addChoiceOnExit)</span>
                </button>
            </div>
        }

    </div>
</div>

@code {
    [Parameter] public StoryLogicNode Logic { get; set; } = default!;

    /// <summary>
    /// The project <see cref="Logic"/> belongs to — the preview session's own, chosen once by the parent (the flattened
    /// story, or authoring space with functions inlined for a blueprint definition previewed on its own). Everything
    /// this component resolves must come from it, so the whole session speaks one set of ids.
    /// </summary>
    [Parameter] public StoryProject Project { get; set; } = default!;

    /// <summary>A preview-only input field the player would fill for a player-input String variable (min 1 / max 30 chars).</summary>
    private RenderFragment InputField(StorageInstruction field) =>@<div class="lpv-input">
        @* No slot badge here — the App tracks which variable a value writes to automatically; the player only sees the prompt. *@
        <label class="lpv-input-label">
            @if (string.IsNullOrEmpty(field.Text))
            {
                <span class="lpv-placeholder">@Loc.T(Localization.Editor.Preview.Logic.noInstructionConnected)</span>
            }
            else
            {
                @SafeHtml(field.Text)
            }
        </label>
        <input class="lpv-input-box"
               type="@(field.InputKind == StringInputKind.Number ? "number" : "text")"
               minlength="1"
               maxlength="@(field.MaxLength > 0 ? field.MaxLength : 30)"
               placeholder="@(!string.IsNullOrEmpty(field.Placeholder) ? field.Placeholder : field.InputKind == StringInputKind.Number ? Loc.T(Localization.Editor.Preview.Logic.inputEnterNumber) : Loc.T(Localization.Editor.Preview.Logic.inputEnterText))"/>
    </div>;

    /// <summary>External Variable values driving SmartFormat blocks (variable id → value); owned by the parent.</summary>
    [Parameter] public Dictionary<Guid, string> Values { get; set; } = new();

    /// <summary>Raised when a continue button is clicked; carries the chosen continuation to follow to the next node.</summary>
    [Parameter] public EventCallback<StoryLogicRenderer.RenderedChoice> OnContinue { get; set; }

    private bool _Paper; // false = dark (default), true = paper/light
    private int  _Page;  // current Split-for-App page shown (reset when the previewed node changes)

    private StoryLogicRenderer.RenderedLogic _Rendered = new();
    private string                           _ContinueLabel = "";
    private Guid                             _RenderedLogicId;

    protected override void OnParametersSet()
    {
        _Rendered      = Render();
        _ContinueLabel = StoryCommonLocalizationKeys.Resolve(_ProjectState.CurrentLocalization, StoryCommonLocalizationKeys.AppContinueButton);
        // Navigating to a different logic node restarts its paging from the top; editing the same node keeps the page.
        if (Logic.Id != _RenderedLogicId)
        {
            _Page            = 0;
            _RenderedLogicId = Logic.Id;
        }
    }

    private void SetPaper(bool paper)
    {
        _Paper    = paper;
        _Rendered = Render(); // a Light/Dark switch may resolve to a different icon
    }

    private StoryLogicRenderer.RenderedLogic Render()
    {
        // Both node and project come from the parent, already in one space — the session decided which.
        return StoryLogicRenderer.Render(Project, _ProjectState.CurrentLocalization, Logic, Values, _Paper, StoryRenderTarget.App);
    }

    /// <summary>
    /// Renders preview text with a whitelist of basic formatting tags (b/i/br/…) plus the project-image tags
    /// <c>&lt;icon=Name&gt;</c> (inline) and <c>&lt;sprite=Name&gt;</c> (standalone picture); everything else escaped.
    /// </summary>
    private MarkupString SafeHtml(string text) => (MarkupString)PreviewHtmlSanitizer.ToSafeHtml(text, ResolveImageTag, ResolveVariableTag);

    /// <summary>The frame-style modifier class for a block (e.g. <c>lpv-block-success</c>); empty for the plain Normal frame.</summary>
    private static string FrameClass(StoryTextFrameStyle style)
    {
        string suffix = StoryStyle.FrameSuffix(style);
        return suffix.Length == 0 ? "" : $"lpv-block-{suffix}";
    }

    /// <summary>Resolves a <c>&lt;var=Name&gt;</c> tag to a registered storage variable (case-insensitive name match),
    /// so it renders as that variable's slot label. Returns null when nothing matches so the tag stays visible.</summary>
    private StoryRegisterVariableNode? ResolveVariableTag(string name)
    {
        // The session's project, so a variable registered inside a blueprint resolves to the slot *this* instance got.
        foreach (StoryLogicNode logic in Project.LogicNodes.Values)
            if (logic.RegisterVariableNodes.Find(n => string.Equals(n.Name, name, StringComparison.OrdinalIgnoreCase)) is StoryRegisterVariableNode reg)
                return reg;
        return null;
    }

    /// <summary>
    /// Resolves an <c>&lt;icon=Name&gt;</c> / <c>&lt;sprite=Name&gt;</c> tag to a project image (name match is
    /// case-insensitive, matching the library's uniqueness rule). <c>icon</c> only accepts the inline Icon library;
    /// <c>sprite</c> accepts either library. Returns null when nothing matches so the tag stays visible.
    /// </summary>
    private StoryImage? ResolveImageTag(string tag, string name)
    {
        foreach (StoryImage image in _ProjectState.CurrentProject!.Images.Values)
        {
            if (!string.Equals(image.Name, name, StringComparison.OrdinalIgnoreCase)) continue;
            if (tag == "icon" && image.Kind != StoryImageKind.Icon)                   continue;
            return image;
        }
        return null;
    }
}

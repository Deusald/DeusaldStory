@namespace DeusaldStoryWeb.Components.Common
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Renders a logic node's output as a screen: the localized title as a heading,
   then a framed row with the connected icon on the left and the localized text
   beside it. When the title text is produced by a SmartFormat node, its result
   depends on the values of the connected External Variable nodes — the "External
   Variables" panel lets the author tweak each value and re-renders live.

   A Dark/Light toggle flips only the inner window between the dark theme and a
   paper-like light theme (the story is printed on paper later); the toggle also
   decides which side of a Light/Dark switch node is shown.
   ───────────────────────────────────────────────────────────────────────── *@

<div class="lpv-root">

    <div class="lpv-toolbar">
        <div class="lpv-toggle">
            <button class="lpv-toggle-btn @(_Paper ? "" : "active")" @onclick="() => SetPaper(false)">
                <i class="bi bi-moon-stars-fill"></i> Dark
            </button>
            <button class="lpv-toggle-btn @(_Paper ? "active" : "")" @onclick="() => SetPaper(true)">
                <i class="bi bi-sun-fill"></i> Light
            </button>
        </div>
    </div>

    @* ── External Variables — tweak the values SmartFormat renders against. ── *@
    @{
        List<StoryVariable> vars = ReferencedVariables();
    }
    @if (vars.Count > 0)
    {
        <div class="lpv-vars">
            <div class="lpv-vars-head">
                <i class="bi bi-braces"></i>
                <span>External Variables</span>
            </div>
            <div class="lpv-vars-body">
                @foreach (StoryVariable v in vars)
                {
                    StoryVariable variable = v;
                    <div class="lpv-var-row">
                        <span class="lpv-var-name">@(string.IsNullOrWhiteSpace(variable.Name) ? "(unnamed)" : variable.Name)</span>
                        @if (variable.PossibleValues.Count > 0)
                        {
                            <select class="modal-input lpv-var-input"
                                    value="@PreviewValue(variable)"
                                    @onchange="e => OnVarValueChanged(variable.Id, e)">
                                @foreach (string val in variable.PossibleValues)
                                {
                                    <option value="@val">@(string.IsNullOrEmpty(val) ? "(empty)" : val)</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input class="modal-input lpv-var-input" type="text"
                                   value="@PreviewValue(variable)"
                                   @oninput="e => OnVarValueChanged(variable.Id, e)"/>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <div class="lpv-screen @(_Paper ? "paper" : "")">

        @if (string.IsNullOrEmpty(_Title))
        {
            <div class="lpv-title lpv-placeholder">No title connected</div>
        }
        else
        {
            <div class="lpv-title">@_Title</div>
        }

        <div class="lpv-frame">
            @if (_IconData is not null)
            {
                <div class="lpv-icon">
                    <img src="data:image/png;base64,@_IconData" alt="icon"/>
                </div>
            }
            <div class="lpv-text @(string.IsNullOrEmpty(_Title) ? "lpv-placeholder" : "")">
                @(string.IsNullOrEmpty(_Title) ? "No text connected" : _Title)
            </div>
        </div>

    </div>
</div>

@code {
    [Parameter] public StoryLogicNode Logic { get; set; } = default!;

    private bool    _Paper;    // false = dark (default), true = paper/light
    private string  _Title = "";
    private string? _IconData; // base64 PNG, or null when no icon connected

    // Transient preview values for the referenced variables, keyed by variable id. Not persisted — they only
    // drive how the SmartFormat nodes render in this preview.
    private readonly Dictionary<Guid, string> _VarValues = new();

    protected override void OnParametersSet()
    {
        SeedVarValues();
        _Title    = ResolveTitle();
        _IconData = ResolveIcon();
    }

    private void SetPaper(bool paper)
    {
        _Paper    = paper;
        _IconData = ResolveIcon(); // a Light/Dark switch may resolve to a different icon
    }

    private void OnVarValueChanged(Guid variableId, ChangeEventArgs e)
    {
        _VarValues[variableId] = e.Value?.ToString() ?? "";
        _Title = ResolveTitle();   // re-render the SmartFormat output against the new value
    }

    // ── External variables ─────────────────────────────────────────────────

    /// <summary>The distinct story variables referenced by this logic node's External Variable nodes.</summary>
    private List<StoryVariable> ReferencedVariables()
    {
        Dictionary<Guid, StoryVariable> map = new();
        foreach (StoryExternalVariableNode n in Logic.ExternalVariableNodes)
            if (Variable(n.SelectedVariableId) is StoryVariable v)
                map[v.Id] = v;
        return map.Values.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase).ToList();
    }

    /// <summary>Ensures every referenced variable has a preview value (defaulting to its first possible value).</summary>
    private void SeedVarValues()
    {
        foreach (StoryVariable v in ReferencedVariables())
            if (!_VarValues.ContainsKey(v.Id))
                _VarValues[v.Id] = v.PossibleValues.FirstOrDefault() ?? "";
    }

    /// <summary>The preview value in use for <paramref name="v"/> — the tweaked one, else its first possible value.</summary>
    private string PreviewValue(StoryVariable v) =>
        _VarValues.TryGetValue(v.Id, out string? val) ? val : v.PossibleValues.FirstOrDefault() ?? "";

    private StoryVariable? Variable(Guid id) =>
        id != Guid.Empty && _ProjectState.CurrentProject!.Variables.TryGetValue(id, out StoryVariable? v) ? v : null;

    // ── Title resolution ────────────────────────────────────────────────────

    /// <summary>Follows the wire into the Title input to whatever text node feeds it (Localization or SmartFormat).</summary>
    private string ResolveTitle() => ResolveText(FromPointInto(Logic.TitleIn.Id), 0);

    /// <summary>
    /// Resolves the text emitted by <paramref name="fromPoint"/>: a Localization node yields its key's main-language
    /// text; a SmartFormat node formats its text input against the values of its connected External Variables.
    /// Depth-guarded against loops.
    /// </summary>
    private string ResolveText(Guid fromPoint, int depth)
    {
        if (fromPoint == Guid.Empty || depth > 8) return "";

        if (Logic.LocalizationNodes.Find(n => n.OutPoint.Id == fromPoint) is StoryLocalizationNode locNode)
            return LocalizedText(locNode.SelectedKeyId);

        if (Logic.SmartFormatNodes.Find(n => n.OutPoint.Id == fromPoint) is StorySmartFormatNode sf)
        {
            string format = ResolveText(FromPointInto(sf.LocalizationIn.Id), depth + 1);

            Dictionary<string, object> values = new(StringComparer.OrdinalIgnoreCase);
            foreach (StoryConnection c in Logic.ContentConnections.Where(c => c.ToPoint == sf.VariablesIn.Id))
            {
                if (Logic.ExternalVariableNodes.Find(n => n.OutPoint.Id == c.FromPoint) is StoryExternalVariableNode ev
                    && Variable(ev.SelectedVariableId) is StoryVariable v && !string.IsNullOrWhiteSpace(v.Name))
                    values[v.Name] = PreviewValue(v);
            }

            return StoryConditionPreview.Render(format, values, out _);
        }

        return "";
    }

    /// <summary>The main-language text of the localization key <paramref name="keyId"/> (empty when unavailable).</summary>
    private string LocalizedText(Guid keyId)
    {
        LocProject?         loc = _ProjectState.CurrentLocalization;
        LocLocalizationKey? key = loc?.Keys.Find(k => k.Id == keyId);
        if (key is null) return "";

        string? main = loc!.Metadata.MainLanguageId;
        if (string.IsNullOrEmpty(main)) return "";
        return key.Translations.Find(t => t.LanguageId == main)?.Text ?? "";
    }

    // ── Icon resolution ─────────────────────────────────────────────────────

    /// <summary>Follows the wire into the Icon input, resolving through a Light/Dark switch when present.</summary>
    private string? ResolveIcon() => ResolveIconImage(FromPointInto(Logic.IconIn.Id), 0);

    /// <summary>
    /// Resolves the icon emitted by <paramref name="fromPoint"/>: an Icon node yields its image; a Light/Dark
    /// switch follows its Dark or Light input (by the current mode) one step further. Depth-guarded against loops.
    /// </summary>
    private string? ResolveIconImage(Guid fromPoint, int depth)
    {
        if (fromPoint == Guid.Empty || depth > 8) return null;

        if (Logic.IconNodes.Find(n => n.OutPoint.Id == fromPoint) is StoryIconNode icon)
            return _ProjectState.CurrentProject!.Images.TryGetValue(icon.SelectedImageId, out StoryImage? img)
                ? img.Data : null;

        if (Logic.LightDarkSwitchNodes.Find(n => n.OutPoint.Id == fromPoint) is StoryLightDarkSwitchNode sw)
        {
            Guid input = _Paper ? sw.LightIn.Id : sw.DarkIn.Id;
            return ResolveIconImage(FromPointInto(input), depth + 1);
        }

        return null;
    }

    /// <summary>The output point wired into <paramref name="toPoint"/>, or empty when nothing is connected.</summary>
    private Guid FromPointInto(Guid toPoint) =>
        Logic.ContentConnections.Find(c => c.ToPoint == toPoint)?.FromPoint ?? Guid.Empty;
}

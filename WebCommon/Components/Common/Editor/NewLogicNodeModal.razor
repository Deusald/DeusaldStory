@namespace DeusaldStoryWeb.Components.Common

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box nlm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? "Edit logic node" : "New logic node")</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            @* ── Name ──────────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">Name</label>
                <input class="modal-input"
                       type="text"
                       placeholder="Arrival at the Gate"
                       @bind="_Name"
                       @bind:event="oninput"
                       maxlength="100"/>
            </div>

            @* ── Description ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    Description
                    <span class="modal-label-hint">optional</span>
                </label>
                <textarea class="modal-input nlm-textarea"
                          placeholder="A short description of what happens here…"
                          @bind="_Description"
                          @bind:event="oninput"
                          rows="2"
                          maxlength="500"></textarea>
            </div>

            @* ── Entry point ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    Entry point
                    <span class="modal-label-hint">exactly one — where the story enters this node</span>
                </label>
                <div class="nlm-point nlm-point-entry">
                    <span class="nlm-point-dot" style="background:var(--success)"></span>
                    <input class="modal-input"
                           type="text"
                           placeholder="In"
                           @bind="_EntryName"
                           @bind:event="oninput"
                           maxlength="60"/>
                </div>
            </div>

            @* ── Exit points ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    Exit points
                    <span class="modal-label-hint">at least one — the branches the story can take from here</span>
                </label>
                @for (int i = 0; i < _Exits.Count; i++)
                {
                    int index = i;
                    <div class="nlm-point nlm-point-exit">
                        <span class="nlm-point-dot" style="background:var(--danger)"></span>
                        <input class="modal-input"
                               type="text"
                               placeholder="Success"
                               value="@_Exits[index].Name"
                               @oninput="e => _Exits[index].Name = e.Value?.ToString() ?? string.Empty"
                               maxlength="60"/>
                        <button class="nlm-point-del"
                                title="Remove exit"
                                disabled="@(_Exits.Count <= 1)"
                                @onclick="() => RemoveExit(index)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }
                <button class="nlm-add-exit" @onclick="AddExit">
                    <i class="bi bi-plus-lg"></i> Add exit
                </button>
            </div>

            @* ── Gamebook instructions ─────────────────────────────────── *@
            <div class="modal-field">
                <label class="nlm-check">
                    <input type="checkbox"
                           checked="@_GamebookInstructions"
                           @onchange="e => _GamebookInstructions = (bool)(e.Value ?? false)"/>
                    <span>
                        Gamebook instructions
                        <span class="modal-label-hint">runs automatically in the app; prints a generated instruction section in the Gamebook</span>
                    </span>
                </label>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @(_IsEdit ? "Save changes" : "Create node")
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<NewLogicNodeArgs> OnConfirm { get; set; }

    private bool          _Visible;
    private bool          _IsEdit;
    private Guid          _EditId;
    private string        _Name        = "";
    private string        _Description = "";
    private string        _EntryName   = "In";
    private List<PointRow> _Exits      = new() { new PointRow { Name = "Out" } };
    private bool          _GamebookInstructions;

    /// <summary>Opens the modal to create a brand-new logic node.</summary>
    public void Show()
    {
        _IsEdit               = false;
        _EditId               = Guid.Empty;
        _Name                 = "";
        _Description          = "";
        _EntryName            = "In";
        _Exits                = new List<PointRow> { new PointRow { Name = "Out" } };
        _GamebookInstructions = false;
        _Visible              = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing logic node, preserving exit-point ids so wires survive.</summary>
    public void ShowEdit(Guid id, string name, string description, string entryName, IEnumerable<(Guid Id, string Name)> exits, bool gamebookInstructions)
    {
        _IsEdit               = true;
        _EditId               = id;
        _Name                 = name;
        _Description          = description;
        _EntryName            = entryName;
        _Exits                = exits.Select(e => new PointRow { Id = e.Id, Name = e.Name }).ToList();
        if (_Exits.Count == 0) _Exits.Add(new PointRow { Name = "Out" });
        _GamebookInstructions = gamebookInstructions;
        _Visible              = true;
        StateHasChanged();
    }

    private bool _CanConfirm =>
        !string.IsNullOrWhiteSpace(_Name)      &&
        !string.IsNullOrWhiteSpace(_EntryName) &&
        _Exits.Any(n => !string.IsNullOrWhiteSpace(n.Name));

    private void AddExit() => _Exits.Add(new PointRow { Name = "" });

    private void RemoveExit(int index)
    {
        if (_Exits.Count <= 1) return;
        _Exits.RemoveAt(index);
    }

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;

        List<(Guid Id, string Name)> exits = _Exits
                                            .Where(e => !string.IsNullOrWhiteSpace(e.Name))
                                            .Select(e => (e.Id, e.Name.Trim()))
                                            .ToList();

        await OnConfirm.InvokeAsync(new NewLogicNodeArgs(
            _EditId,
            _Name.Trim(),
            _Description.Trim(),
            _EntryName.Trim(),
            exits,
            _GamebookInstructions));
    }

    private void Cancel() => _Visible = false;

    private sealed class PointRow
    {
        public Guid   Id   { get; set; }
        public string Name { get; set; } = "";
    }

    /// <summary>Result passed back to the parent. <see cref="EditId"/> is empty for a create, set for an edit.</summary>
    public record NewLogicNodeArgs(
        Guid                         EditId,
        string                       Name,
        string                       Description,
        string                       EntryName,
        List<(Guid Id, string Name)> Exits,
        bool                         GamebookInstructions);
}

@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box nlm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.Logic.editTitle) : Loc.T(Localization.Editor.Modals.Logic.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            @* ── Name ──────────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Common.Fields.name)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@Loc.T(Localization.Editor.Modals.Logic.namePlaceholder)"
                       @bind="_Name"
                       @bind:event="oninput"
                       maxlength="100"/>
            </div>

            @* ── Description ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Common.Fields.description)
                    <span class="modal-label-hint">@Loc.T(Localization.Common.Fields.optional)</span>
                </label>
                <textarea class="modal-input nlm-textarea"
                          placeholder="@Loc.T(Localization.Editor.Modals.Logic.descriptionPlaceholder)"
                          @bind="_Description"
                          @bind:event="oninput"
                          rows="2"
                          maxlength="500"></textarea>
            </div>

            @* ── Exit mode ─────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Editor.Modals.Logic.exitModeLabel)
                    <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.Logic.exitModeHint)</span>
                </label>
                <div class="nlm-mode">
                    <button type="button"
                            class="nlm-mode-opt @(_ExitMode == StoryLogicExitMode.ManyPaths ? "active" : "")"
                            @onclick="() => _ExitMode = StoryLogicExitMode.ManyPaths">
                        <span class="nlm-mode-title">@Loc.T(Localization.Editor.Modals.Logic.manyPathsTitle)</span>
                        <span class="nlm-mode-desc">@Loc.T(Localization.Editor.Modals.Logic.manyPathsDesc)</span>
                    </button>
                    <button type="button"
                            class="nlm-mode-opt @(_ExitMode == StoryLogicExitMode.SinglePath ? "active" : "")"
                            @onclick="() => _ExitMode = StoryLogicExitMode.SinglePath">
                        <span class="nlm-mode-title">@Loc.T(Localization.Editor.Modals.Logic.singlePathTitle)</span>
                        <span class="nlm-mode-desc">@Loc.T(Localization.Editor.Modals.Logic.singlePathDesc)</span>
                    </button>
                    <button type="button"
                            class="nlm-mode-opt @(_ExitMode == StoryLogicExitMode.HubPaths ? "active" : "")"
                            @onclick="() => _ExitMode = StoryLogicExitMode.HubPaths">
                        <span class="nlm-mode-title">@Loc.T(Localization.Editor.Modals.Logic.hubPathsTitle)</span>
                        <span class="nlm-mode-desc">@Loc.T(Localization.Editor.Modals.Logic.hubPathsDesc)</span>
                    </button>
                </div>
            </div>

            @* ── Declared variables (Single path only) ─────────────────── *@
            @if (_ExitMode == StoryLogicExitMode.SinglePath)
            {
                <div class="modal-field">
                    <label class="modal-label">
                        @Loc.T(Localization.Editor.Modals.Logic.declaredVariablesLabel)
                        <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.Logic.declaredVariablesHint)</span>
                    </label>
                    @for (int i = 0; i < _Vars.Count; i++)
                    {
                        int index = i;
                        <div class="nlm-point">
                            <span class="nlm-point-dot" style="background:var(--code-func)"></span>
                            <input class="modal-input nlm-var-name"
                                   type="text"
                                   placeholder="@Loc.T(Localization.Editor.Modals.Logic.variableNamePlaceholder)"
                                   value="@_Vars[index].Name"
                                   @oninput="e => _Vars[index].Name = e.Value?.ToString() ?? string.Empty"
                                   maxlength="60"/>
                            <input class="modal-input nlm-var-vals"
                                   type="text"
                                   placeholder="@Loc.T(Localization.Editor.Modals.Logic.variableValuesPlaceholder)"
                                   value="@_Vars[index].ValuesCsv"
                                   @oninput="e => _Vars[index].ValuesCsv = e.Value?.ToString() ?? string.Empty"
                                   maxlength="300"/>
                            <button class="nlm-point-del" title="@Loc.T(Localization.Editor.Modals.Logic.removeVariable)" @onclick="() => RemoveVar(index)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                    <button class="nlm-add-exit" @onclick="AddVar">
                        <i class="bi bi-plus-lg"></i> @Loc.T(Localization.Editor.Modals.Logic.addVariable)
                    </button>
                </div>
            }

            @* ── Gamebook instructions ─────────────────────────────────── *@
            <div class="modal-field">
                <label class="nlm-check">
                    <input type="checkbox"
                           checked="@_GamebookInstructions"
                           @onchange="e => _GamebookInstructions = (bool)(e.Value ?? false)"/>
                    <span>
                        @Loc.T(Localization.Editor.Modals.Logic.gamebookInstructionsLabel)
                        <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.Logic.gamebookInstructionsHint)</span>
                    </span>
                </label>
            </div>

            @* ── Accept variables ──────────────────────────────────────── *@
            <div class="modal-field">
                <label class="nlm-check">
                    <input type="checkbox"
                           checked="@_AcceptVariables"
                           @onchange="e => _AcceptVariables = (bool)(e.Value ?? false)"/>
                    <span>
                        @Loc.T(Localization.Editor.Modals.Logic.acceptVariablesLabel)
                        <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.Logic.acceptVariablesHint)</span>
                    </span>
                </label>
            </div>

            @* ── Expected incoming variables (the AcceptVariables contract) ─── *@
            @if (_AcceptVariables)
            {
                <div class="modal-field">
                    <label class="modal-label">
                        @Loc.T(Localization.Editor.Modals.Logic.expectedVariablesLabel)
                        <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.Logic.expectedVariablesHint)</span>
                    </label>
                    @for (int i = 0; i < _Expected.Count; i++)
                    {
                        int index = i;
                        <div class="nlm-point">
                            <span class="nlm-point-dot" style="background:var(--code-func)"></span>
                            <input class="modal-input nlm-var-name"
                                   type="text"
                                   placeholder="@Loc.T(Localization.Editor.Modals.Logic.variableNamePlaceholder)"
                                   value="@_Expected[index].Name"
                                   @oninput="e => _Expected[index].Name = e.Value?.ToString() ?? string.Empty"
                                   maxlength="60"/>
                            <input class="modal-input nlm-var-vals"
                                   type="text"
                                   placeholder="@Loc.T(Localization.Editor.Modals.Logic.variableValuesPlaceholder)"
                                   value="@_Expected[index].ValuesCsv"
                                   @oninput="e => _Expected[index].ValuesCsv = e.Value?.ToString() ?? string.Empty"
                                   maxlength="300"/>
                            <button class="nlm-point-del" title="@Loc.T(Localization.Editor.Modals.Logic.removeVariable)" @onclick="() => _Expected.RemoveAt(index)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                    <button class="nlm-add-exit" @onclick="() => _Expected.Add(new PointRow())">
                        <i class="bi bi-plus-lg"></i> @Loc.T(Localization.Editor.Modals.Logic.addExpectedVariable)
                    </button>
                </div>
            }

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : Loc.T(Localization.Editor.Modals.Logic.createButton))
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<NewLogicNodeArgs> OnConfirm { get; set; }

    private bool               _Visible;
    private bool               _IsEdit;
    private Guid               _EditId;
    private string             _Name        = "";
    private string             _Description = "";
    private List<PointRow>     _Vars        = new();
    private List<PointRow>     _Expected    = new();
    private bool               _GamebookInstructions;
    private StoryLogicExitMode _ExitMode;
    private bool               _AcceptVariables;

    /// <summary>Opens the modal to create a brand-new logic node.</summary>
    public void Show()
    {
        _IsEdit               = false;
        _EditId               = Guid.Empty;
        _Name                 = "";
        _Description          = "";
        _Vars                 = new();
        _Expected             = new();
        _GamebookInstructions = false;
        _ExitMode             = StoryLogicExitMode.ManyPaths;
        _AcceptVariables      = false;
        _Visible              = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing logic node, preserving declared/expected-variable ids so wires survive.</summary>
    public void ShowEdit(Guid id, string name, string description,
                         bool gamebookInstructions, StoryLogicExitMode exitMode, bool acceptVariables,
                         IEnumerable<(Guid Id, string Name, List<string> PossibleValues)> declaredVariables,
                         IEnumerable<(Guid Id, string Name, List<string> PossibleValues)>? expectedVariables = null)
    {
        _IsEdit               = true;
        _EditId               = id;
        _Name                 = name;
        _Description          = description;
        _Vars                 = declaredVariables.Select(d => new PointRow { Id = d.Id, Name = d.Name, ValuesCsv = string.Join(", ", d.PossibleValues) }).ToList();
        _Expected             = (expectedVariables ?? []).Select(d => new PointRow { Id = d.Id, Name = d.Name, ValuesCsv = string.Join(", ", d.PossibleValues) }).ToList();
        _GamebookInstructions = gamebookInstructions;
        _ExitMode             = exitMode;
        _AcceptVariables      = acceptVariables;
        _Visible              = true;
        StateHasChanged();
    }

    private bool _CanConfirm => !string.IsNullOrWhiteSpace(_Name);

    private void AddVar() => _Vars.Add(new PointRow { Name = "" });

    private void RemoveVar(int index)
    {
        if (index >= 0 && index < _Vars.Count) _Vars.RemoveAt(index);
    }

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;

        List<(Guid Id, string Name, List<string> PossibleValues)> vars = _ExitMode == StoryLogicExitMode.SinglePath
            ? _Vars.Where(v => !string.IsNullOrWhiteSpace(v.Name))
                   .Select(v => (v.Id, v.Name.Trim(), SplitValues(v.ValuesCsv)))
                   .ToList()
            : new List<(Guid, string, List<string>)>();

        List<(Guid Id, string Name, List<string> PossibleValues)> expected = _AcceptVariables
            ? _Expected.Where(v => !string.IsNullOrWhiteSpace(v.Name))
                       .Select(v => (v.Id, v.Name.Trim(), SplitValues(v.ValuesCsv)))
                       .ToList()
            : new List<(Guid, string, List<string>)>();

        await OnConfirm.InvokeAsync(new NewLogicNodeArgs(
            _EditId,
            _Name.Trim(),
            _Description.Trim(),
            _GamebookInstructions,
            _ExitMode,
            _AcceptVariables,
            vars,
            expected));
    }

    private static List<string> SplitValues(string csv) =>
        csv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private void Cancel() => _Visible = false;

    private sealed class PointRow
    {
        public Guid   Id        { get; set; }
        public string Name      { get; set; } = "";
        public string ValuesCsv { get; set; } = "";
    }

    /// <summary>Result passed back to the parent. <see cref="EditId"/> is empty for a create, set for an edit.</summary>
    public record NewLogicNodeArgs(
        Guid                                             EditId,
        string                                           Name,
        string                                           Description,
        bool                                             GamebookInstructions,
        StoryLogicExitMode                               ExitMode,
        bool                                             AcceptVariables,
        List<(Guid Id, string Name, List<string> PossibleValues)> DeclaredVariables,
        List<(Guid Id, string Name, List<string> PossibleValues)> ExpectedVariables);
}

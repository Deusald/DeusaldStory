@namespace DeusaldStoryWeb.Components.Common
@implements IAsyncDisposable
@inject IJSRuntime _JS

<div class="edg-root">

    @* ── Floating toolbar ────────────────────────────────────────────── *@
    <div class="edg-toolbar">
        <button class="edg-tool-btn edg-tool-primary" @onclick="AddNodeAtCenter">
            <i class="bi bi-plus-lg"></i> Add node
        </button>
        <span class="edg-tool-count">@Nodes.Count nodes</span>
        <span class="edg-tool-hint">drag to select · middle-drag or Space+drag to pan · double-click a container to open it</span>
    </div>

    @* ── Canvas ──────────────────────────────────────────────────────── *@
    <div class="edg-canvas @(_Panning ? "edg-canvas-panning" : "") @(_Selecting ? "edg-canvas-selecting" : "")"
         @ref="_CanvasEl"
         @onpointerdown="CanvasDown" @onpointerdown:preventDefault="true"
         @onpointermove="CanvasMove"
         @onpointerup="CanvasUp"
         @onpointerleave="CanvasUp"
         @oncontextmenu="CanvasContextMenu" @oncontextmenu:preventDefault="true"
         @onwheel="OnWheel" @onwheel:preventDefault="true">

        <div class="edg-world" style="transform: translate(@F(_PanX)px, @F(_PanY)px) scale(@F(_Scale));">

            @{
                Dictionary<Guid, PortAnchor> anchors = BuildAnchors();
                _Anchors = anchors;
            }

            @* Edge layer. A large, explicitly-sized <svg> with an offset <g> — NOT a tiny svg relying on
               overflow:visible, which WebKit (the MAUI WebView) clips regardless of CSS, hiding every wire.
               Styling is inline: Blazor CSS isolation does not tag svg children, so scoped rules never apply. *@
            <svg width="8000" height="8000" xmlns="http://www.w3.org/2000/svg"
                 style="position:absolute; left:-4000px; top:-4000px; overflow:visible; pointer-events:none;">
                <g transform="translate(4000 4000)">
                    @foreach (EdEdge edge in Edges)
                    {
                        if (!anchors.TryGetValue(edge.FromPoint, out PortAnchor from) ||
                            !anchors.TryGetValue(edge.ToPoint,   out PortAnchor to))
                            continue;

                        EdEdge e      = edge;
                        bool   active = edge.Id == _SelectedEdgeId;
                        // Tint the wire in its signal colour (the connected ports' type) so the flow it carries reads at a glance.
                        string stroke = active ? "var(--accent)" : StoryStyle.PortColor(from.Type);
                        <path d="@EdgePath(from.X, from.Y, to.X, to.Y)"
                              style="stroke:transparent; stroke-width:14px; fill:none; pointer-events:stroke; cursor:pointer;"
                              @onpointerdown="() => SelectEdge(e.Id)" @onpointerdown:stopPropagation="true"
                              @oncontextmenu="() => OnDisconnect.InvokeAsync(e.Id)"
                              @oncontextmenu:stopPropagation="true" @oncontextmenu:preventDefault="true"/>
                        <path d="@EdgePath(from.X, from.Y, to.X, to.Y)"
                              style="stroke:@stroke; stroke-width:@(active ? "2.5" : "2")px; fill:none; pointer-events:none;"/>

                        @if (active)
                        {
                            double mx = (from.X + to.X) / 2, my = (from.Y + to.Y) / 2;
                            <g transform="translate(@F(mx) @F(my))" style="cursor:pointer; pointer-events:auto;"
                               @onpointerdown="() => OnDisconnect.InvokeAsync(e.Id)" @onpointerdown:stopPropagation="true">
                                <circle r="9" style="fill:var(--danger);"/>
                                <line x1="-3.5" y1="-3.5" x2="3.5" y2="3.5" style="stroke:#fff; stroke-width:1.6px; stroke-linecap:round;"/>
                                <line x1="3.5" y1="-3.5" x2="-3.5" y2="3.5" style="stroke:#fff; stroke-width:1.6px; stroke-linecap:round;"/>
                            </g>
                        }
                    }

                    @* Rubber-band edge that trails the cursor from the moment a drag starts until it drops. *@
                    @if (_ConnFrom is Guid connFrom && anchors.TryGetValue(connFrom, out PortAnchor src))
                    {
                        <path d="@EdgePath(src.X, src.Y, _ConnX, _ConnY)"
                              style="stroke:var(--accent); stroke-width:2.5px; stroke-dasharray:5 4; fill:none; pointer-events:none;"/>
                        <circle cx="@F(_ConnX)" cy="@F(_ConnY)" r="4" style="fill:var(--accent);"/>
                    }
                </g>
            </svg>

            @* Nodes *@
            @foreach (EdNode node in Nodes)
            {
                EdNode n     = node;
                bool   sub   = HasSub(n);
                if (n.Kind == StoryNodeKind.Comment)
                {
                    <div class="edg-node edg-node-comment @(IsSelected(n) ? "edg-node-sel" : "")"
                         style="left:@F(n.X)px; top:@F(n.Y)px;"
                         @onpointerdown="e => NodeDown(e, n)" @onpointerdown:stopPropagation="true"
                         @ondblclick="() => OnNodeEdit.InvokeAsync(n)" @ondblclick:stopPropagation="true"
                         @oncontextmenu="e => NodeContextMenu(e, n)"
                         @oncontextmenu:stopPropagation="true" @oncontextmenu:preventDefault="true">
                        <div class="edg-node-comment-head">
                            <i class="bi bi-chat-left-text"></i> COMMENT
                        </div>
                        <div class="edg-node-comment-body">
                            @(string.IsNullOrWhiteSpace(n.Title) ? "(empty note)" : n.Title)
                        </div>
                    </div>
                    continue;
                }
                <div class="edg-node @NodeClass(n)"
                     style="left:@F(n.X)px; top:@F(n.Y)px; height:@F(NodeHeight(n))px;"
                     @onpointerdown="e => NodeDown(e, n)" @onpointerdown:stopPropagation="true"
                     @ondblclick="() => OnNodeActivated.InvokeAsync(n)" @ondblclick:stopPropagation="true"
                     @oncontextmenu="e => NodeContextMenu(e, n)"
                     @oncontextmenu:stopPropagation="true" @oncontextmenu:preventDefault="true">

                    <div class="edg-node-head">
                        <span class="edg-node-kind">
                            <i class="edg-node-kind-ico bi @StoryStyle.NodeIcon(n.Kind)"></i>
                            @StoryStyle.NodeLabel(n.Kind)
                        </span>
                        @if (!n.Deletable)
                        {
                            <span class="edg-node-lock" title="Built-in node — edit via the container's entry/exit points">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                        }
                    </div>
                    <div class="edg-node-title">@n.Title</div>
                    @if (sub)
                    {
                        <div class="edg-node-preview">@n.Subtitle</div>
                    }
                    @if (HasThumb(n))
                    {
                        <div class="edg-node-thumb">
                            <img src="data:image/png;base64,@n.Thumb" alt="@n.Title"/>
                        </div>
                    }

                    @* Input ports — dots hang on the left border, connections drop onto them. *@
                    @for (int i = 0; i < n.Inputs.Count; ++i)
                    {
                        EdPort port = n.Inputs[i];
                        <div class="edg-port-anchor edg-port-in" style="top:@F(PortCenterY(n, i))px;">
                            <span class="edg-port @(IsCompatibleTarget(port) ? "edg-port-target" : "")"
                                  style="background:@StoryStyle.PortColor(port.Type)"
                                  @onpointerdown:stopPropagation="true"></span>
                            @if (ShowPortLabels(n) && !string.IsNullOrEmpty(port.Name))
                            {
                                <span class="edg-port-label">@port.Name</span>
                            }
                        </div>
                    }

                    @* Output ports — drag from a dot to start wiring the next node. *@
                    @for (int i = 0; i < n.Outputs.Count; ++i)
                    {
                        EdPort port = n.Outputs[i];
                        <div class="edg-port-anchor edg-port-out" style="top:@F(PortCenterY(n, i))px;">
                            <span class="edg-port" style="background:@StoryStyle.PortColor(port.Type)"
                                  @onpointerdown="e => StartConnect(e, port.Id)" @onpointerdown:stopPropagation="true"></span>
                            @if (ShowPortLabels(n) && !string.IsNullOrEmpty(port.Name))
                            {
                                <span class="edg-port-label">@port.Name</span>
                            }
                        </div>
                    }
                </div>
            }

            @* Rubber-band selection marquee, drawn in world space so it tracks pan/zoom with the nodes. *@
            @if (_Selecting)
            {
                double sx = Math.Min(_SelStartX, _SelCurX), sy = Math.Min(_SelStartY, _SelCurY);
                double sw = Math.Abs(_SelCurX - _SelStartX), sh = Math.Abs(_SelCurY - _SelStartY);
                <div class="edg-select-box" style="left:@F(sx)px; top:@F(sy)px; width:@F(sw)px; height:@F(sh)px;"></div>
            }
        </div>

        @* ── Minimap ─────────────────────────────────────────────────── *@
        @if (Nodes.Count > 0)
        {
            <div class="edg-minimap"
                 @onpointerdown="MinimapDown" @onpointerdown:stopPropagation="true" @onpointerdown:preventDefault="true">
                <div class="edg-minimap-label">MAP</div>
                @{
                    const double mapW = 168, mapH = 96, pad = 10, nodeH = 82;
                    double minX = Nodes.Min(n => n.X), maxX = Nodes.Max(n => n.X) + NODE_W;
                    double minY = Nodes.Min(n => n.Y), maxY = Nodes.Max(n => n.Y) + nodeH;
                    double bw = Math.Max(1, maxX - minX), bh = Math.Max(1, maxY - minY);
                    double s  = Math.Min((mapW - 2 * pad) / bw, (mapH - 2 * pad) / bh);
                }
                @foreach (EdNode node in Nodes)
                {
                    double mx = pad + (node.X - minX) * s;
                    double my = pad + (node.Y - minY) * s;
                    double mw = Math.Max(9, NODE_W * s);
                    <span class="edg-minimap-node"
                          style="left:@F(mx)px; top:@F(my)px; width:@F(mw)px; background:@StoryStyle.NodeColor(node.Kind)"></span>
                }
            </div>
        }
    </div>

    @* ── Node context menu ───────────────────────────────────────────── *@
    @if (_MenuNode is EdNode menu)
    {
        <div class="edg-menu-backdrop"
             @onpointerdown="CloseMenu" @onpointerdown:stopPropagation="true"
             @oncontextmenu="CloseMenu" @oncontextmenu:preventDefault="true" @oncontextmenu:stopPropagation="true"></div>
        <div class="edg-menu" style="left:@F(_MenuX)px; top:@F(_MenuY)px;"
             @oncontextmenu:preventDefault="true" @oncontextmenu:stopPropagation="true">
            @if (menu.Editable)
            {
                <button class="edg-menu-item" @onclick="() => MenuInvoke(OnNodeEdit, menu)">
                    <i class="bi bi-pencil"></i> Edit @MenuNoun(menu)
                </button>
            }
            @if (menu.Kind is StoryNodeKind.PortalIn or StoryNodeKind.PortalOut)
            {
                <button class="edg-menu-item" @onclick="() => MenuInvoke(OnNodeAddPortalIn, menu)">
                    <i class="bi bi-box-arrow-in-right"></i> Add portal in
                </button>
            }
            @if (CanMoveToParent && menu.Kind is StoryNodeKind.Logic or StoryNodeKind.Container)
            {
                <button class="edg-menu-item" @onclick="() => MenuInvoke(OnNodeMoveToParent, menu)">
                    <i class="bi bi-box-arrow-up-left"></i> Move to parent
                </button>
            }
            @if (menu.Deletable)
            {
                @if (menu.Editable || menu.Kind is StoryNodeKind.PortalIn or StoryNodeKind.PortalOut
                                   || (CanMoveToParent && menu.Kind is StoryNodeKind.Logic or StoryNodeKind.Container))
                {
                    <div class="edg-menu-sep"></div>
                }
                <button class="edg-menu-item edg-menu-danger" @onclick="() => MenuInvoke(OnNodeDelete, menu)">
                    <i class="bi bi-trash"></i> Delete @MenuNoun(menu)
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<EdNode>              Nodes               { get; set; } = [];
    [Parameter] public List<EdEdge>              Edges               { get; set; } = [];
    [Parameter] public Guid                      SelectedId          { get; set; }
    [Parameter] public EventCallback<Guid>       SelectedChanged     { get; set; }
    [Parameter] public EventCallback<CanvasPoint> OnAddNode          { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<EdNode>> OnNodesMoved { get; set; }
    [Parameter] public EventCallback<EdNode>     OnNodeActivated     { get; set; }
    [Parameter] public EventCallback<CanvasPoint> OnCanvasContextMenu { get; set; }
    [Parameter] public EventCallback<EdConnectRequest> OnConnect     { get; set; }
    [Parameter] public EventCallback<Guid>       OnDisconnect        { get; set; }
    [Parameter] public EventCallback<EdNode>     OnNodeEdit          { get; set; }
    [Parameter] public EventCallback<EdNode>     OnNodeDelete        { get; set; }
    [Parameter] public EventCallback<EdNode>     OnNodeAddPortalIn   { get; set; }
    [Parameter] public EventCallback<EdNodeReparent> OnNodeReparent  { get; set; }
    [Parameter] public EventCallback<EdNode>     OnNodeMoveToParent  { get; set; }
    [Parameter] public EventCallback             OnUndo              { get; set; }
    [Parameter] public EventCallback             OnRedo              { get; set; }

    /// <summary>Whether the current graph's nodes can be pushed up a level (false in the Root container).</summary>
    [Parameter] public bool CanMoveToParent { get; set; }

    // ── Node layout constants (must match the absolute positions in EditorGraph.razor.css) ──
    private const double NODE_W       = 216; // fixed card width
    private const double HEAD_TOP     = 12;  // kind row top
    private const double HEAD_H       = 16;
    private const double TITLE_GAP    = 8;
    private const double TITLE_H      = 20;
    private const double SUB_GAP      = 6;
    private const double SUB_H        = 16;
    private const double THUMB_GAP    = 8;   // space above an inline thumbnail (Icon node preview)
    private const double THUMB_H      = 46;  // inline thumbnail height
    private const double PORTS_GAP    = 14;  // space between the header block and the first port
    private const double PORT_SLOT    = 24;  // vertical pitch of a port row
    private const double PORTS_BOTTOM = 14;  // padding below the last port
    private const double SNAP_RADIUS  = 60;  // how close a drop must land to an input port to wire it

    /// <summary>A resolved connection-point position in world coordinates, keyed by point id.</summary>
    private readonly record struct PortAnchor(Guid NodeId, double X, double Y, bool IsOutput, PortType Type, StoryNodeKind OwnerKind);

    private double _Scale = 1;
    private double _PanX  = 24;
    private double _PanY  = 28;

    private ElementReference       _CanvasEl;
    private IJSObjectReference?    _Module;
    private DotNetObjectReference<EditorGraph>? _SelfRef;
    private bool                   _SpaceHeld; // Space held → left-drag pans instead of selecting

    private bool           _Panning;
    private List<EdNode>   _DragGroup = new(); // node(s) being dragged (one, or the whole multi-selection)
    private bool           _DragMoved;
    private Guid?          _DropTargetId; // container the (single) dragged node currently hovers over
    private double         _LastClientX;
    private double         _LastClientY;

    // Rubber-band selection (world coordinates). Active while _Selecting.
    private readonly HashSet<Guid> _Selected = new(); // multi-selected node ids (beyond the primary SelectedId)
    private bool   _Selecting;
    private double _SelStartX;
    private double _SelStartY;
    private double _SelCurX;
    private double _SelCurY;

    private Guid?  _SelectedEdgeId;
    private Guid?  _ConnFrom;  // output point currently being dragged from
    private bool   _ConnMoved; // the drag actually moved (guards against a bare click auto-wiring)
    private double _ConnX;     // temp-edge end, world coordinates
    private double _ConnY;

    private Dictionary<Guid, PortAnchor> _Anchors = new();

    private EdNode? _MenuNode; // node whose right-click context menu is open (null when closed)
    private double  _MenuX;    // menu position, viewport coordinates (position: fixed)
    private double  _MenuY;

    // ── Node geometry ──────────────────────────────────────────────────────

    private static bool HasSub(EdNode n) => !string.IsNullOrEmpty(n.Subtitle);
    private static bool HasThumb(EdNode n) => !string.IsNullOrEmpty(n.Thumb);

    private static double PortsTop(EdNode n) =>
        HEAD_TOP + HEAD_H + TITLE_GAP + TITLE_H
        + (HasSub(n)   ? SUB_GAP + SUB_H     : 0)
        + (HasThumb(n) ? THUMB_GAP + THUMB_H : 0)
        + PORTS_GAP;

    private static double PortCenterY(EdNode n, int slot) => PortsTop(n) + slot * PORT_SLOT + PORT_SLOT / 2;

    private static double NodeHeight(EdNode n) =>
        PortsTop(n) + Math.Max(1, Math.Max(n.Inputs.Count, n.Outputs.Count)) * PORT_SLOT + PORTS_BOTTOM;

    private Dictionary<Guid, PortAnchor> BuildAnchors()
    {
        Dictionary<Guid, PortAnchor> anchors = new();
        foreach (EdNode n in Nodes)
        {
            for (int i = 0; i < n.Inputs.Count; ++i)
                anchors[n.Inputs[i].Id] = new PortAnchor(n.Id, n.X, n.Y + PortCenterY(n, i), false, n.Inputs[i].Type, n.Kind);
            for (int i = 0; i < n.Outputs.Count; ++i)
                anchors[n.Outputs[i].Id] = new PortAnchor(n.Id, n.X + NODE_W, n.Y + PortCenterY(n, i), true, n.Outputs[i].Type, n.Kind);
        }
        return anchors;
    }

    // ── Node styling ───────────────────────────────────────────────────────

    // Node type is conveyed by the header icon + label, not a card colour, so the class only carries state.
    private string NodeClass(EdNode n)
    {
        string sel  = IsSelected(n)          ? "edg-node-sel"  : "";
        string drop = n.Id == _DropTargetId  ? "edg-node-drop" : "";
        return $"{sel} {drop}";
    }

    // ── Reparent (drop a logic/container node onto a container) ───────────────

    private static bool IsReparentable(EdNode n) => n.Kind is StoryNodeKind.Logic or StoryNodeKind.Container;

    /// <summary>The container node whose card the dragged node's centre overlaps (never itself), or null.</summary>
    private Guid? ContainerUnder(EdNode dragged)
    {
        double cx = dragged.X + NODE_W / 2;
        double cy = dragged.Y + NodeHeight(dragged) / 2;
        foreach (EdNode n in Nodes)
        {
            if (n.Kind != StoryNodeKind.Container || n.Id == dragged.Id) continue;
            if (cx >= n.X && cx <= n.X + NODE_W && cy >= n.Y && cy <= n.Y + NodeHeight(n))
                return n.Id;
        }
        return null;
    }

    // Every port carries a name (an author name, or its signal type as a fallback), so label them all.
    private static bool ShowPortLabels(EdNode n) => true;

    /// <summary>
    /// True when a wire is being dragged and this input port is a valid drop target for its source: same signal type,
    /// and — when dragging from a Choice option's flow-out — only an Exit input qualifies (choices lead to exits only).
    /// </summary>
    private bool IsCompatibleTarget(EdPort input) =>
        _ConnFrom is Guid from
        && _Anchors.TryGetValue(from, out PortAnchor src)
        && _Anchors.TryGetValue(input.Id, out PortAnchor tgt)
        && src.Type == input.Type
        && (src.OwnerKind != StoryNodeKind.Choice || tgt.OwnerKind == StoryNodeKind.LogicExit);

    // ── Pan / drag ─────────────────────────────────────────────────────────

    private async Task CanvasDown(PointerEventArgs e)
    {
        _SelectedEdgeId = null;
        _LastClientX    = e.ClientX;
        _LastClientY    = e.ClientY;

        // Right button belongs to the context menu / palette — never pan or select on it.
        if (e.Button == 2) return;

        // Middle button, or Space held, pans the view (and keeps any current selection).
        if (e.Button == 1 || _SpaceHeld)
        {
            _Panning = true;
            return;
        }

        // Plain left-drag on empty canvas starts a rubber-band selection (clears the current one).
        // Anchor from the measured canvas rect — OffsetX is relative to whatever child was hit, not the canvas.
        _Selected.Clear();
        if (SelectedId != Guid.Empty) await SelectedChanged.InvokeAsync(Guid.Empty);
        double[] r = await RectAsync();
        _SelStartX = (e.ClientX - r[0] - _PanX) / _Scale;
        _SelStartY = (e.ClientY - r[1] - _PanY) / _Scale;
        _SelCurX   = _SelStartX;
        _SelCurY   = _SelStartY;
        _Selecting = true;
    }

    private async Task NodeDown(PointerEventArgs e, EdNode node)
    {
        _SelectedEdgeId = null;
        _DragMoved      = false;
        _Panning        = false;
        _Selecting      = false;
        _LastClientX    = e.ClientX;
        _LastClientY    = e.ClientY;

        // Grabbing a node that's part of a multi-selection drags the whole group; grabbing any other node
        // collapses the selection to just that node.
        if (_Selected.Count > 1 && _Selected.Contains(node.Id))
        {
            _DragGroup = Nodes.Where(n => _Selected.Contains(n.Id)).ToList();
        }
        else
        {
            _Selected.Clear();
            _DragGroup = [node];
            if (node.Id != SelectedId) await SelectedChanged.InvokeAsync(node.Id);
        }
    }

    private void CanvasMove(PointerEventArgs e)
    {
        if (_ConnFrom is not null)
        {
            _ConnX     += (e.ClientX - _LastClientX) / _Scale;
            _ConnY     += (e.ClientY - _LastClientY) / _Scale;
            _ConnMoved  = true;
        }
        else if (_DragGroup.Count > 0)
        {
            double dx = (e.ClientX - _LastClientX) / _Scale;
            double dy = (e.ClientY - _LastClientY) / _Scale;
            foreach (EdNode n in _DragGroup)
            {
                n.X += dx;
                n.Y += dy;
            }
            _DragMoved = true;
            // A lone reparentable node highlights the container it would drop into (disabled for group drags).
            _DropTargetId = _DragGroup.Count == 1 && IsReparentable(_DragGroup[0]) ? ContainerUnder(_DragGroup[0]) : null;
        }
        else if (_Selecting)
        {
            _SelCurX += (e.ClientX - _LastClientX) / _Scale;
            _SelCurY += (e.ClientY - _LastClientY) / _Scale;
            UpdateMarqueeSelection();
        }
        else if (_Panning)
        {
            _PanX += e.ClientX - _LastClientX;
            _PanY += e.ClientY - _LastClientY;
        }
        else
        {
            return;
        }

        _LastClientX = e.ClientX;
        _LastClientY = e.ClientY;
    }

    private async Task CanvasUp(PointerEventArgs e)
    {
        if (_DragGroup.Count > 0 && _DragMoved)
        {
            // A single reparentable node dropped onto a container moves inside it; everything else is a plain move.
            if (_DragGroup.Count == 1 && IsReparentable(_DragGroup[0]) && ContainerUnder(_DragGroup[0]) is Guid target)
                await OnNodeReparent.InvokeAsync(new EdNodeReparent(_DragGroup[0].Id, target));
            else
                // One callback for the whole drag so a multi-selection move is a single (atomic, undoable) step.
                await OnNodesMoved.InvokeAsync(_DragGroup.ToList());
        }

        // Drop a pending wire onto the nearest input port under the cursor (forgiving — no pixel-perfect hit needed).
        if (_ConnFrom is Guid from && _ConnMoved && NearestInputPoint(from) is Guid to)
            await OnConnect.InvokeAsync(new EdConnectRequest(from, to));

        // Finish a marquee: a single hit becomes the primary selection so the inspector fills in.
        if (_Selecting)
        {
            UpdateMarqueeSelection();
            if (_Selected.Count == 1)
            {
                Guid only = _Selected.First();
                _Selected.Clear();
                await SelectedChanged.InvokeAsync(only);
            }
        }

        _Panning      = false;
        _DragGroup    = new();
        _DragMoved    = false;
        _DropTargetId = null;
        _ConnFrom     = null;
        _ConnMoved    = false;
        _Selecting    = false;
    }

    /// <summary>Recomputes the multi-selection from the current marquee rectangle (nodes whose card it overlaps).</summary>
    private void UpdateMarqueeSelection()
    {
        double x0 = Math.Min(_SelStartX, _SelCurX), x1 = Math.Max(_SelStartX, _SelCurX);
        double y0 = Math.Min(_SelStartY, _SelCurY), y1 = Math.Max(_SelStartY, _SelCurY);
        _Selected.Clear();
        foreach (EdNode n in Nodes)
        {
            double nx1 = n.X + NODE_W, ny1 = n.Y + SelectHeight(n);
            if (n.X <= x1 && nx1 >= x0 && n.Y <= y1 && ny1 >= y0)
                _Selected.Add(n.Id);
        }
    }

    /// <summary>Card height used for marquee hit-testing (comment cards flow, so use a representative height).</summary>
    private static double SelectHeight(EdNode n) => n.Kind == StoryNodeKind.Comment ? 72 : NodeHeight(n);

    private bool IsSelected(EdNode n) => n.Id == SelectedId || _Selected.Contains(n.Id);

    // ── Add node at the view centre / minimap navigation ────────────────────

    /// <summary>Toolbar "Add node" — drop the palette's node at the centre of the visible canvas, not a far-off default.</summary>
    private async Task AddNodeAtCenter()
    {
        double[] r  = await RectAsync();
        double   wx = (r[2] / 2 - _PanX) / _Scale;
        double   wy = (r[3] / 2 - _PanY) / _Scale;
        await OnAddNode.InvokeAsync(new CanvasPoint(wx, wy));
    }

    /// <summary>Click the minimap — recentre the view on the world point that was clicked.</summary>
    private async Task MinimapDown(PointerEventArgs e)
    {
        if (Nodes.Count == 0) return;
        const double mapW = 168, mapH = 96, pad = 10, nodeH = 82;
        double minX = Nodes.Min(n => n.X), maxX = Nodes.Max(n => n.X) + NODE_W;
        double minY = Nodes.Min(n => n.Y), maxY = Nodes.Max(n => n.Y) + nodeH;
        double bw = Math.Max(1, maxX - minX), bh = Math.Max(1, maxY - minY);
        double s  = Math.Min((mapW - 2 * pad) / bw, (mapH - 2 * pad) / bh);

        double worldX = minX + (e.OffsetX - pad) / s;
        double worldY = minY + (e.OffsetY - pad) / s;

        double[] r = await RectAsync();
        _PanX = r[2] / 2 - worldX * _Scale;
        _PanY = r[3] / 2 - worldY * _Scale;
    }

    private async Task<double[]> RectAsync()
    {
        IJSObjectReference module = await ModuleAsync();
        return await module.InvokeAsync<double[]>("rect", _CanvasEl);
    }

    private void OnWheel(WheelEventArgs e)
    {
        double factor = e.DeltaY < 0 ? 1.1 : 1 / 1.1;
        _Scale = Math.Clamp(_Scale * factor, 0.35, 2.2);
    }

    // ── Connecting ports ───────────────────────────────────────────────────

    private void StartConnect(PointerEventArgs e, Guid fromPoint)
    {
        _ConnFrom       = fromPoint;
        _ConnMoved      = false;
        _SelectedEdgeId = null;
        if (_Anchors.TryGetValue(fromPoint, out PortAnchor a))
        {
            _ConnX = a.X;
            _ConnY = a.Y;
        }
        _LastClientX = e.ClientX;
        _LastClientY = e.ClientY;
    }

    /// <summary>
    /// The input port nearest the current drag point (<see cref="_ConnX"/>/<see cref="_ConnY"/>), within
    /// <see cref="SNAP_RADIUS"/> and not on the source node. Null when the drop lands away from any input.
    /// </summary>
    private Guid? NearestInputPoint(Guid fromPoint)
    {
        bool     haveSrc     = _Anchors.TryGetValue(fromPoint, out PortAnchor src);
        Guid     sourceNode  = haveSrc ? src.NodeId   : Guid.Empty;
        PortType sourceType  = haveSrc ? src.Type     : PortType.Flow;
        bool     fromChoice  = haveSrc && src.OwnerKind == StoryNodeKind.Choice;
        Guid?    best        = null;
        double   bestDist    = SNAP_RADIUS * SNAP_RADIUS;

        foreach ((Guid pointId, PortAnchor a) in _Anchors)
        {
            if (a.IsOutput || a.NodeId == sourceNode || a.Type != sourceType) continue;
            // A Choice option's flow-out may land only on an Exit node.
            if (fromChoice && a.OwnerKind != StoryNodeKind.LogicExit) continue;
            double dx = a.X - _ConnX, dy = a.Y - _ConnY;
            double d2 = dx * dx + dy * dy;
            if (d2 <= bestDist)
            {
                bestDist = d2;
                best     = pointId;
            }
        }
        return best;
    }

    private void SelectEdge(Guid edgeId) => _SelectedEdgeId = edgeId;

    // ── Context menu ───────────────────────────────────────────────────────

    /// <summary>Right-click on empty canvas — convert the cursor to world coordinates and ask to open the palette.</summary>
    private async Task CanvasContextMenu(MouseEventArgs e)
    {
        _MenuNode = null;
        // Anchor from the measured canvas rect — OffsetX is relative to whatever child was hit, not the canvas.
        double[] r = await RectAsync();
        double wx = (e.ClientX - r[0] - _PanX) / _Scale;
        double wy = (e.ClientY - r[1] - _PanY) / _Scale;
        await OnCanvasContextMenu.InvokeAsync(new CanvasPoint(wx, wy));
    }

    /// <summary>Right-click on a node — open its edit/delete menu at the cursor. Built-in boundary nodes have none.</summary>
    private void NodeContextMenu(MouseEventArgs e, EdNode node)
    {
        if (!node.Deletable && !node.Editable) { _MenuNode = null; return; }
        _MenuNode = node;
        _MenuX    = e.ClientX;
        _MenuY    = e.ClientY;
    }

    private void CloseMenu() => _MenuNode = null;

    private async Task MenuInvoke(EventCallback<EdNode> callback, EdNode node)
    {
        _MenuNode = null;
        await callback.InvokeAsync(node);
    }

    private static string MenuNoun(EdNode n) => n.Kind switch
    {
        StoryNodeKind.Logic        => "logic node",
        StoryNodeKind.Container    => "container",
        StoryNodeKind.PortalIn     => "portal in",
        StoryNodeKind.PortalOut    => "portal",
        StoryNodeKind.Localization    => "localization node",
        StoryNodeKind.Icon            => "icon node",
        StoryNodeKind.LightDarkSwitch => "light/dark switch",
        StoryNodeKind.SmartFormat      => "SmartFormat node",
        StoryNodeKind.ExternalVariable => "external variable node",
        StoryNodeKind.FlowText         => "flow text node",
        StoryNodeKind.SetExternalVariable => "set external variable node",
        StoryNodeKind.Choice              => "choice node",
        StoryNodeKind.AppGamebookTextSplitter => "App/Gamebook text splitter",
        StoryNodeKind.AppGamebookFlowSplitter => "App/Gamebook flow splitter",
        StoryNodeKind.PrevExitVariable        => "selection variable",
        StoryNodeKind.Condition               => "condition node",
        StoryNodeKind.Comment                 => "comment",
        _                       => "node"
    };

    // ── Edge geometry ──────────────────────────────────────────────────────

    private static string EdgePath(double x1, double y1, double x2, double y2)
    {
        double dx = Math.Max(40, Math.Abs(x2 - x1) / 2);
        return $"M {F(x1)} {F(y1)} C {F(x1 + dx)} {F(y1)}, {F(x2 - dx)} {F(y2)}, {F(x2)} {F(y2)}";
    }

    private static string F(double v) => v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    // ── JS module (element measuring + Space-key bridge) ────────────────────

    private async Task<IJSObjectReference> ModuleAsync() =>
        _Module ??= await _JS.InvokeAsync<IJSObjectReference>("import", "./js/editor-graph.js");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _SelfRef = DotNetObjectReference.Create(this);
        await (await ModuleAsync()).InvokeVoidAsync("register", _SelfRef);
    }

    /// <summary>Called from JS when the Space key is pressed or released (Space + left-drag pans the canvas).</summary>
    [JSInvokable]
    public void SetSpaceHeld(bool held)
    {
        _SpaceHeld = held;
    }

    /// <summary>Called from JS on Ctrl/Cmd+Z — bubbles up to the editor to undo the last action.</summary>
    [JSInvokable]
    public Task Undo() => OnUndo.InvokeAsync();

    /// <summary>Called from JS on Ctrl/Cmd+Y (or Ctrl/Cmd+Shift+Z) — bubbles up to the editor to redo.</summary>
    [JSInvokable]
    public Task Redo() => OnRedo.InvokeAsync();

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_Module is not null)
            {
                await _Module.InvokeVoidAsync("unregister");
                await _Module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { /* circuit already gone — nothing to unwind */ }
        _SelfRef?.Dispose();
    }
}

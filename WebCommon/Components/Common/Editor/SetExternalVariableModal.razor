@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Set-External-Variable node: picks a story-wide external
   variable and the value to assign it (one of the variable's possible values).
   The physical game components track external variables automatically, so this
   emits no Gamebook instruction — it drives the App's play-time state only.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box sev-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.SetExternalVariable.editTitle) : Loc.T(Localization.Editor.Modals.SetExternalVariable.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body sev-body">

            @{
                List<StoryVariable> vars = Variables();
            }
            @if (vars.Count == 0)
            {
                <div class="sev-empty">
                    <i class="bi bi-braces"></i>
                    <span>@Loc.T(Localization.Editor.Modals.SetExternalVariable.noVariablesYet)</span>
                </div>
            }
            else
            {
                <div class="modal-field">
                    <label class="modal-label">@Loc.T(Localization.Common.Fields.variable)</label>
                    <div class="sev-list">
                        @foreach (StoryVariable v in vars)
                        {
                            StoryVariable variable = v;
                            <button class="sev-item @(_SelectedVariableId == variable.Id ? "selected" : "")"
                                    @onclick="() => SelectVariable(variable)">
                                <span class="sev-item-name">@(string.IsNullOrWhiteSpace(variable.Name) ? Loc.T(Localization.Common.Placeholders.unnamed) : variable.Name)</span>
                                <span class="sev-item-sub">@Loc.T(Localization.Common.Misc.valueCount, new Dictionary<string, object> { ["count"] = variable.PossibleValues.Count })</span>
                            </button>
                        }
                    </div>
                </div>

                @if (Selected is StoryVariable sel)
                {
                    <div class="modal-field">
                        <label class="modal-label">@Loc.T(Localization.Editor.Modals.SetExternalVariable.howToAssign)</label>
                        <select class="modal-input" value="@((int)_Mode)" @onchange="OnModeChanged">
                            <option value="@((int)StorySetExternalVariableMode.SpecificValue)">@Loc.T(Localization.Editor.Modals.SetExternalVariable.modeSpecificValue)</option>
                            <option value="@((int)StorySetExternalVariableMode.MapFromVariable)">@Loc.T(Localization.Editor.Modals.SetExternalVariable.modeMapFromVariable)</option>
                            <option value="@((int)StorySetExternalVariableMode.RemapFromVariable)">@Loc.T(Localization.Editor.Modals.SetExternalVariable.modeRemapFromVariable)</option>
                        </select>
                    </div>

                    @switch (_Mode)
                    {
                        case StorySetExternalVariableMode.SpecificValue:
                            <div class="modal-field">
                                <label class="modal-label">@Loc.T(Localization.Common.Fields.value)</label>
                                @if (sel.PossibleValues.Count == 0)
                                {
                                    <div class="sev-hint">@Loc.T(Localization.Editor.Modals.SetExternalVariable.noPossibleValues)</div>
                                }
                                else
                                {
                                    <select class="modal-input" @bind="_Value">
                                        @foreach (string value in sel.PossibleValues)
                                        {
                                            <option value="@value">@value</option>
                                        }
                                    </select>
                                }
                            </div>
                            break;

                        case StorySetExternalVariableMode.MapFromVariable:
                            <div class="sev-hint">@((MarkupString)Loc.T(Localization.Editor.Modals.SetExternalVariable.mapFromVariableHint))</div>
                            break;

                        case StorySetExternalVariableMode.RemapFromVariable:
                            <div class="sev-hint">
                                @((MarkupString)Loc.T(Localization.Editor.Modals.SetExternalVariable.remapFromVariableHint))
                            </div>
                            @if (sel.PossibleValues.Count == 0)
                            {
                                <div class="sev-hint">@Loc.T(Localization.Editor.Modals.SetExternalVariable.noPossibleValues)</div>
                            }
                            else
                            {
                                <div class="modal-field">
                                    <label class="modal-label">@Loc.T(Localization.Editor.Modals.SetExternalVariable.valueConversions)</label>
                                    <div class="sev-map">
                                        @for (int i = 0; i < _ValueMap.Count; ++i)
                                        {
                                            int row = i;
                                            <div class="sev-map-row">
                                                <input class="modal-input sev-map-from" placeholder="@Loc.T(Localization.Editor.Modals.SetExternalVariable.incomingValuePlaceholder)"
                                                       value="@_ValueMap[row].From"
                                                       @onchange="e => _ValueMap[row].From = e.Value?.ToString() ?? string.Empty"/>
                                                <i class="bi bi-arrow-right sev-map-arrow"></i>
                                                <select class="modal-input sev-map-to" value="@_ValueMap[row].To"
                                                        @onchange="e => _ValueMap[row].To = e.Value?.ToString() ?? string.Empty">
                                                    @foreach (string value in sel.PossibleValues)
                                                    {
                                                        <option value="@value">@value</option>
                                                    }
                                                </select>
                                                <button class="sev-map-del" title="@Loc.T(Localization.Editor.Modals.SetExternalVariable.removeConversion)" @onclick="() => RemoveMapping(row)">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    <button class="modal-btn modal-btn-ghost sev-map-add" @onclick="() => AddMapping(sel)">
                                        <i class="bi bi-plus-lg"></i> @Loc.T(Localization.Editor.Modals.SetExternalVariable.addConversion)
                                    </button>
                                </div>
                            }
                            break;
                    }
                }
            }

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!CanConfirm)">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : Loc.T(Localization.Editor.Modals.SetExternalVariable.confirm))
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<SetExternalVariableArgs> OnConfirm { get; set; }

    private bool                                _Visible;
    private bool                                _IsEdit;
    private Guid                                _EditNodeId;
    private Guid                                _SelectedVariableId;
    private StorySetExternalVariableMode        _Mode;
    private string                              _Value = "";
    private List<StorySetExternalVariableRemap> _ValueMap = new();

    private StoryProject Project => _ProjectState.CurrentProject!;

    /// <summary>Opens the modal to create a new Set-External-Variable node.</summary>
    public void Show()
    {
        _IsEdit             = false;
        _EditNodeId         = Guid.Empty;
        _SelectedVariableId = Guid.Empty;
        _Mode               = StorySetExternalVariableMode.SpecificValue;
        _Value              = "";
        _ValueMap           = new();
        _Visible            = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Set-External-Variable node.</summary>
    public void ShowEdit(StorySetExternalVariableNode node)
    {
        _IsEdit             = true;
        _EditNodeId         = node.Id;
        _SelectedVariableId = node.SelectedVariableId;
        _Mode               = node.Mode;
        _Value              = node.Value;
        // Clone so edits stay local until the author confirms.
        _ValueMap           = node.ValueMap.Select(m => new StorySetExternalVariableRemap { From = m.From, To = m.To }).ToList();
        _Visible            = true;
        StateHasChanged();
    }

    private StoryVariable? Selected =>
        _SelectedVariableId != Guid.Empty && Project.Variables.TryGetValue(_SelectedVariableId, out StoryVariable? v) ? v : null;

    private bool CanConfirm =>
        Selected is StoryVariable sel
     && (_Mode != StorySetExternalVariableMode.SpecificValue || sel.PossibleValues.Count == 0 || !string.IsNullOrEmpty(_Value));

    private List<StoryVariable> Variables() =>
        Project.Variables.Values.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase).ToList();

    private void SelectVariable(StoryVariable variable)
    {
        _SelectedVariableId = variable.Id;
        // Keep the current value if it's still valid; otherwise default to the first possible value.
        if (!variable.PossibleValues.Contains(_Value))
            _Value = variable.PossibleValues.FirstOrDefault() ?? "";
        // Drop conversions whose target is no longer a possible value of the newly picked variable.
        _ValueMap.RemoveAll(m => !variable.PossibleValues.Contains(m.To));
    }

    private void OnModeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int mode))
            _Mode = (StorySetExternalVariableMode)mode;
    }

    private void AddMapping(StoryVariable variable) =>
        _ValueMap.Add(new StorySetExternalVariableRemap { From = "", To = variable.PossibleValues.FirstOrDefault() ?? "" });

    private void RemoveMapping(int index)
    {
        if (index >= 0 && index < _ValueMap.Count) _ValueMap.RemoveAt(index);
    }

    private async Task Confirm()
    {
        if (!CanConfirm) return;
        _Visible = false;
        // Only carry the conversion table when it's actually used.
        List<StorySetExternalVariableRemap> valueMap = _Mode == StorySetExternalVariableMode.RemapFromVariable ? _ValueMap : new();
        await OnConfirm.InvokeAsync(new SetExternalVariableArgs(_EditNodeId, _SelectedVariableId, _Mode, _Value, valueMap));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record SetExternalVariableArgs(
        Guid EditNodeId, Guid SelectedVariableId, StorySetExternalVariableMode Mode, string Value,
        List<StorySetExternalVariableRemap> ValueMap);
}

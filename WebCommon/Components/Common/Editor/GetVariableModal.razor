@namespace DeusaldStoryWeb.Components.Common
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Get Variable node: picks a registered storage variable to
   read, optionally overrides the SmartFormat token name, and sets the preview
   value shown in the App preview (the App tracks the live value at runtime; the
   Gamebook prints the variable's slot tag instead). Used by create and edit.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box gvm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? "Edit get variable" : "Get variable")</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body gvm-body">

            <div class="modal-field">
                <label class="modal-label">Registered variable</label>
                @{
                    List<StoryRegisterVariableNode> vars = RegisteredVariables();
                }
                @if (vars.Count == 0)
                {
                    <div class="gvm-empty">
                        <i class="bi bi-box-seam"></i>
                        <span>No variables registered yet — add a Register-variable node first.</span>
                    </div>
                }
                else
                {
                    <div class="gvm-list">
                        @foreach (StoryRegisterVariableNode v in vars)
                        {
                            StoryRegisterVariableNode variable = v;
                            <button class="gvm-item @(_RegisteredVariableId == variable.Id ? "selected" : "")"
                                    @onclick="() => _RegisteredVariableId = variable.Id">
                                <span class="gvm-item-name">@(string.IsNullOrWhiteSpace(variable.Name) ? "(unnamed)" : variable.Name)</span>
                                <span class="gvm-item-slot">@StorageSlots.Label(variable.Type, variable.SlotIndex)</span>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="modal-field">
                <label class="modal-label">Name override</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@_RegisteredName"
                       @bind="_NameOverride"
                       @bind:event="oninput"
                       maxlength="100"/>
                <span class="modal-label-hint">the <code>{token}</code> name this value fills in the text — blank uses the variable's own name</span>
            </div>

            <div class="modal-field">
                <label class="modal-label">Preview value</label>
                <input class="modal-input"
                       type="text"
                       placeholder="value shown in the App preview"
                       @bind="_PreviewValue"
                       @bind:event="oninput"
                       maxlength="100"/>
                <span class="modal-label-hint">shown in the App preview; blank falls back to the registered variable's preview value. The Gamebook prints the slot tag instead of a value.</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(_RegisteredVariableId == Guid.Empty)">
                @(_IsEdit ? "Save changes" : "Add get variable node")
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<GetVariableArgs> OnConfirm { get; set; }

    private bool   _Visible;
    private bool   _IsEdit;
    private Guid   _EditNodeId;
    private Guid   _RegisteredVariableId;
    private string _NameOverride = "";
    private string _PreviewValue = "";

    /// <summary>The picked register's name, used as the name-override placeholder ("" when nothing picked).</summary>
    private string _RegisteredName =>
        RegisteredVariables().Find(v => v.Id == _RegisteredVariableId) is { Name: { Length: > 0 } n } ? n : "variable name";

    /// <summary>Opens the modal to create a new Get Variable node.</summary>
    public void Show()
    {
        _IsEdit               = false;
        _EditNodeId           = Guid.Empty;
        _RegisteredVariableId = Guid.Empty;
        _NameOverride         = "";
        _PreviewValue         = "";
        _Visible              = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Get Variable node.</summary>
    public void ShowEdit(StoryGetVariableNode node)
    {
        _IsEdit               = true;
        _EditNodeId           = node.Id;
        _RegisteredVariableId = node.RegisteredVariableId;
        _NameOverride         = node.NameOverride;
        _PreviewValue         = node.PreviewValue;
        _Visible              = true;
        StateHasChanged();
    }

    private List<StoryRegisterVariableNode> RegisteredVariables()
    {
        List<StoryRegisterVariableNode> list = new();
        foreach (StoryLogicNode logic in _ProjectState.CurrentProject!.LogicNodes.Values)
            list.AddRange(logic.RegisterVariableNodes);
        return list.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private async Task Confirm()
    {
        if (_RegisteredVariableId == Guid.Empty) return;
        _Visible = false;
        await OnConfirm.InvokeAsync(new GetVariableArgs(_EditNodeId, _RegisteredVariableId, _NameOverride.Trim(), _PreviewValue.Trim()));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record GetVariableArgs(Guid EditNodeId, Guid RegisteredVariableId, string NameOverride, string PreviewValue);
}

@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Get Variable node: picks a global variable (External or
   Internal, including the read-only built-ins) to read, optionally overrides the
   Value / Slot SmartFormat token names, and sets the preview value shown in the App
   preview. The Slot token applies only to Internal variables (they own a board slot).
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box gvm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.GetVariable.editTitle) : Loc.T(Localization.Editor.Modals.GetVariable.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body gvm-body">

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Editor.Modals.GetVariable.registeredVariable)</label>
                <input class="modal-input" type="text" placeholder="Search"
                       @bind="_Search" @bind:event="oninput"/>
                @{
                    List<StoryVariable> vars = FilteredVariables();
                }
                @if (vars.Count == 0)
                {
                    <div class="gvm-empty">
                        <i class="bi bi-braces"></i>
                        <span>@Loc.T(Localization.Common.Messages.noVariablesRegistered)</span>
                    </div>
                }
                else
                {
                    <div class="gvm-list">
                        @foreach (StoryVariable v in vars)
                        {
                            StoryVariable variable = v;
                            <button class="gvm-item @(_SelectedVariableId == variable.Id ? "selected" : "")"
                                    @onclick="() => _SelectedVariableId = variable.Id">
                                <span class="gvm-item-name">@(string.IsNullOrWhiteSpace(variable.Name) ? Loc.T(Localization.Common.Placeholders.unnamed) : variable.Name)</span>
                                <span class="gvm-item-slot">@SlotOrScope(variable)</span>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Editor.Modals.GetVariable.nameOverride)</label>
                <input class="modal-input" type="text" placeholder="@_SelectedName"
                       @bind="_NameOverride" @bind:event="oninput" maxlength="100"/>
            </div>

            @if (_SelectedInternal)
            {
                <div class="modal-field">
                    <label class="modal-label">@Loc.T(Localization.Editor.Modals.GetVariable.slotNameOverride)</label>
                    <input class="modal-input" type="text" placeholder="@_DefaultSlotName"
                           @bind="_SlotNameOverride" @bind:event="oninput" maxlength="100"/>
                </div>
            }

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Common.Fields.previewValue)</label>
                <input class="modal-input" type="text"
                       placeholder="@Loc.T(Localization.Editor.Modals.GetVariable.previewValuePlaceholder)"
                       @bind="_PreviewValue" @bind:event="oninput" maxlength="100"/>
                <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.GetVariable.previewValueHint)</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm" disabled="@(!_CanConfirm)">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : Loc.T(Localization.Editor.Modals.GetVariable.addButton))
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<GetVariableArgs> OnConfirm { get; set; }

    private bool   _Visible;
    private bool   _IsEdit;
    private Guid   _EditNodeId;
    private Guid   _SelectedVariableId;
    private string _Search           = "";
    private string _NameOverride     = "";
    private string _SlotNameOverride = "";
    private string _PreviewValue     = "";

    private StoryVariable? _Selected => StoryLogicFlow.Variable(_ProjectState.CurrentProject!, _SelectedVariableId);
    private bool           _SelectedInternal => _Selected is { Scope: StoryVariableScope.Internal };
    private string         _SelectedName => _Selected is { Name: { Length: > 0 } n } ? n : "variable name";
    private string         _DefaultSlotName => (string.IsNullOrWhiteSpace(_NameOverride) ? _SelectedName : _NameOverride.Trim()) + "Slot";
    private bool           _CanConfirm => _SelectedVariableId != Guid.Empty;

    /// <summary>Opens the modal to create a new Get Variable node.</summary>
    public void Show()
    {
        _IsEdit             = false;
        _EditNodeId         = Guid.Empty;
        _SelectedVariableId = Guid.Empty;
        _Search             = "";
        _NameOverride       = "";
        _SlotNameOverride   = "";
        _PreviewValue       = "";
        _Visible            = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Get Variable node.</summary>
    public void ShowEdit(StoryGetVariableNode node)
    {
        _IsEdit             = true;
        _EditNodeId         = node.Id;
        _SelectedVariableId = node.SelectedVariableId;
        _Search             = "";
        _NameOverride       = node.NameOverride;
        _SlotNameOverride   = node.SlotNameOverride;
        _PreviewValue       = node.PreviewValue;
        _Visible            = true;
        StateHasChanged();
    }

    private List<StoryVariable> FilteredVariables()
    {
        IEnumerable<StoryVariable> all = _ProjectState.CurrentProject!.Variables.Values.Concat(StoryBuiltInVariables.All);
        if (!string.IsNullOrWhiteSpace(_Search))
            all = all.Where(v => v.Name.Contains(_Search.Trim(), StringComparison.OrdinalIgnoreCase));
        return all.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private string SlotOrScope(StoryVariable v) =>
        v.Scope == StoryVariableScope.Internal
            ? StoryVariableSlots.Label(v.InternalSubtype, v.SlotIndex)
            : v.ExternalForm.ToString();

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;
        string slotOverride = _SelectedInternal ? _SlotNameOverride.Trim() : "";
        await OnConfirm.InvokeAsync(new GetVariableArgs(_EditNodeId, _SelectedVariableId, _NameOverride.Trim(), slotOverride, _PreviewValue.Trim()));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record GetVariableArgs(
        Guid   EditNodeId,
        Guid   SelectedVariableId,
        string NameOverride,
        string SlotNameOverride,
        string PreviewValue);
}

@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Get Variable node: picks a registered storage variable to
   read, optionally overrides the Value / Slot SmartFormat token names, and sets the preview
   value shown in the App preview (the App tracks the live value at runtime; the
   Gamebook prints the variable's slot tag instead). Used by create and edit.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box gvm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.GetVariable.editTitle) : Loc.T(Localization.Editor.Modals.GetVariable.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body gvm-body">

            @* ── Which variable: one picked here, or one named by the wired Name port ── *@
            <div class="modal-field">
                <label class="gvm-mode">
                    <input type="radio"
                           name="gvm-mode"
                           checked="@(_RefMode == StorageVariableRefMode.Specific)"
                           @onchange="() => _RefMode = StorageVariableRefMode.Specific"/>
                    <span>@Loc.T(Localization.Editor.Modals.GetVariable.modeSpecific)</span>
                </label>
                <label class="gvm-mode">
                    <input type="radio"
                           name="gvm-mode"
                           checked="@(_RefMode == StorageVariableRefMode.ByType)"
                           @onchange="() => _RefMode = StorageVariableRefMode.ByType"/>
                    <span>@Loc.T(Localization.Editor.Modals.GetVariable.modeByType)</span>
                </label>
            </div>

            @if (_RefMode == StorageVariableRefMode.Specific)
            {
                <div class="modal-field">
                    <label class="modal-label">@Loc.T(Localization.Editor.Modals.GetVariable.registeredVariable)</label>
                    @{
                        List<StoryRegisterVariableNode> vars = RegisteredVariables();
                    }
                    @if (vars.Count == 0)
                    {
                        <div class="gvm-empty">
                            <i class="bi bi-box-seam"></i>
                            <span>@Loc.T(Localization.Common.Messages.noVariablesRegistered)</span>
                        </div>
                    }
                    else
                    {
                        <div class="gvm-list">
                            @foreach (StoryRegisterVariableNode v in vars)
                            {
                                StoryRegisterVariableNode variable = v;
                                <button class="gvm-item @(_RegisteredVariableId == variable.Id ? "selected" : "")"
                                        @onclick="() => _RegisteredVariableId = variable.Id">
                                    <span class="gvm-item-name">@(string.IsNullOrWhiteSpace(variable.Name) ? Loc.T(Localization.Common.Placeholders.unnamed) : variable.Name)</span>
                                    <span class="gvm-item-slot">@StorageSlots.Label(variable.Type, variable.SlotIndex)</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="modal-field">
                    <label class="modal-label">@Loc.T(Localization.Editor.Modals.RegisterVariable.storageType)</label>
                    <select class="modal-input" @bind="_RefType">
                        <option value="@StorageVariableType.Number">@Loc.T(Localization.Editor.Modals.RegisterVariable.storageTypeNumber)</option>
                        <option value="@StorageVariableType.Dial">@Loc.T(Localization.Common.Misc.dialRange)</option>
                        <option value="@StorageVariableType.String">@Loc.T(Localization.Common.Misc.stringWritten)</option>
                    </select>
                    <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.GetVariable.byTypeHint)</span>
                </div>
            }

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Editor.Modals.GetVariable.nameOverride)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@_RegisteredName"
                       @bind="_NameOverride"
                       @bind:event="oninput"
                       maxlength="100"/>
                <span class="modal-label-hint">@((MarkupString)Loc.T(Localization.Editor.Modals.GetVariable.nameOverrideHint).Replace("[slotToken]", _SlotToken))</span>
            </div>

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Editor.Modals.GetVariable.slotNameOverride)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@_DefaultSlotName"
                       @bind="_SlotNameOverride"
                       @bind:event="oninput"
                       maxlength="100"/>
                <span class="modal-label-hint">@((MarkupString)Loc.T(Localization.Editor.Modals.GetVariable.slotNameOverrideHint).Replace("[defaultSlotToken]", "{" + _DefaultSlotName + "}"))</span>
            </div>

            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Common.Fields.previewValue)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@Loc.T(Localization.Editor.Modals.GetVariable.previewValuePlaceholder)"
                       @bind="_PreviewValue"
                       @bind:event="oninput"
                       maxlength="100"/>
                <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.GetVariable.previewValueHint)</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : Loc.T(Localization.Editor.Modals.GetVariable.addButton))
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<GetVariableArgs> OnConfirm { get; set; }

    private bool                   _Visible;
    private bool                   _IsEdit;
    private Guid                   _EditNodeId;
    private StorageVariableRefMode _RefMode;
    private StorageVariableType    _RefType;
    private Guid                   _RegisteredVariableId;
    private string                 _NameOverride     = "";
    private string                 _SlotNameOverride = "";
    private string                 _PreviewValue     = "";

    /// <summary>The picked register's name, used as the name-override placeholder ("" when nothing picked).</summary>
    private string _RegisteredName =>
        RegisteredVariables().Find(v => v.Id == _RegisteredVariableId) is { Name: { Length: > 0 } n } ? n : "variable name";

    /// <summary>A ByType node names its variable through a wire, so only a Specific node needs a pick before it can be saved.</summary>
    private bool _CanConfirm =>
        _RefMode == StorageVariableRefMode.ByType || _RegisteredVariableId != Guid.Empty;

    /// <summary>The Slot port's default token name — the Value token plus a <c>Slot</c> suffix (mirrors <c>StoryLogicRenderer.SlotTokenName</c>).</summary>
    private string _DefaultSlotName =>
        (string.IsNullOrWhiteSpace(_NameOverride) ? _RegisteredName : _NameOverride.Trim()) + "Slot";

    /// <summary>The <c>{token}</c> the Slot port actually fills — its override, else the default (mirrors <c>StoryLogicRenderer.GetVariableSlotName</c>).</summary>
    private string _SlotToken =>
        "{" + (string.IsNullOrWhiteSpace(_SlotNameOverride) ? _DefaultSlotName : _SlotNameOverride.Trim()) + "}";

    /// <summary>Opens the modal to create a new Get Variable node.</summary>
    public void Show()
    {
        _IsEdit               = false;
        _EditNodeId           = Guid.Empty;
        _RefMode              = StorageVariableRefMode.Specific;
        _RefType              = StorageVariableType.Number;
        _RegisteredVariableId = Guid.Empty;
        _NameOverride         = "";
        _SlotNameOverride     = "";
        _PreviewValue         = "";
        _Visible              = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Get Variable node.</summary>
    public void ShowEdit(StoryGetVariableNode node)
    {
        _IsEdit               = true;
        _EditNodeId           = node.Id;
        _RefMode              = node.RefMode;
        _RefType              = node.RefType;
        _RegisteredVariableId = node.RegisteredVariableId;
        _NameOverride         = node.NameOverride;
        _SlotNameOverride     = node.SlotNameOverride;
        _PreviewValue         = node.PreviewValue;
        _Visible              = true;
        StateHasChanged();
    }

    private List<StoryRegisterVariableNode> RegisteredVariables()
    {
        List<StoryRegisterVariableNode> list = new();
        foreach (StoryLogicNode logic in _ProjectState.CurrentProject!.LogicNodes.Values)
            list.AddRange(logic.RegisterVariableNodes);
        return list.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;
        // A ByType node takes its target from the Name wire, so it keeps no register id.
        Guid registered = _RefMode == StorageVariableRefMode.ByType ? Guid.Empty : _RegisteredVariableId;
        await OnConfirm.InvokeAsync(new GetVariableArgs(_EditNodeId, _RefMode, _RefType, registered, _NameOverride.Trim(), _SlotNameOverride.Trim(), _PreviewValue.Trim()));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record GetVariableArgs(
        Guid                   EditNodeId,
        StorageVariableRefMode RefMode,
        StorageVariableType    RefType,
        Guid                   RegisteredVariableId,
        string                 NameOverride,
        string                 SlotNameOverride,
        string                 PreviewValue);
}

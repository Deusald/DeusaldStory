@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@* ─────────────────────────────────────────────────────────────────────────
   Edits a logic node's Exit node: the list of choices (continuations). Each
   choice has a name and — in Single-path mode — a value per declared variable.
   When a variable is wired into the Exit node's Variables input the App
   auto-resolves to one button: each choice carries a condition and the LAST
   choice is the locked Else fallback (no condition).
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box enm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@Loc.T(Localization.Editor.Modals.Exit.title)</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body enm-body">

            @if (_Auto)
            {
                @* When variables are wired, choose how they drive the exit. Hub Paths always uses Choice Visibility. *@
                @if (_ExitMode != StoryLogicExitMode.HubPaths)
                {
                    <div class="modal-field">
                        <label class="modal-label">@Loc.T(Localization.Editor.Modals.Exit.autoModeLabel)</label>
                        <div class="enm-mode">
                            <button type="button"
                                    class="enm-mode-opt @(_AutoMode == StoryExitAutoMode.AutomaticChoice ? "active" : "")"
                                    @onclick="() => _AutoMode = StoryExitAutoMode.AutomaticChoice">
                                <span class="enm-mode-title">@Loc.T(Localization.Editor.Modals.Exit.automaticChoiceTitle)</span>
                                <span class="enm-mode-desc">@Loc.T(Localization.Editor.Modals.Exit.automaticChoiceDesc)</span>
                            </button>
                            <button type="button"
                                    class="enm-mode-opt @(_AutoMode == StoryExitAutoMode.ChoiceVisibility ? "active" : "")"
                                    @onclick="() => _AutoMode = StoryExitAutoMode.ChoiceVisibility">
                                <span class="enm-mode-title">@Loc.T(Localization.Editor.Modals.Exit.choiceVisibilityTitle)</span>
                                <span class="enm-mode-desc">@Loc.T(Localization.Editor.Modals.Exit.choiceVisibilityDesc)</span>
                            </button>
                        </div>
                    </div>
                }

                <div class="modal-note">
                    <i class="bi bi-info-circle"></i>
                    <span>@((MarkupString)Loc.T(_AutoMode == StoryExitAutoMode.AutomaticChoice
                        ? Localization.Editor.Modals.Exit.autoConditionsNote
                        : Localization.Editor.Modals.Exit.visibilityConditionsNote))</span>
                </div>
            }

            @for (int i = 0; i < _Rows.Count; i++)
            {
                int  index  = i;
                Row  row    = _Rows[i];
                bool isElse = _Auto && _AutoMode == StoryExitAutoMode.AutomaticChoice && index == _Rows.Count - 1;
                <div class="enm-choice">
                    <div class="enm-choice-head">
                        <span class="enm-num">@(index + 1)</span>
                        <input class="modal-input enm-name" type="text" placeholder="@Loc.T(Localization.Editor.Modals.Exit.choiceNamePlaceholder)"
                               @bind="row.Name" @bind:event="oninput"/>
                        @if (isElse)
                        {
                            <span class="enm-else-tag">@Loc.T(Localization.Editor.Modals.Exit.elseTag)</span>
                        }
                        <button class="enm-del" title="@Loc.T(Localization.Editor.Modals.Exit.removeChoice)" disabled="@(_Rows.Count <= 1)" @onclick="() => RemoveRow(index)">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                    @if (_SinglePath && _Declared.Count > 0)
                    {
                        <div class="enm-values">
                            @foreach (StoryDeclaredVariable d in _Declared)
                            {
                                Guid vid = d.Id;
                                <div class="enm-value">
                                    <label class="enm-value-label">@(string.IsNullOrWhiteSpace(d.Name) ? Loc.T(Localization.Editor.Modals.Exit.varNameFallback) : d.Name)</label>
                                    <select class="modal-input" value="@row.Value(vid)" @onchange="e => row.SetValue(vid, e.Value?.ToString() ?? string.Empty)">
                                        @foreach (string val in d.PossibleValues)
                                        {
                                            <option value="@val">@(string.IsNullOrEmpty(val) ? Loc.T(Localization.Common.Placeholders.empty) : val)</option>
                                        }
                                    </select>
                                </div>
                            }
                        </div>
                    }

                    @if (_Auto && !isElse)
                    {
                        <ExitConditionEditor Expr="row.Condition" Vars="_AvailableVars" OnChanged="StateHasChanged"/>
                    }
                </div>
            }

            <button class="enm-add" @onclick="AddRow">
                <i class="bi bi-plus-lg"></i> @Loc.T(Localization.Editor.Modals.Exit.addChoice)
            </button>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm" disabled="@(_Rows.Count == 0)">@Loc.T(Localization.Common.Buttons.saveChanges)</button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<ExitNodeArgs> OnConfirm { get; set; }

    private bool                          _Visible;
    private bool                          _SinglePath;
    private bool                          _Auto;
    private StoryLogicExitMode            _ExitMode;
    private StoryExitAutoMode             _AutoMode;
    private List<StoryDeclaredVariable>   _Declared      = new();
    private List<(Guid Id, string Name)>  _AvailableVars = new();
    private List<Row>                     _Rows          = new();

    private sealed class Row
    {
        public Guid                     Id        { get; init; }
        public string                   Name      { get; set; } = "";
        public StoryConditionExpr       Condition { get; set; } = new() { Kind = StoryConditionExprKind.Group };
        public Dictionary<Guid, string> Values    { get; init; } = new();

        public string Value(Guid id) => Values.TryGetValue(id, out string? v) ? v : "";
        public void   SetValue(Guid id, string v) => Values[id] = v;
    }

    /// <summary>Opens the modal to edit <paramref name="logic"/>'s choices. <paramref name="availableVars"/> are the variables
    /// wired into the Exit node's Variables input (empty when the node isn't auto-resolving).</summary>
    public void ShowEdit(StoryLogicNode logic, List<(Guid Id, string Name)> availableVars)
    {
        _SinglePath    = logic.ExitMode == StoryLogicExitMode.SinglePath;
        _Auto          = availableVars.Count > 0;
        _ExitMode      = logic.ExitMode;
        // Hub Paths is always visibility-driven; otherwise honour the node's stored auto mode.
        _AutoMode      = logic.ExitMode == StoryLogicExitMode.HubPaths ? StoryExitAutoMode.ChoiceVisibility : logic.ExitAutoMode;
        _AvailableVars = availableVars;
        _Declared      = logic.DeclaredVariables.ToList();
        _Rows = logic.Choices.Select(c => new Row
        {
            Id        = c.Id,
            Name      = c.Name,
            Condition = c.Condition?.Clone() ?? new StoryConditionExpr { Kind = StoryConditionExprKind.Group },
            Values    = _Declared.ToDictionary(d => d.Id, d =>
            {
                string? existing = c.VariableValues.Find(v => v.DeclaredVarId == d.Id)?.Value;
                return string.IsNullOrEmpty(existing) ? DefaultValue(d) : existing;
            })
        }).ToList();
        if (_Rows.Count == 0) _Rows.Add(NewRow(Loc.T(Localization.Editor.Modals.Exit.defaultChoiceName)));
        _Visible = true;
        StateHasChanged();
    }

    private string DefaultValue(StoryDeclaredVariable d) => d.PossibleValues.FirstOrDefault() ?? "";

    private Row NewRow(string name) => new()
    {
        Name   = name,
        Values = _Declared.ToDictionary(d => d.Id, DefaultValue)
    };

    private void AddRow() => _Rows.Add(NewRow(""));

    private void RemoveRow(int index)
    {
        if (_Rows.Count > 1) _Rows.RemoveAt(index);
    }

    private async Task Confirm()
    {
        if (_Rows.Count == 0) return;
        _Visible = false;

        List<ChoiceSpec> specs = new();
        for (int i = 0; i < _Rows.Count; i++)
        {
            Row  r      = _Rows[i];
            bool isElse = _Auto && _AutoMode == StoryExitAutoMode.AutomaticChoice && i == _Rows.Count - 1;
            // Automatic Choice: a condition on every non-Else row. Choice Visibility: a condition on every row
            // (an empty one means "always visible"). Non-auto nodes carry no conditions.
            bool wantsCondition = _Auto && (_AutoMode == StoryExitAutoMode.ChoiceVisibility || !isElse);
            specs.Add(new ChoiceSpec(
                r.Id,
                r.Name.Trim(),
                isElse,
                wantsCondition ? r.Condition : null,
                _SinglePath
                    ? _Declared.Select(d => new StoryChoiceVarValue { DeclaredVarId = d.Id, Value = r.Value(d.Id).Trim() }).ToList()
                    : new List<StoryChoiceVarValue>()));
        }

        await OnConfirm.InvokeAsync(new ExitNodeArgs(_AutoMode, specs));
    }

    private void Cancel() => _Visible = false;

    public record ChoiceSpec(Guid Id, string Name, bool IsElse, StoryConditionExpr? Condition, List<StoryChoiceVarValue> Values);

    public record ExitNodeArgs(StoryExitAutoMode AutoMode, List<ChoiceSpec> Choices);
}

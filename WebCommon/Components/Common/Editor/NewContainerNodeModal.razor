@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box ncm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.Container.editTitle) : Loc.T(Localization.Editor.Modals.Container.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body ncm-body">

            @* ── Name ──────────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Common.Fields.name)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@Loc.T(Localization.Editor.Modals.Container.namePlaceholder)"
                       @bind="_Name"
                       @bind:event="oninput"
                       maxlength="100"/>
            </div>

            @* ── Description ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Common.Fields.description)
                    <span class="modal-label-hint">@Loc.T(Localization.Common.Fields.optional)</span>
                </label>
                <textarea class="modal-input ncm-textarea"
                          placeholder="@Loc.T(Localization.Editor.Modals.Container.descriptionPlaceholder)"
                          @bind="_Description"
                          @bind:event="oninput"
                          rows="2"
                          maxlength="500"></textarea>
            </div>

            @* ── Entry point ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Editor.Modals.Container.entryPointLabel)
                    <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.Container.entryPointHint)</span>
                </label>
                <div class="ncm-point">
                    <span class="ncm-point-dot" style="background:var(--success)"></span>
                    <input class="modal-input"
                           type="text"
                           placeholder="@Loc.T(Localization.Editor.Modals.Container.entryNamePlaceholder)"
                           value="@_Entry.Name"
                           @oninput="e => _Entry.Name = e.Value?.ToString() ?? string.Empty"
                           maxlength="60"/>
                    <select class="modal-input ncm-flow"
                            title="@Loc.T(Localization.Editor.Modals.Container.flowType)"
                            value="@_Entry.Flow"
                            @onchange="e => _Entry.Flow = ParseFlow(e.Value)">
                        <option value="@StoryPointFlow.Flow">@Loc.T(Localization.Editor.Modals.Container.flowFlow)</option>
                        <option value="@StoryPointFlow.VFlow">@Loc.T(Localization.Editor.Modals.Container.flowVFlow)</option>
                    </select>
                </div>
            </div>

            @* ── Exit points ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Editor.Modals.Container.exitPointsLabel)
                    <span class="modal-label-hint">@Loc.T(Localization.Editor.Modals.Container.exitPointsHint)</span>
                </label>
                @for (int i = 0; i < _Exits.Count; i++)
                {
                    int index = i;
                    <div class="ncm-point">
                        <span class="ncm-point-dot" style="background:var(--danger)"></span>
                        <input class="modal-input"
                               type="text"
                               placeholder="@Loc.T(Localization.Editor.Modals.Container.exitNamePlaceholder)"
                               value="@_Exits[index].Name"
                               @oninput="e => _Exits[index].Name = e.Value?.ToString() ?? string.Empty"
                               maxlength="60"/>
                        <select class="modal-input ncm-flow"
                                title="@Loc.T(Localization.Editor.Modals.Container.flowType)"
                                value="@_Exits[index].Flow"
                                @onchange="e => _Exits[index].Flow = ParseFlow(e.Value)">
                            <option value="@StoryPointFlow.Flow">@Loc.T(Localization.Editor.Modals.Container.flowFlow)</option>
                            <option value="@StoryPointFlow.VFlow">@Loc.T(Localization.Editor.Modals.Container.flowVFlow)</option>
                        </select>
                        <button class="ncm-point-del"
                                title="@Loc.T(Localization.Editor.Modals.Container.removeExit)"
                                disabled="@(_Exits.Count <= 1)"
                                @onclick="() => RemoveExit(index)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }
                <button class="ncm-add" @onclick="AddExit">
                    <i class="bi bi-plus-lg"></i> @Loc.T(Localization.Editor.Modals.Container.addExit)
                </button>
            </div>

            @* ── Variables used in this container (chapter-lifespan Internal, reserving their slot here) ── *@
            @{
                List<StoryVariable> chapterVars = ChapterVariables();
            }
            @if (chapterVars.Count > 0)
            {
                <div class="modal-field">
                    <label class="modal-label">
                        Variables used in this container
                        <span class="modal-label-hint">reserves each variable's board slot while flow is inside</span>
                    </label>
                    @foreach (StoryVariable v in chapterVars)
                    {
                        StoryVariable variable = v;
                        bool locked   = IsSlotLocked(variable) && !_UsedVariables.Contains(variable.Id);
                        bool conflict = ConflictsWithSelected(variable);
                        <label class="ncm-var @(locked || conflict ? "ncm-var-locked" : "")">
                            <input type="checkbox"
                                   checked="@_UsedVariables.Contains(variable.Id)"
                                   disabled="@(locked || conflict)"
                                   @onchange="e => ToggleVariable(variable.Id, e)"/>
                            <span class="ncm-var-name">@(string.IsNullOrWhiteSpace(variable.Name) ? Loc.T(Localization.Common.Placeholders.unnamed) : variable.Name)</span>
                            <span class="ncm-var-slot">@StoryVariableSlots.Label(variable.InternalSubtype, variable.SlotIndex)</span>
                            @if (locked || conflict)
                            {
                                <i class="bi bi-lock-fill" title="slot already reserved on this path"></i>
                            }
                        </label>
                    }
                </div>
            }

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : Loc.T(Localization.Editor.Modals.Container.createButton))
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<NewContainerNodeArgs> OnConfirm { get; set; }

    private bool           _Visible;
    private bool           _IsEdit;
    private Guid           _EditId;
    private Guid           _ParentId;      // the container this node lives in (for ancestor slot reservations)
    private PointRow       _Entry       = new() { Name = "In" };   // the single entry, preserved across edits so its wire survives
    private string         _Name        = "";
    private string         _Description = "";
    private List<PointRow> _Exits       = new() { new PointRow { Name = "Out" } };
    private List<Guid>     _UsedVariables = new();

    /// <summary>Opens the modal to create a brand-new container node in <paramref name="parentContainerId"/>.</summary>
    public void Show(Guid parentContainerId = default)
    {
        _IsEdit        = false;
        _EditId        = Guid.Empty;
        _ParentId      = parentContainerId;
        _Entry         = new PointRow { Name = "In" };
        _Name          = "";
        _Description   = "";
        _Exits         = new List<PointRow> { new PointRow { Name = "Out" } };
        _UsedVariables = new List<Guid>();
        _Visible       = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing container, preserving the entry/exit-point ids so wires survive.</summary>
    public void ShowEdit(
        Guid                                             id,
        string                                           name,
        string                                           description,
        IEnumerable<(Guid Id, string Name, StoryPointFlow Flow)> entries,
        IEnumerable<(Guid Id, string Name, StoryPointFlow Flow)> exits,
        Guid                                             parentContainerId = default,
        IEnumerable<Guid>?                               usedVariables = null)
    {
        _IsEdit      = true;
        _EditId      = id;
        _ParentId    = parentContainerId;
        (Guid Id, string Name, StoryPointFlow Flow) entry = entries.FirstOrDefault();
        _Entry       = new PointRow { Id = entry.Id, Name = string.IsNullOrEmpty(entry.Name) ? "In" : entry.Name, Flow = entry.Flow };
        _Name        = name;
        _Description = description;
        _Exits       = exits.Select(e => new PointRow { Id = e.Id, Name = e.Name, Flow = e.Flow }).ToList();
        if (_Exits.Count == 0) _Exits.Add(new PointRow { Name = "Out" });
        _UsedVariables = usedVariables?.ToList() ?? new List<Guid>();
        _Visible = true;
        StateHasChanged();
    }

    /// <summary>The chapter-lifespan Internal variables that can be reserved by a container.</summary>
    private List<StoryVariable> ChapterVariables() =>
        _ProjectState.CurrentProject is null
            ? new List<StoryVariable>()
            : _ProjectState.CurrentProject.Variables.Values
                .Where(v => v.Scope == StoryVariableScope.Internal && v.Lifespan == StoryVariableLifespan.Chapter)
                .OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();

    /// <summary>Slots reserved by scenario-lifespan Internal variables (global) and by every ancestor container.</summary>
    private HashSet<(StorageVariableType, int)> ReservedSlots()
    {
        HashSet<(StorageVariableType, int)> slots = new();
        StoryProject? project = _ProjectState.CurrentProject;
        if (project is null) return slots;

        foreach (StoryVariable v in project.Variables.Values)
            if (v.Scope == StoryVariableScope.Internal && v.Lifespan == StoryVariableLifespan.Scenario)
                slots.Add((StoryVariableSlots.Bank(v.InternalSubtype), v.SlotIndex));

        Guid parentId = _ParentId;
        int  guard    = 0;
        while (parentId != Guid.Empty && guard++ < 256 && project.ContainerNodes.TryGetValue(parentId, out StoryContainerNode? parent))
        {
            foreach (Guid id in parent.UsedVariables)
                if (project.Variables.TryGetValue(id, out StoryVariable? v) && v.Scope == StoryVariableScope.Internal)
                    slots.Add((StoryVariableSlots.Bank(v.InternalSubtype), v.SlotIndex));
            parentId = parent.ParentContainer;
        }
        return slots;
    }

    private (StorageVariableType, int) SlotOf(StoryVariable v) => (StoryVariableSlots.Bank(v.InternalSubtype), v.SlotIndex);

    private bool IsSlotLocked(StoryVariable v) => ReservedSlots().Contains(SlotOf(v));

    private bool ConflictsWithSelected(StoryVariable v)
    {
        if (_UsedVariables.Contains(v.Id) || _ProjectState.CurrentProject is null) return false;
        (StorageVariableType, int) slot = SlotOf(v);
        foreach (Guid id in _UsedVariables)
            if (_ProjectState.CurrentProject.Variables.TryGetValue(id, out StoryVariable? other)
                && other.Scope == StoryVariableScope.Internal && SlotOf(other).Equals(slot))
                return true;
        return false;
    }

    private void ToggleVariable(Guid id, ChangeEventArgs e)
    {
        bool on = e.Value is bool b && b;
        if (on) { if (!_UsedVariables.Contains(id)) _UsedVariables.Add(id); }
        else _UsedVariables.Remove(id);
    }

    private bool _CanConfirm =>
        !string.IsNullOrWhiteSpace(_Name) &&
        _Exits.Any(n => !string.IsNullOrWhiteSpace(n.Name));

    private void AddExit() => _Exits.Add(new PointRow { Name = "" });

    private void RemoveExit(int index)
    {
        if (_Exits.Count <= 1) return;
        _Exits.RemoveAt(index);
    }

    private static StoryPointFlow ParseFlow(object? value) =>
        Enum.TryParse(value?.ToString(), out StoryPointFlow flow) ? flow : StoryPointFlow.Flow;

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;

        string entryName = string.IsNullOrWhiteSpace(_Entry.Name) ? "In" : _Entry.Name.Trim();

        await OnConfirm.InvokeAsync(new NewContainerNodeArgs(
            _EditId,
            _Name.Trim(),
            _Description.Trim(),
            new List<(Guid Id, string Name, StoryPointFlow Flow)> { (_Entry.Id, entryName, _Entry.Flow) },
            Clean(_Exits),
            new List<Guid>(_UsedVariables)));
    }

    private static List<(Guid Id, string Name, StoryPointFlow Flow)> Clean(IEnumerable<PointRow> rows) =>
        rows.Where(r => !string.IsNullOrWhiteSpace(r.Name))
            .Select(r => (r.Id, r.Name.Trim(), r.Flow))
            .ToList();

    private void Cancel() => _Visible = false;

    private sealed class PointRow
    {
        public Guid           Id   { get; set; }
        public string         Name { get; set; } = "";
        public StoryPointFlow Flow { get; set; } = StoryPointFlow.Flow;
    }

    /// <summary>Result passed back to the parent. <see cref="EditId"/> is empty for a create, set for an edit.</summary>
    public record NewContainerNodeArgs(
        Guid                                      EditId,
        string                                    Name,
        string                                    Description,
        List<(Guid Id, string Name, StoryPointFlow Flow)> Entries,
        List<(Guid Id, string Name, StoryPointFlow Flow)> Exits,
        List<Guid>                                UsedVariables);
}

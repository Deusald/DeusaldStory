@namespace DeusaldStoryWeb.Components.Common

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box ncm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? "Edit container node" : "New container node")</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body ncm-body">

            @* ── Name ──────────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">Name</label>
                <input class="modal-input"
                       type="text"
                       placeholder="Chapter 1"
                       @bind="_Name"
                       @bind:event="oninput"
                       maxlength="100"/>
            </div>

            @* ── Description ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    Description
                    <span class="modal-label-hint">optional</span>
                </label>
                <textarea class="modal-input ncm-textarea"
                          placeholder="A short description of this part of the story…"
                          @bind="_Description"
                          @bind:event="oninput"
                          rows="2"
                          maxlength="500"></textarea>
            </div>

            @* ── Exit points ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    Exit points
                    <span class="modal-label-hint">at least one — ways the story can leave this container</span>
                </label>
                @for (int i = 0; i < _Exits.Count; i++)
                {
                    int index = i;
                    <div class="ncm-point">
                        <span class="ncm-point-dot" style="background:var(--danger)"></span>
                        <input class="modal-input"
                               type="text"
                               placeholder="Out"
                               value="@_Exits[index].Name"
                               @oninput="e => _Exits[index].Name = e.Value?.ToString() ?? string.Empty"
                               maxlength="60"/>
                        <button class="ncm-point-del"
                                title="Remove exit"
                                disabled="@(_Exits.Count <= 1)"
                                @onclick="() => RemoveExit(index)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }
                <button class="ncm-add" @onclick="AddExit">
                    <i class="bi bi-plus-lg"></i> Add exit
                </button>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @(_IsEdit ? "Save changes" : "Create container")
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<NewContainerNodeArgs> OnConfirm { get; set; }

    private bool           _Visible;
    private bool           _IsEdit;
    private Guid           _EditId;
    private Guid           _EntryId;   // the single entry's id, preserved across edits so its wire survives
    private string         _Name        = "";
    private string         _Description = "";
    private List<PointRow> _Exits       = new() { new PointRow { Name = "Out" } };

    /// <summary>Opens the modal to create a brand-new container node.</summary>
    public void Show()
    {
        _IsEdit      = false;
        _EditId      = Guid.Empty;
        _EntryId     = Guid.Empty;
        _Name        = "";
        _Description = "";
        _Exits       = new List<PointRow> { new PointRow { Name = "Out" } };
        _Visible     = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing container, preserving the entry/exit-point ids so wires survive.</summary>
    public void ShowEdit(
        Guid                                id,
        string                              name,
        string                              description,
        IEnumerable<(Guid Id, string Name)> entries,
        IEnumerable<(Guid Id, string Name)> exits)
    {
        _IsEdit      = true;
        _EditId      = id;
        _EntryId     = entries.Select(e => e.Id).FirstOrDefault();
        _Name        = name;
        _Description = description;
        _Exits       = exits.Select(e => new PointRow { Id = e.Id, Name = e.Name }).ToList();
        if (_Exits.Count == 0) _Exits.Add(new PointRow { Name = "Out" });
        _Visible = true;
        StateHasChanged();
    }

    private bool _CanConfirm =>
        !string.IsNullOrWhiteSpace(_Name) &&
        _Exits.Any(n => !string.IsNullOrWhiteSpace(n.Name));

    private void AddExit() => _Exits.Add(new PointRow { Name = "" });

    private void RemoveExit(int index)
    {
        if (_Exits.Count <= 1) return;
        _Exits.RemoveAt(index);
    }

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;

        await OnConfirm.InvokeAsync(new NewContainerNodeArgs(
            _EditId,
            _Name.Trim(),
            _Description.Trim(),
            new List<(Guid Id, string Name)> { (_EntryId, "In") },
            Clean(_Exits)));
    }

    private static List<(Guid Id, string Name)> Clean(IEnumerable<PointRow> rows) =>
        rows.Where(r => !string.IsNullOrWhiteSpace(r.Name))
            .Select(r => (r.Id, r.Name.Trim()))
            .ToList();

    private void Cancel() => _Visible = false;

    private sealed class PointRow
    {
        public Guid   Id   { get; set; }
        public string Name { get; set; } = "";
    }

    /// <summary>Result passed back to the parent. <see cref="EditId"/> is empty for a create, set for an edit.</summary>
    public record NewContainerNodeArgs(
        Guid                         EditId,
        string                       Name,
        string                       Description,
        List<(Guid Id, string Name)> Entries,
        List<(Guid Id, string Name)> Exits);
}

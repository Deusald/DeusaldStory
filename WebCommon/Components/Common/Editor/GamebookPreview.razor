@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@implements IAsyncDisposable
@inject ProjectStateService _ProjectState
@inject IJSRuntime _JS

@* ─────────────────────────────────────────────────────────────────────────
   The Gamebook preview: renders a logic node as it would appear printed — one
   paper "section" per combination of the node's External Variable values (built
   by StoryGamebookPreview), each ending in the example continue-instructions
   that look at the next node's own combinations. Global section numbers don't
   exist yet, so section references are placeholder tokens ([§ …]).
   ───────────────────────────────────────────────────────────────────────── *@

<div class="gbp-root">

    @{
        StoryGamebookPreview.Result result = _Result;
    }

    <div class="gbp-summary">
        <i class="bi bi-journal-text"></i>
        <span>
            @Loc.T(Localization.Editor.Preview.Gamebook.sectionCount, new Dictionary<string, object> { ["count"] = result.Sections.Count })
            @if (result.Truncated)
            {
                <span class="gbp-warn">@Loc.T(Localization.Editor.Preview.Gamebook.truncatedCombinations, new Dictionary<string, object> { ["shown"] = result.Sections.Count, ["total"] = result.TotalCombinations })</span>
            }
        </span>
    </div>

    @for (int i = 0; i < result.Sections.Count; i++)
    {
        StoryGamebookPreview.Section sec = result.Sections[i];
        bool selected = IsSelected(sec);
        <div class="gbp-section @(selected ? "selected" : "")" id="@($"gbp-sec-{i}")">

            <div class="gbp-section-head">
                <span class="gbp-section-tag">@Loc.T(Localization.Editor.Preview.Gamebook.sectionTag, new Dictionary<string, object> { ["n"] = i + 1 })</span>
                @if (!string.IsNullOrEmpty(sec.Label))
                {
                    <span class="gbp-section-combo">@sec.Label</span>
                }
                @if (selected)
                {
                    <span class="gbp-section-badge gbp-section-selected"><i class="bi bi-eye-fill"></i> @Loc.T(Localization.Editor.Preview.Gamebook.selectedBadge)</span>
                }
                @if (sec.IsInstructions)
                {
                    <span class="gbp-section-badge"><i class="bi bi-gear-fill"></i> @Loc.T(Localization.Editor.Preview.Gamebook.instructionsBadge)</span>
                }
            </div>

            <div class="gbp-head">
                @if (sec.Rendered.IconData is not null)
                {
                    <div class="gbp-icon">
                        <img src="data:image/png;base64,@sec.Rendered.IconData" alt="@Loc.T(Localization.Editor.Preview.iconAlt)"/>
                    </div>
                }
                <div class="gbp-titles">
                    @if (string.IsNullOrEmpty(sec.Rendered.Title))
                    {
                        <div class="gbp-title gbp-placeholder">@Loc.T(Localization.Editor.Preview.noTitleConnected)</div>
                    }
                    else
                    {
                        <div class="gbp-title">@SafeHtml(sec.Rendered.Title)</div>
                    }
                    @if (!string.IsNullOrEmpty(sec.Rendered.Subtitle))
                    {
                        <div class="gbp-subtitle">@SafeHtml(sec.Rendered.Subtitle)</div>
                    }
                </div>
            </div>

            @{
                List<StorageInstruction> aboveStorage = sec.Rendered.Instructions.Where(i => i.Placement == StorageInstructionPlacement.Above).ToList();
                List<StorageInstruction> belowStorage = sec.Rendered.Instructions.Where(i => i.Placement == StorageInstructionPlacement.Below).ToList();
            }
            @if (aboveStorage.Count > 0)
            {
                <div class="gbp-storage">
                    @foreach (StorageInstruction ins in aboveStorage)
                    {
                        <div class="gbp-storage-line"><i class="bi bi-box-seam"></i> <span>@SafeHtml(ins.Text)</span></div>
                    }
                </div>
            }

            @if (sec.IsInstructions)
            {
                <div class="gbp-instructions">
                    @if (sec.InstructionLines.Count == 0)
                    {
                        <div class="gbp-block gbp-placeholder">@Loc.T(Localization.Editor.Preview.Gamebook.noOperations)</div>
                    }
                    else
                    {
                        @foreach (string line in sec.InstructionLines)
                        {
                            <div class="gbp-block">@SafeHtml(line)</div>
                        }
                    }
                </div>
            }
            else
            {
                @foreach (StoryLogicRenderer.RenderedBlock block in sec.Rendered.Blocks)
                {
                    StoryTextFrameStyle style = block.FrameStyle;
                    <div class="gbp-block @FrameClass(style)">
                        @if (StoryStyle.FrameIcon(style) is { Length: > 0 } frameIcon)
                        {
                            <i class="gbp-block-icon bi @frameIcon" title="@StoryStyle.FrameLabel(style)"></i>
                        }
                        <span class="gbp-block-text">@SafeHtml(block.Text)</span>
                    </div>
                }
            }

            @if (belowStorage.Count > 0)
            {
                <div class="gbp-storage">
                    @foreach (StorageInstruction ins in belowStorage)
                    {
                        <div class="gbp-storage-line"><i class="bi bi-box-seam"></i> <span>@SafeHtml(ins.Text)</span></div>
                    }
                </div>
            }

            <div class="gbp-continue">
                @foreach (StoryGamebookPreview.ContinueLine line in result.Continue)
                {
                    @if (line.TargetLogicId != Guid.Empty)
                    {
                        <button type="button" class="gbp-continue-line gbp-continue-link" @onclick="() => Navigate(line)">
                            <i class="bi bi-arrow-return-right"></i>
                            <span>@SafeHtml(line.Text)</span>
                        </button>
                    }
                    else
                    {
                        <div class="gbp-continue-line @(line.IsError ? "error" : "")">
                            <i class="bi @(line.IsError ? "bi-exclamation-triangle-fill" : "bi-arrow-return-right")"></i>
                            <span>@SafeHtml(line.Text)</span>
                        </div>
                    }
                }
            </div>

        </div>
    }

</div>

@code {
    [Parameter] public StoryLogicNode Logic { get; set; } = default!;

    /// <summary>The project <see cref="Logic"/> belongs to — the preview session's own (see <see cref="LogicPreview.Project"/>).</summary>
    [Parameter] public StoryProject Project { get; set; } = default!;

    /// <summary>Raised when the user clicks a navigable "go to section" line — the host switches the preview and scrolls.</summary>
    [Parameter] public EventCallback<GamebookNavRequest> OnNavigate { get; set; }

    /// <summary>The <see cref="StoryGamebookPreview.Section.Key"/> to scroll to the top of the view after render.</summary>
    [Parameter] public string? ScrollToKey { get; set; }

    private StoryGamebookPreview.Result _Result = new();
    private string?                     _ScrolledKey;
    private IJSObjectReference?         _Module;

    protected override void OnParametersSet() => _Result = Build();

    private Task Navigate(StoryGamebookPreview.ContinueLine line) =>
        OnNavigate.InvokeAsync(new GamebookNavRequest(line.TargetLogicId, line.TargetSectionKey));

    /// <summary>The section the last "go to section" click jumped to — flagged transiently, never persisted.</summary>
    private bool IsSelected(StoryGamebookPreview.Section sec) =>
        !string.IsNullOrEmpty(ScrollToKey) && sec.Key == ScrollToKey;

    /// <summary>
    /// Honour a new scroll request exactly once (tracked by <see cref="_ScrolledKey"/> so plain re-renders don't
    /// re-scroll and fight the user's own scrolling). The host leaves <see cref="ScrollToKey"/> set — it need not be
    /// cleared, which is what previously interrupted the smooth scroll mid-animation.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrEmpty(ScrollToKey) || ScrollToKey == _ScrolledKey) return;
        _ScrolledKey = ScrollToKey;

        int index = _Result.Sections.FindIndex(s => s.Key == ScrollToKey);
        if (index < 0) return;

        IJSObjectReference module = await ModuleAsync();
        await module.InvokeVoidAsync("scrollToTopById", $"gbp-sec-{index}");
    }

    private async Task<IJSObjectReference> ModuleAsync() =>
        _Module ??= await _JS.InvokeAsync<IJSObjectReference>("import", "./js/editor-graph.js");

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_Module is not null) await _Module.DisposeAsync();
        }
        catch (JSDisconnectedException) { /* circuit already gone — nothing to unwind */ }
    }

    private StoryGamebookPreview.Result Build()
    {
        // Both node and project come from the parent, already in one space — the session decided which.
        return StoryGamebookPreview.Build(Project, _ProjectState.CurrentLocalization, Logic);
    }

    private MarkupString SafeHtml(string text) => (MarkupString)PreviewHtmlSanitizer.ToSafeHtml(text, ResolveImageTag, ResolveVariableTag);

    /// <summary>The frame-style modifier class for a block (e.g. <c>gbp-block-success</c>); empty for the plain Normal frame.</summary>
    private static string FrameClass(StoryTextFrameStyle style)
    {
        string suffix = StoryStyle.FrameSuffix(style);
        return suffix.Length == 0 ? "" : $"gbp-block-{suffix}";
    }

    private StoryImage? ResolveImageTag(string tag, string name)
    {
        foreach (StoryImage image in _ProjectState.CurrentProject!.Images.Values)
        {
            if (!string.Equals(image.Name, name, StringComparison.OrdinalIgnoreCase)) continue;
            if (tag == "icon" && image.Kind != StoryImageKind.Icon)                   continue;
            return image;
        }
        return null;
    }

    private StoryRegisterVariableNode? ResolveVariableTag(string name)
    {
        // The session's project, so a variable registered inside a blueprint resolves to the slot *this* instance got.
        foreach (StoryLogicNode logic in Project.LogicNodes.Values)
            if (logic.RegisterVariableNodes.Find(n => string.Equals(n.Name, name, StringComparison.OrdinalIgnoreCase)) is StoryRegisterVariableNode reg)
                return reg;
        return null;
    }
}

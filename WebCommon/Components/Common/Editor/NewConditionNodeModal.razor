@namespace DeusaldStoryWeb.Components.Common

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Condition node: picks the comparison operator and the value
   the wired variable is tested against. The variable itself is supplied on the
   canvas by wiring an External Variable (or the Prev-Exit Selection) into the
   node's Variable input; flow then leaves through the True or False output.
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box cnm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? "Edit condition" : "Condition")</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            <div class="modal-field">
                <label class="modal-label">Comparison</label>
                <select class="modal-input" @bind="_Operator">
                    <option value="@StoryConditionOperator.Equal">Equal (=)</option>
                    <option value="@StoryConditionOperator.NotEqual">Not equal (≠)</option>
                    <option value="@StoryConditionOperator.LessThan">Less than (&lt;)</option>
                    <option value="@StoryConditionOperator.GreaterThan">Greater than (&gt;)</option>
                    <option value="@StoryConditionOperator.LessOrEqual">Less or equal (≤)</option>
                    <option value="@StoryConditionOperator.GreaterOrEqual">Greater or equal (≥)</option>
                </select>
                @if (_Operator is not StoryConditionOperator.Equal and not StoryConditionOperator.NotEqual)
                {
                    <span class="modal-label-hint">both the variable value and this value are parsed to whole numbers</span>
                }
            </div>

            <div class="modal-field">
                <label class="modal-label">Compared value</label>
                <input class="modal-input"
                       type="text"
                       placeholder="value to test against"
                       @bind="_CompareValue"
                       @bind:event="oninput"
                       maxlength="100"/>
            </div>

            <div class="modal-note">
                <i class="bi bi-info-circle"></i>
                <span>Wire the variable to test into the node's <b>Variable</b> input; flow leaves through <b>True</b> or <b>False</b>.</span>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm">
                @(_IsEdit ? "Save changes" : "Add condition node")
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<ConditionArgs> OnConfirm { get; set; }

    private bool                   _Visible;
    private bool                   _IsEdit;
    private Guid                   _EditNodeId;
    private StoryConditionOperator _Operator;
    private string                 _CompareValue = "";

    /// <summary>Opens the modal to create a new Condition node.</summary>
    public void Show()
    {
        _IsEdit       = false;
        _EditNodeId   = Guid.Empty;
        _Operator     = StoryConditionOperator.Equal;
        _CompareValue = "";
        _Visible      = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Condition node.</summary>
    public void ShowEdit(StoryConditionNode node)
    {
        _IsEdit       = true;
        _EditNodeId   = node.Id;
        _Operator     = node.Operator;
        _CompareValue = node.CompareValue;
        _Visible      = true;
        StateHasChanged();
    }

    private async Task Confirm()
    {
        _Visible = false;
        await OnConfirm.InvokeAsync(new ConditionArgs(_EditNodeId, _Operator, _CompareValue.Trim()));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record ConditionArgs(Guid EditNodeId, StoryConditionOperator Operator, string CompareValue);
}

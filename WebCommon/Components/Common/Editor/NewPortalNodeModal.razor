@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box npm-portal-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.Portal.editTitle) : Loc.T(Localization.Editor.Modals.Portal.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">

            @if (!_IsEdit)
            {
                <div class="npm-portal-hint">
                    <i class="bi bi-box-arrow-in-right" style="color:var(--orange)"></i>
                    @((MarkupString)Loc.T(Localization.Editor.Modals.Portal.createHint))
                </div>
            }

            @* ── Name ──────────────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">@Loc.T(Localization.Common.Fields.name)</label>
                <input class="modal-input"
                       type="text"
                       placeholder="@Loc.T(Localization.Editor.Modals.Portal.namePlaceholder)"
                       @bind="_Name"
                       @bind:event="oninput"
                       maxlength="100"/>
            </div>

            @* ── Description ───────────────────────────────────────────── *@
            <div class="modal-field">
                <label class="modal-label">
                    @Loc.T(Localization.Common.Fields.description)
                    <span class="modal-label-hint">@Loc.T(Localization.Common.Fields.optional)</span>
                </label>
                <textarea class="modal-input npm-portal-textarea"
                          placeholder="@Loc.T(Localization.Editor.Modals.Portal.descriptionPlaceholder)"
                          @bind="_Description"
                          @bind:event="oninput"
                          rows="2"
                          maxlength="500"></textarea>
            </div>

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary"
                    @onclick="Confirm"
                    disabled="@(!_CanConfirm)">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : Loc.T(Localization.Editor.Modals.Portal.createButton))
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<NewPortalNodeArgs> OnConfirm { get; set; }

    private bool   _Visible;
    private bool   _IsEdit;
    private Guid   _EditId;
    private string _Name        = "";
    private string _Description = "";

    /// <summary>Opens the modal to create a brand-new portal pair.</summary>
    public void Show()
    {
        _IsEdit      = false;
        _EditId      = Guid.Empty;
        _Name        = "";
        _Description = "";
        _Visible     = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to rename / re-describe an existing portal pair.</summary>
    public void ShowEdit(Guid id, string name, string description)
    {
        _IsEdit      = true;
        _EditId      = id;
        _Name        = name;
        _Description = description;
        _Visible     = true;
        StateHasChanged();
    }

    private bool _CanConfirm => !string.IsNullOrWhiteSpace(_Name);

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;
        await OnConfirm.InvokeAsync(new NewPortalNodeArgs(_EditId, _Name.Trim(), _Description.Trim()));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditId"/> is empty for a create, set for an edit.</summary>
    public record NewPortalNodeArgs(Guid EditId, string Name, string Description);
}

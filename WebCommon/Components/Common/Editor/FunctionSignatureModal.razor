@namespace DeusaldStoryWeb.Components.Common
@using DeusaldStoryCommon

@* ─────────────────────────────────────────────────────────────────────────
   Edits a Function blueprint's signature: the typed inputs (fed into the
   function) and typed outputs (produced by it). Point ids are preserved across
   edits so existing instance wires survive; changing a port's type drops its
   now-incompatible wires (handled by the state service on confirm).
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box fsm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">Function signature — @_Name</span>
            <button class="modal-close" @onclick="Cancel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body fsm-body">

            @Section("Inputs", _Inputs)
            @Section("Outputs", _Outputs)

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">Cancel</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm">Save signature</button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<SignatureArgs> OnConfirm { get; set; }

    private bool          _Visible;
    private Guid          _BlueprintId;
    private string        _Name = "";
    private List<PortRow> _Inputs  = new();
    private List<PortRow> _Outputs = new();

    private static readonly PortType[] _Types = (PortType[])Enum.GetValues(typeof(PortType));

    /// <summary>Opens the signature editor for a Function blueprint, pre-filled with its current ports.</summary>
    public void Show(Guid blueprintId, string name,
        IEnumerable<(Guid Id, string Name, PortType Type)> inputs,
        IEnumerable<(Guid Id, string Name, PortType Type)> outputs)
    {
        _BlueprintId = blueprintId;
        _Name        = name;
        _Inputs      = inputs.Select(p => new PortRow { Id = p.Id, Name = p.Name, Type = p.Type }).ToList();
        _Outputs     = outputs.Select(p => new PortRow { Id = p.Id, Name = p.Name, Type = p.Type }).ToList();
        _Visible     = true;
        StateHasChanged();
    }

    private RenderFragment Section(string title, List<PortRow> rows) =>@<div class="modal-field">
        <label class="modal-label">@title</label>
        @for (int i = 0; i < rows.Count; i++)
        {
            int index = i;
            <div class="fsm-row">
                <input class="modal-input"
                       type="text"
                       placeholder="name"
                       value="@rows[index].Name"
                       @oninput="e => rows[index].Name = e.Value?.ToString() ?? string.Empty"
                       maxlength="60"/>
                <select class="modal-input fsm-type"
                        value="@rows[index].Type"
                        @onchange="e => rows[index].Type = ParseType(e.Value)">
                    @foreach (PortType t in _Types)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
                <button class="fsm-del" title="Remove" @onclick="() => rows.RemoveAt(index)">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        }
        <button class="fsm-add" @onclick="() => rows.Add(new PortRow())">
            <i class="bi bi-plus-lg"></i> Add @title.TrimEnd('s').ToLowerInvariant()
        </button>
    </div>;

    private static PortType ParseType(object? value) =>
        Enum.TryParse(value?.ToString(), out PortType t) ? t : PortType.Data;

    private async Task Confirm()
    {
        _Visible = false;
        await OnConfirm.InvokeAsync(new SignatureArgs(
            _BlueprintId,
            Clean(_Inputs),
            Clean(_Outputs)));
    }

    private static List<(Guid Id, string Name, PortType Type)> Clean(IEnumerable<PortRow> rows) =>
        rows.Where(r => !string.IsNullOrWhiteSpace(r.Name))
            .Select(r => (r.Id, r.Name.Trim(), r.Type))
            .ToList();

    private void Cancel() => _Visible = false;

    private sealed class PortRow
    {
        public Guid     Id   { get; set; }
        public string   Name { get; set; } = "";
        public PortType Type { get; set; } = PortType.Data;
    }

    /// <summary>Result: the blueprint whose signature changed plus its new input/output ports (empty id = new port).</summary>
    public record SignatureArgs(
        Guid                                              BlueprintId,
        List<(Guid Id, string Name, PortType Type)>       Inputs,
        List<(Guid Id, string Name, PortType Type)>       Outputs);
}

@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState

@* ─────────────────────────────────────────────────────────────────────────
   Creates / edits a Set Variable node: picks a global variable and how its value
   is assigned. External variables use a mode (a fixed value, the wired value, or a
   remapped wired value) and emit no printed instruction. Internal Number/Dial/Text
   variables use the assignment / string-input fields and surface a Gamebook line
   (or an App input field for player-input Strings).
   ───────────────────────────────────────────────────────────────────────── *@

@if (_Visible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>

    <div class="modal-box svm-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@(_IsEdit ? Loc.T(Localization.Editor.Modals.SetVariable.editTitle) : Loc.T(Localization.Editor.Modals.SetVariable.title))</span>
            <button class="modal-close" @onclick="Cancel" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body svm-body">

            @* ── Which variable ── *@
            <div class="modal-field">
                <label class="modal-label">Variable</label>
                <input class="modal-input" type="text" placeholder="Search"
                       @bind="_Search" @bind:event="oninput"/>
                @{
                    List<StoryVariable> vars = FilteredVariables();
                }
                @if (vars.Count == 0)
                {
                    <div class="svm-empty"><i class="bi bi-braces"></i><span>@Loc.T(Localization.Common.Messages.noVariablesRegistered)</span></div>
                }
                else
                {
                    <div class="svm-list">
                        @foreach (StoryVariable v in vars)
                        {
                            StoryVariable variable = v;
                            <button class="svm-item @(_SelectedVariableId == variable.Id ? "selected" : "")"
                                    @onclick="() => Select(variable)">
                                <span>@(string.IsNullOrWhiteSpace(variable.Name) ? Loc.T(Localization.Common.Placeholders.unnamed) : variable.Name)</span>
                            </button>
                        }
                    </div>
                }
            </div>

            @if (_Selected is StoryVariable sel)
            {
                @if (sel.Scope == StoryVariableScope.External)
                {
                    <div class="modal-field">
                        <label class="modal-label">@Loc.T(Localization.Common.Fields.value)</label>
                        <select class="modal-input" @bind="_ExternalMode">
                            <option value="@StorySetExternalVariableMode.SpecificValue">Specific value</option>
                            <option value="@StorySetExternalVariableMode.MapFromVariable">From wired value</option>
                            <option value="@StorySetExternalVariableMode.RemapFromVariable">Remap wired value</option>
                        </select>
                    </div>

                    @if (_ExternalMode == StorySetExternalVariableMode.SpecificValue)
                    {
                        <div class="modal-field">
                            <label class="modal-label">@Loc.T(Localization.Common.Fields.value)</label>
                            @{
                                List<string> options = StoryVariableValues.PossibleValues(sel);
                            }
                            @if (options.Count > 0)
                            {
                                <select class="modal-input" @bind="_ExternalValue">
                                    @foreach (string o in options)
                                    {
                                        <option value="@o">@o</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input class="modal-input" type="text" @bind="_ExternalValue" @bind:event="oninput" maxlength="200"/>
                            }
                        </div>
                    }
                    else if (_ExternalMode == StorySetExternalVariableMode.RemapFromVariable)
                    {
                        <div class="modal-field">
                            <label class="modal-label">Remap table</label>
                            @foreach (StorySetExternalVariableRemap row in _ValueMap)
                            {
                                StorySetExternalVariableRemap r = row;
                                <div class="svm-remap-row">
                                    <input class="modal-input" type="text" placeholder="from" @bind="r.From" @bind:event="oninput"/>
                                    <i class="bi bi-arrow-right"></i>
                                    <input class="modal-input" type="text" placeholder="to" @bind="r.To" @bind:event="oninput"/>
                                    <button class="modal-btn modal-btn-ghost" @onclick="() => _ValueMap.Remove(r)"><i class="bi bi-trash"></i></button>
                                </div>
                            }
                            <button class="modal-btn modal-btn-ghost" @onclick="() => _ValueMap.Add(new StorySetExternalVariableRemap())">
                                <i class="bi bi-plus-lg"></i> @Loc.T(Localization.Common.Buttons.add)
                            </button>
                        </div>
                    }
                }
                else if (sel.InternalSubtype == StoryInternalSubtype.Text)
                {
                    <div class="modal-field">
                        <label class="modal-label">@Loc.T(Localization.Common.Fields.value)</label>
                        <select class="modal-input" @bind="_StringMode">
                            <option value="@StringValueMode.Unset">Unset</option>
                            <option value="@StringValueMode.Specific">Specific value</option>
                            <option value="@StringValueMode.PlayerInput">Player input</option>
                        </select>
                    </div>
                    @if (_StringMode == StringValueMode.Specific)
                    {
                        <div class="modal-field">
                            <label class="modal-label">@Loc.T(Localization.Common.Fields.value)</label>
                            <input class="modal-input" type="text" @bind="_StringValue" @bind:event="oninput" maxlength="200"/>
                        </div>
                    }
                    else if (_StringMode == StringValueMode.PlayerInput)
                    {
                        <div class="modal-field">
                            <label class="modal-label">Input kind</label>
                            <select class="modal-input" @bind="_StringInputKind">
                                <option value="@StringInputKind.Text">@Loc.T(Localization.Common.Misc.stringWritten)</option>
                                <option value="@StringInputKind.Number">@Loc.T(Localization.Editor.Modals.RegisterVariable.storageTypeNumber)</option>
                            </select>
                        </div>
                        <div class="modal-field svm-inline">
                            <div>
                                <label class="modal-label">Min</label>
                                <input class="modal-input" type="number" min="1" max="30" @bind="_MinLength"/>
                            </div>
                            <div>
                                <label class="modal-label">Max</label>
                                <input class="modal-input" type="number" min="1" max="30" @bind="_MaxLength"/>
                            </div>
                        </div>
                    }
                }
                else
                {
                    @* Internal Number / Dial *@
                    <div class="modal-field">
                        <label class="modal-label">@Loc.T(Localization.Common.Fields.newValue)</label>
                        <select class="modal-input" @bind="_Assignment">
                            <option value="@NumberAssignment.Unset">Unset</option>
                            <option value="@NumberAssignment.SetSpecific">Specific value</option>
                            <option value="@NumberAssignment.Randomize">@Loc.T(Localization.Common.Assignment.randomize)</option>
                        </select>
                    </div>
                    @if (_Assignment == NumberAssignment.SetSpecific)
                    {
                        <div class="modal-field">
                            <label class="modal-label">@Loc.T(Localization.Common.Fields.value)</label>
                            <input class="modal-input" type="number" @bind="_SpecificValue"/>
                        </div>
                    }
                    else if (_Assignment == NumberAssignment.Randomize)
                    {
                        <div class="modal-field">
                            <label class="modal-label">@Loc.T(Localization.Common.Assignment.randomMode)</label>
                            <select class="modal-input" @bind="_RandomMode">
                                <option value="@RandomMode.Saved">@Loc.T(Localization.Common.Assignment.randomModeSaved)</option>
                                <option value="@RandomMode.Pure">@Loc.T(Localization.Common.Assignment.randomModePure)</option>
                            </select>
                        </div>
                    }
                    <label class="svm-check">
                        <input type="checkbox" @bind="_Secret"/>
                        <span>@Loc.T(Localization.Common.Fields.secret)</span>
                    </label>
                }

                @if (sel.Scope == StoryVariableScope.Internal)
                {
                    <div class="modal-field">
                        <label class="modal-label">@Loc.T(Localization.Common.Fields.placement)</label>
                        <select class="modal-input" @bind="_Placement">
                            <option value="@StorageInstructionPlacement.Below">Below</option>
                            <option value="@StorageInstructionPlacement.Above">Above</option>
                        </select>
                    </div>
                }
            }

        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="Cancel">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-primary" @onclick="Confirm" disabled="@(!_CanConfirm)">
                @(_IsEdit ? Loc.T(Localization.Common.Buttons.saveChanges) : "Add")
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public EventCallback<SetVariableArgs> OnConfirm { get; set; }

    private bool                                _Visible;
    private bool                                _IsEdit;
    private Guid                                _EditNodeId;
    private Guid                                _SelectedVariableId;
    private string                              _Search = "";
    private StorySetExternalVariableMode        _ExternalMode;
    private string                              _ExternalValue = "";
    private List<StorySetExternalVariableRemap> _ValueMap = new();
    private NumberAssignment                    _Assignment = NumberAssignment.SetSpecific;
    private bool                                _Secret;
    private int                                 _SpecificValue;
    private RandomMode                          _RandomMode;
    private StorageInstructionPlacement         _Placement;
    private StringValueMode                     _StringMode;
    private string                              _StringValue = "";
    private StringInputKind                     _StringInputKind;
    private int                                 _MinLength = 1;
    private int                                 _MaxLength = 30;

    private StoryVariable? _Selected => StoryLogicFlow.Variable(_ProjectState.CurrentProject!, _SelectedVariableId);
    private bool           _CanConfirm => _SelectedVariableId != Guid.Empty;

    /// <summary>Opens the modal to create a new Set Variable node.</summary>
    public void Show()
    {
        Reset();
        _IsEdit     = false;
        _EditNodeId = Guid.Empty;
        _Visible    = true;
        StateHasChanged();
    }

    /// <summary>Opens the modal to edit an existing Set Variable node.</summary>
    public void ShowEdit(StorySetVariableNode node)
    {
        Reset();
        _IsEdit             = true;
        _EditNodeId         = node.Id;
        _SelectedVariableId = node.SelectedVariableId;
        _ExternalMode       = node.ExternalMode;
        _ExternalValue      = node.ExternalValue;
        _ValueMap           = node.ValueMap.Select(r => new StorySetExternalVariableRemap { From = r.From, To = r.To }).ToList();
        _Assignment         = node.Assignment;
        _Secret             = node.Secret;
        _SpecificValue      = node.SpecificValue;
        _RandomMode         = node.RandomMode;
        _Placement          = node.Placement;
        _StringMode         = node.StringMode;
        _StringValue        = node.StringValue;
        _StringInputKind    = node.StringInputKind;
        _MinLength          = node.MinLength;
        _MaxLength          = node.MaxLength;
        _Visible            = true;
        StateHasChanged();
    }

    private void Reset()
    {
        _SelectedVariableId = Guid.Empty;
        _Search             = "";
        _ExternalMode       = StorySetExternalVariableMode.SpecificValue;
        _ExternalValue      = "";
        _ValueMap           = new();
        _Assignment         = NumberAssignment.SetSpecific;
        _Secret             = false;
        _SpecificValue      = 0;
        _RandomMode         = RandomMode.Saved;
        _Placement          = StorageInstructionPlacement.Below;
        _StringMode         = StringValueMode.Unset;
        _StringValue        = "";
        _StringInputKind    = StringInputKind.Text;
        _MinLength          = 1;
        _MaxLength          = 30;
    }

    private void Select(StoryVariable v)
    {
        _SelectedVariableId = v.Id;
        // Default the external fixed value to the first possible value so a Bool/Options set is valid immediately.
        if (v.Scope == StoryVariableScope.External && string.IsNullOrEmpty(_ExternalValue))
            _ExternalValue = StoryVariableValues.PossibleValues(v).FirstOrDefault() ?? "";
    }

    private List<StoryVariable> FilteredVariables()
    {
        IEnumerable<StoryVariable> all = _ProjectState.CurrentProject!.Variables.Values.Where(v => !v.IsReadOnly);
        if (!string.IsNullOrWhiteSpace(_Search))
            all = all.Where(v => v.Name.Contains(_Search.Trim(), StringComparison.OrdinalIgnoreCase));
        return all.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private async Task Confirm()
    {
        if (!_CanConfirm) return;
        _Visible = false;
        int min = Math.Clamp(_MinLength, 1, 30);
        int max = Math.Clamp(_MaxLength, min, 30);
        await OnConfirm.InvokeAsync(new SetVariableArgs(
            _EditNodeId, _SelectedVariableId,
            _ExternalMode, _ExternalValue, _ValueMap,
            _Assignment, _Secret, _SpecificValue, _RandomMode, _Placement,
            _StringMode, _StringValue, _StringInputKind,
            min, max, Guid.Empty, null, Guid.Empty, false));
    }

    private void Cancel() => _Visible = false;

    /// <summary>Result passed back to the parent. <see cref="EditNodeId"/> is empty for a create, set for an edit.</summary>
    public record SetVariableArgs(
        Guid                                EditNodeId,
        Guid                                SelectedVariableId,
        StorySetExternalVariableMode        ExternalMode,
        string                              ExternalValue,
        List<StorySetExternalVariableRemap> ValueMap,
        NumberAssignment                    Assignment,
        bool                                Secret,
        int                                 SpecificValue,
        RandomMode                          RandomMode,
        StorageInstructionPlacement         Placement,
        StringValueMode                     StringMode,
        string                              StringValue,
        StringInputKind                     StringInputKind,
        int                                 MinLength,
        int                                 MaxLength,
        Guid                                LengthErrorKeyId,
        StoryConditionExpr?                 ValidationRule,
        Guid                                ValidationErrorKeyId,
        bool                                WireValue);
}

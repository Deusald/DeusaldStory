@namespace DeusaldStoryWeb.Components.Common
@inject ProjectStateService _ProjectState
@inject UiLocalizationService Loc

@* ─────────────────────────────────────────────────────────────────────────
   Inspector shown when the story's End node is selected. Lists the registered
   storage variables and lets the author mark which ones are released at The End
   — for variables that live through the whole story and so have no natural
   Unregister node. The graph validator treats these as unregistered at End.
   ───────────────────────────────────────────────────────────────────────── *@

<div class="eue-root">

    <div class="eue-header">
        <span class="eue-kind" style="color:var(--danger)">
            <span class="eue-kind-dot" style="background:var(--danger)"></span>
            @Loc.T(Localization.Editor.Modals.EndUnregister.endKind)
        </span>
        <div class="eue-title">@Loc.T(Localization.Editor.Modals.EndUnregister.theEndTitle)</div>
        <div class="eue-sub">@Loc.T(Localization.Editor.Modals.EndUnregister.releaseSubtitle)</div>
    </div>

    <div class="eue-body">
        @{
            List<StoryRegisterVariableNode> vars = ReleaseCandidates();
        }
        @if (vars.Count == 0)
        {
            <div class="eue-empty">@Loc.T(Localization.Editor.Modals.EndUnregister.noVariablesEmpty)</div>
        }
        else
        {
            <div class="eue-section-head">@Loc.T(Localization.Editor.Modals.EndUnregister.releaseSectionHead)</div>
            @foreach (StoryRegisterVariableNode v in vars)
            {
                StoryRegisterVariableNode variable = v;
                <label class="eue-item">
                    <input type="checkbox"
                           checked="@IsReleased(variable.Id)"
                           @onchange="e => Toggle(variable.Id, (bool)(e.Value ?? false))"/>
                    <span class="eue-item-name">@(string.IsNullOrWhiteSpace(variable.Name) ? Loc.T(Localization.Common.Placeholders.unnamed) : variable.Name)</span>
                    <span class="eue-item-slot">@StorageSlots.Label(variable.Type, variable.SlotIndex)</span>
                </label>
            }
        }
    </div>

</div>

@code {
    private StoryProject Project => _ProjectState.CurrentProject!;

    // Only variables that actually reach The End still registered are release candidates. Any variable released by
    // an Unregister node on every path never appears here. Currently-selected ids are kept so they can be unchecked.
    private List<StoryRegisterVariableNode> ReleaseCandidates()
    {
        StoryValidationResult result = StoryGraphValidator.Validate(Project, _ProjectState.CurrentLocalization);

        HashSet<Guid> ids = new(result.EndActive);
        foreach (Guid selected in Project.Metadata.UnregisterAtEnd) ids.Add(selected);

        List<StoryRegisterVariableNode> list = new();
        foreach (Guid id in ids)
            if (EditorProjection.FindRegister(Project, id) is StoryRegisterVariableNode reg)
                list.Add(reg);
        return list.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private bool IsReleased(Guid registeredVariableId) => Project.Metadata.UnregisterAtEnd.Contains(registeredVariableId);

    private void Toggle(Guid registeredVariableId, bool released)
    {
        HashSet<Guid> set = new(Project.Metadata.UnregisterAtEnd);
        if (released) set.Add(registeredVariableId);
        else          set.Remove(registeredVariableId);
        _ProjectState.SetEndUnregister(set);
    }
}

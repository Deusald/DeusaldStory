@namespace DeusaldStoryWeb.Components.Common
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState
@inject NavigationManager   _Nav
@implements IDisposable

@{ if (!_ProjectState.HasProject) return; }

<div class="etb-root">

    @* ── Left: back · logo · breadcrumb ──────────────────────────────── *@
    <div class="etb-left">
        <button class="etb-back-btn" @onclick="GoHome" title="@Loc.T(Localization.Editor.TopBar.backToProjects)">
            <i class="bi bi-chevron-left"></i>
        </button>

        <svg class="etb-logo" width="22" height="22" viewBox="0 0 44 44" fill="none"
             xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="6" width="32" height="32" rx="9"
                  style="fill:none;stroke:var(--border-strong)" stroke-width="1.8"/>
            <path d="M13.5 14.5 L30.5 29.5" style="stroke:var(--accent)" stroke-width="2.8" stroke-linecap="round"/>
            <circle cx="13.5" cy="14.5" r="4.2" style="fill:var(--accent)"/>
            <circle cx="30.5" cy="29.5" r="4.2" style="fill:var(--accent)"/>
            <circle cx="30" cy="14" r="2.8" style="fill:var(--success)"/>
        </svg>

        <span class="etb-project-name">@Loc.T(Localization.Editor.TopBar.brand)</span>

        <nav class="etb-crumbs">
            @for (int i = 0; i < Crumbs.Count; ++i)
            {
                int         index = i;
                EditorCrumb crumb = Crumbs[i];
                <span class="etb-sep">/</span>
                @if (index == Crumbs.Count - 1)
                {
                    <span class="etb-crumb etb-crumb-current">@crumb.Name</span>
                }
                else
                {
                    <button class="etb-crumb" @onclick="() => CrumbClicked.InvokeAsync(index)">@crumb.Name</button>
                }
            }
        </nav>
    </div>

    @* ── Center: Edit / (Play | Preview) ─────────────────────────────── *@
    @* Inside a logic node the second tab previews the node's output; elsewhere it plays the story. *@
    <div class="etb-tabs">
        <button class="etb-tab @(Mode == EditorMode.Edit ? "active" : "")"
                @onclick="() => SetMode(EditorMode.Edit)">
            <i class="bi bi-diagram-2"></i> @Loc.T(Localization.Editor.TopBar.tabEdit)
        </button>
        @if (InLogicNode)
        {
            <button class="etb-tab @(Mode == EditorMode.Preview ? "active" : "")"
                    @onclick="() => SetMode(EditorMode.Preview)">
                <i class="bi bi-eye-fill"></i> @Loc.T(Localization.Editor.TopBar.tabPreview)
            </button>
        }
        else
        {
            <button class="etb-tab @(Mode == EditorMode.Play ? "active" : "")"
                    @onclick="() => SetMode(EditorMode.Play)">
                <i class="bi bi-play-fill"></i> @Loc.T(Localization.Editor.TopBar.tabPlay)
            </button>
        }
    </div>

    @* ── Right: undo/redo · saved state · export · import ────────────── *@
    <div class="etb-right">
        <button class="etb-icon-btn" @onclick="Undo" disabled="@(!_ProjectState.CanUndo)" title="@Loc.T(Localization.Editor.TopBar.undoTooltip)">
            <i class="bi bi-arrow-counterclockwise"></i>
        </button>
        <button class="etb-icon-btn" @onclick="Redo" disabled="@(!_ProjectState.CanRedo)" title="@Loc.T(Localization.Editor.TopBar.redoTooltip)">
            <i class="bi bi-arrow-clockwise"></i>
        </button>

        @if (_ProjectState.IsDirty)
        {
            <button class="etb-save-btn" @onclick="Save">
                <i class="bi bi-check2"></i> @Loc.T(Localization.Common.Buttons.save)
            </button>
        }
        <span class="etb-status-pill @(_ProjectState.IsDirty ? "etb-status-warn" : "etb-status-ok")">
            <span class="etb-status-dot"></span>
            @(_ProjectState.IsDirty ? Loc.T(Localization.Editor.TopBar.statusUnsaved) : Loc.T(Localization.Editor.TopBar.statusSaved))
        </span>

        <div class="etb-menu-wrap">
            <button class="etb-icon-btn" @onclick="() => _ExportOpen = !_ExportOpen" title="@Loc.T(Localization.Editor.TopBar.exportTooltip)">
                <i class="bi bi-box-arrow-up"></i>
            </button>
            @if (_ExportOpen)
            {
                <div class="etb-menu-backdrop" @onclick="() => _ExportOpen = false"></div>
                <div class="etb-menu">
                    <button class="etb-menu-item" @onclick="ExportStoryPdf">
                        <i class="bi bi-filetype-pdf"></i>
                        <div class="etb-menu-text">
                            <span class="etb-menu-title">@Loc.T(Localization.Editor.TopBar.exportStoryPdfTitle)</span>
                            <span class="etb-menu-sub">@Loc.T(Localization.Editor.TopBar.exportStoryPdfSub)</span>
                        </div>
                    </button>
                    <button class="etb-menu-item" @onclick="ExportLocalization">
                        <i class="bi bi-file-earmark-spreadsheet"></i>
                        <div class="etb-menu-text">
                            <span class="etb-menu-title">@Loc.T(Localization.Editor.TopBar.exportLocalizationTitle)</span>
                            <span class="etb-menu-sub">@Loc.T(Localization.Editor.TopBar.exportLocalizationSub)</span>
                        </div>
                    </button>
                </div>
            }
        </div>

        <button class="etb-icon-btn" @onclick="ImportLocalization" title="@Loc.T(Localization.Editor.TopBar.importLocalizationTooltip)">
            <i class="bi bi-box-arrow-in-down"></i>
        </button>

        @if (_ProjectState.CurrentLocalization is not null)
        {
            <button class="etb-icon-btn" @onclick="RefreshLocalization" title="@Loc.T(Localization.Common.Loc.refreshTooltip)">
                <i class="bi bi-translate"></i>
            </button>
        }
    </div>

</div>

@* ── Unsaved-changes guard shown when leaving to the projects list ─────── *@
@if (_ConfirmLeaveOpen)
{
    <div class="modal-backdrop" @onclick="CancelLeave"></div>

    <div class="modal-box etb-leave-box" @onclick:stopPropagation="true">

        <div class="modal-header">
            <span class="modal-title">@Loc.T(Localization.Editor.TopBar.unsavedChangesTitle)</span>
            <button class="modal-close" @onclick="CancelLeave" title="@Loc.T(Localization.Common.Buttons.close)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="modal-body">
            <div class="modal-note">
                <i class="bi bi-exclamation-triangle"></i>
                <span>@Loc.T(Localization.Editor.TopBar.unsavedChangesBody)</span>
            </div>
        </div>

        <div class="modal-footer">
            <button class="modal-btn modal-btn-ghost" @onclick="CancelLeave">@Loc.T(Localization.Common.Buttons.cancel)</button>
            <button class="modal-btn modal-btn-ghost" @onclick="DiscardAndLeave">@Loc.T(Localization.Editor.TopBar.discardChanges)</button>
            <button class="modal-btn modal-btn-primary" @onclick="SaveAndLeave">@Loc.T(Localization.Editor.TopBar.saveAndLeave)</button>
        </div>

    </div>
}

@code {
    [Parameter] public EditorMode                   Mode                 { get; set; }
    [Parameter] public EventCallback<EditorMode>    ModeChanged          { get; set; }
    [Parameter] public IReadOnlyList<EditorCrumb>   Crumbs               { get; set; } = [];
    [Parameter] public EventCallback<int>           CrumbClicked         { get; set; }
    [Parameter] public bool                         InLogicNode          { get; set; }
    [Parameter] public EventCallback                OnRefreshLocalization { get; set; }

    private bool _ExportOpen;
    private bool _ConfirmLeaveOpen;

    protected override void OnInitialized()
    {
        _ProjectState.DirtyStateChanged  += OnStateChanged;
        _ProjectState.ProjectDataChanged += OnStateChanged;
        _ProjectState.HistoryChanged     += OnStateChanged;
        _ProjectState.HistoryApplied     += OnStateChanged;
    }

    private void Undo() => _ProjectState.Undo();
    private void Redo() => _ProjectState.Redo();

    private Task SetMode(EditorMode mode)
    {
        if (mode == Mode) return Task.CompletedTask;
        Mode = mode;
        return ModeChanged.InvokeAsync(mode);
    }

    private async Task Save()
    {
        await _ProjectState.SaveAsync();
        StateHasChanged();
    }

    private async Task RefreshLocalization()
    {
        await OnRefreshLocalization.InvokeAsync();
        StateHasChanged();
    }

    private void GoHome()
    {
        // Guard against losing unsaved work — prompt to save/discard first.
        if (_ProjectState.IsDirty)
        {
            _ConfirmLeaveOpen = true;
            StateHasChanged();
            return;
        }
        LeaveToHome();
    }

    private void CancelLeave() => _ConfirmLeaveOpen = false;

    private void DiscardAndLeave()
    {
        _ConfirmLeaveOpen = false;
        LeaveToHome();
    }

    private async Task SaveAndLeave()
    {
        _ConfirmLeaveOpen = false;
        await _ProjectState.SaveAsync();
        LeaveToHome();
    }

    private void LeaveToHome()
    {
        _ProjectState.CloseProject();
        // BaseUri (not "/" or "") so this works both in the MAUI WebView and under the web app's rewritten base href.
        _Nav.NavigateTo(_Nav.BaseUri);
    }

    // ── Export / import (stubbed until the pipelines exist) ────────────────
    private void ExportStoryPdf()     => _ExportOpen = false; // TODO: story → PDF
    private void ExportLocalization() => _ExportOpen = false; // TODO: localization → Excel / .loc
    private void ImportLocalization() { /* TODO: import localization from Excel / .loc */ }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        _ProjectState.DirtyStateChanged  -= OnStateChanged;
        _ProjectState.ProjectDataChanged -= OnStateChanged;
        _ProjectState.HistoryChanged     -= OnStateChanged;
        _ProjectState.HistoryApplied     -= OnStateChanged;
    }
}

@page "/editor"
@layout EmptyLayout
@namespace DeusaldStoryWeb.Components.Pages
@inject ProjectStateService _ProjectState
@inject NavigationManager   _Nav

@if (!_ProjectState.HasProject)
{
    return;
}

<div class="ed-page">

    <EditorTopBar Mode="_Mode"
                  ModeChanged="OnModeChanged"
                  Crumbs="_Crumbs"
                  CrumbClicked="OnCrumbClicked"/>

    <div class="ed-body">

        <EditorRail/>

        <div class="ed-stage">
            @if (_Mode == EditorMode.Edit)
            {
                <EditorGraph Nodes="_Nodes"
                             Edges="_Edges"
                             SelectedId="_SelectedId"
                             SelectedChanged="OnSelect"
                             OnAddNode="OnAddNode"
                             OnNodeMoved="OnNodeMoved"/>
            }
            else
            {
                <div class="ed-play">
                    <div class="ed-play-inner">
                        <i class="bi bi-play-circle"></i>
                        <div class="ed-play-title">Play mode</div>
                        <div class="ed-play-sub">Step through the story from the start node. Runtime playback is coming next.</div>
                    </div>
                </div>
            }
        </div>

        <div class="ed-inspector">
            <EditorInspector Node="_SelectedNode"/>
        </div>

    </div>
</div>

<NewLogicNodeModal @ref="_NewLogicNodeModal" OnConfirm="OnNewLogicNodeConfirmed"/>

@code {
    private EditorMode        _Mode = EditorMode.Edit;
    private Guid              _SelectedId;
    private Guid              _CurrentContainerId;
    private List<EditorCrumb> _Crumbs = [];
    private List<EdNode>      _Nodes  = [];
    private List<EdEdge>      _Edges  = [];

    private NewLogicNodeModal? _NewLogicNodeModal;

    private EdNode? _SelectedNode => _Nodes.Find(n => n.Id == _SelectedId);

    private StoryProject Project => _ProjectState.CurrentProject!;

    protected override void OnInitialized()
    {
        if (!_ProjectState.HasProject)
        {
            // Opened /editor directly with nothing loaded — send the user back to pick a project.
            _Nav.NavigateTo(_Nav.BaseUri);
            return;
        }

        _CurrentContainerId = Project.Metadata.RootStoryContainerNodeId;
        _Crumbs             = [new EditorCrumb(_CurrentContainerId, RootName())];
        RebuildNodes();
    }

    private string RootName() =>
        Project.ContainerNodes.TryGetValue(_CurrentContainerId, out StoryContainerNode? root) ? root.Name : "Root";

    private bool IsRootContainer => _CurrentContainerId == Project.Metadata.RootStoryContainerNodeId;

    /// <summary>Re-projects the current container's persisted contents into the canvas view models.</summary>
    private void RebuildNodes()
    {
        if (!Project.ContainerNodes.TryGetValue(_CurrentContainerId, out StoryContainerNode? container))
        {
            _Nodes = [];
            return;
        }
        _Nodes = EditorProjection.BuildNodes(Project, container, IsRootContainer);
    }

    private void OnModeChanged(EditorMode mode) => _Mode = mode;

    private void OnSelect(Guid id) => _SelectedId = id;

    private void OnCrumbClicked(int index)
    {
        // Drill back up to the clicked container (only the root exists for now).
        if (index < _Crumbs.Count - 1)
        {
            _Crumbs             = _Crumbs.GetRange(0, index + 1);
            _CurrentContainerId = _Crumbs[^1].Id;
            RebuildNodes();
        }
    }

    // ── Add logic node ─────────────────────────────────────────────────────

    private void OnAddNode() => _NewLogicNodeModal?.Show();

    private void OnNewLogicNodeConfirmed(NewLogicNodeModal.NewLogicNodeArgs args)
    {
        StoryConnectionPoint entry = new() { Name = args.EntryName };
        List<StoryConnectionPoint> exits = args.ExitNames
                                               .Select(n => new StoryConnectionPoint { Name = n })
                                               .ToList();

        // Stagger new nodes so a burst of additions doesn't stack on one spot.
        int count = Project.LogicNodes.Count;
        double x  = 320 + count % 5 * 30;
        double y  = 120 + count % 5 * 26;

        StoryLogicNode node = _ProjectState.AddLogicNode(_CurrentContainerId, args.Name, args.Description, entry, exits, x, y);

        RebuildNodes();
        _SelectedId = node.Id;
    }

    // ── Persist a drag ─────────────────────────────────────────────────────

    private void OnNodeMoved(EdNode moved)
    {
        // A logic node moved.
        if (Project.LogicNodes.TryGetValue(moved.Id, out StoryLogicNode? logic))
        {
            logic.X = moved.X;
            logic.Y = moved.Y;
            _ProjectState.MarkKeyDirty(logic.Id);
            return;
        }

        // A child container moved.
        if (Project.ContainerNodes.TryGetValue(moved.Id, out StoryContainerNode? child))
        {
            child.X = moved.X;
            child.Y = moved.Y;
            _ProjectState.MarkKeyDirty(child.Id);
            return;
        }

        // A connection point (Start/End/Entry/Exit) of the current container moved.
        if (Project.ContainerNodes.TryGetValue(_CurrentContainerId, out StoryContainerNode? container))
        {
            StoryConnectionPoint? point = container.EntryPoints.Find(p => p.Id == moved.Id)
                                       ?? container.ExitPoints.Find(p => p.Id == moved.Id);
            if (point is not null)
            {
                point.X = moved.X;
                point.Y = moved.Y;
                _ProjectState.MarkKeyDirty(container.Id);
            }
        }
    }
}

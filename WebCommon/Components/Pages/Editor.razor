@page "/editor"
@layout EmptyLayout
@namespace DeusaldStoryWeb.Components.Pages
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState
@inject NavigationManager   _Nav
@implements IDisposable

@if (!_ProjectState.HasProject)
{
    return;
}

<div class="ed-page">

    <EditorTopBar Mode="_Mode"
                  ModeChanged="OnModeChanged"
                  Crumbs="_Crumbs"
                  CrumbClicked="OnCrumbClicked"
                  InLogicNode="_InLogic"
                  OnRefreshLocalization="OnRefreshLocalization"/>

    <div class="ed-body">

        <EditorRail @ref="_Rail" OnToolSelected="OnToolSelected"/>

        @if (_ActiveTool == EditorRail.Tool.Media)
        {
            @* The images library spans the whole centre (graph + inspector); only the rail stays. *@
            <ImagesPanel/>
        }
        else if (_ActiveTool == EditorRail.Tool.Localization)
        {
            @* The localization browser spans the whole centre; refresh re-projects the graph behind it. *@
            <LocalizationPanel OnRefresh="OnRefreshLocalization"/>
        }
        else if (_ActiveTool == EditorRail.Tool.Variables)
        {
            @* The variables editor spans the whole centre (list + edit); only the rail stays. *@
            <VariablesPanel/>
        }
        else if (_ActiveTool == EditorRail.Tool.Problems)
        {
            @* The problems list spans the whole centre; clicking a row navigates the graph behind it. *@
            <ProblemsPanel OnNavigate="OnProblemNavigate"/>
        }
        else if (_ActiveTool == EditorRail.Tool.Blocks)
        {
            @* The blueprint library spans the whole centre; opening a definition drills into the graph behind it. *@
            <BlueprintsPanel OnOpen="OnOpenBlueprint" OnEditSignature="OnEditSignature" OnEditProperties="OnEditBlueprintProperties"/>
        }
        else
        {
            <div class="ed-stage">
                @if (_Mode == EditorMode.Edit)
                {
                    <EditorGraph @ref="_GraphRef"
                                 Nodes="_Nodes"
                                 Edges="_Edges"
                                 GraphId="_CurrentId"
                                 InitialViewport="_ViewCurrent"
                                 SelectedId="_SelectedId"
                                 SelectedChanged="OnSelect"
                                 OnAddNode="OnAddNode"
                                 OnNodesMoved="OnNodesMoved"
                                 OnNodeActivated="OnNodeActivated"
                                 OnConnect="OnConnect"
                                 OnDisconnect="OnDisconnect"
                                 OnCanvasContextMenu="OnCanvasContextMenu"
                                 OnNodeEdit="OnNodeEdit"
                                 OnNodePreview="OnNodePreview"
                                 OnNodeDelete="OnNodeDelete"
                                 OnNodesDelete="OnNodesDelete"
                                 OnNodesCopy="OnNodesCopy"
                                 OnPaste="OnPaste"
                                 OnNodeAddPortalIn="OnNodeAddPortalIn"
                                 OnNodeAddPortalOut="OnNodeAddPortalOut"
                                 OnNodeReparent="OnNodeReparent"
                                 OnNodeMoveToParent="OnNodeMoveToParent"
                                 OnNodeMakeBlueprint="OnNodeMakeBlueprint"
                                 OnUndo="OnUndo"
                                 OnRedo="OnRedo"
                                 CanMoveToParent="@(!_InLogic && !IsRootContainer)"
                                 CanPaste="@CanPaste"/>
                }
                else if (_Mode == EditorMode.Preview && _PreviewLogic is StoryLogicNode previewLogic)
                {
                    <div class="ed-preview">
                        <div class="ed-preview-switch">
                            <button class="ed-preview-tab @(_PreviewGamebook ? "" : "active")" @onclick="() => SetPreviewKind(false)">
                                <i class="bi bi-phone"></i> @Loc.T(Localization.Editor.Page.previewTabApp)
                            </button>
                            <button class="ed-preview-tab @(_PreviewGamebook ? "active" : "")" @onclick="() => SetPreviewKind(true)">
                                <i class="bi bi-book"></i> @Loc.T(Localization.Editor.Page.previewTabGamebook)
                            </button>
                        </div>
                        @if (_PreviewNotice is not null)
                        {
                            <div class="ed-preview-notice">@_PreviewNotice</div>
                        }
                        <div class="ed-preview-body">
                            @if (_PreviewGamebook)
                            {
                                <GamebookPreview Logic="previewLogic"
                                                 Project="_PreviewProject"
                                                 OnNavigate="OnGamebookNavigate"
                                                 ScrollToKey="@_GbpScrollKey"/>
                            }
                            else
                            {
                                <LogicPreview Logic="previewLogic" Project="_PreviewProject" Values="_PreviewVars" OnContinue="OnPreviewContinue"/>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="ed-play">
                        <div class="ed-play-inner">
                            <i class="bi bi-play-circle"></i>
                            <div class="ed-play-title">@Loc.T(Localization.Editor.Page.playModeTitle)</div>
                            <div class="ed-play-sub">@Loc.T(Localization.Editor.Page.playModeSubtitle)</div>
                        </div>
                    </div>
                }
            </div>

            <div class="ed-inspector">
                @if (_Mode == EditorMode.Preview && _PreviewLogic is StoryLogicNode inspectLogic)
                {
                    @* In App preview the inspector becomes the variables tweak panel; in Gamebook it shows a read-only note. *@
                    @* Project is the session's own — seeding must key values exactly as the renderer reads them. *@
                    <PreviewVariablesPanel Logic="inspectLogic" Project="_PreviewProject" Values="_PreviewVars" ValuesChanged="StateHasChanged" Gamebook="_PreviewGamebook"/>
                }
                else if (_SelectedNode?.Kind == StoryNodeKind.End)
                {
                    @* The story End node: choose which whole-story storage variables are released here. *@
                    <EndUnregisterEditor/>
                }
                else if (_InLogic && _SelectedNode?.Kind is StoryNodeKind.RegisterVariable or StoryNodeKind.SetVariable or StoryNodeKind.UnregisterVariable or StoryNodeKind.GetVariable)
                {
                    @* A storage-variable node: show its full configuration. *@
                    <VariableNodeInspector Logic="_CurrentLogicNode" NodeId="_SelectedId"/>
                }
                else
                {
                    <EditorInspector Node="_SelectedNode" Logic="@(_InLogic ? _CurrentLogicNode : null)"/>
                }
            </div>
        }

    </div>
</div>

<NodePaletteModal          @ref="_NodePalette"         OnSelect="OnPaletteSelect"/>
<NewLogicNodeModal         @ref="_NewLogicNodeModal"   OnConfirm="OnNewLogicNodeConfirmed"/>
<NewContainerNodeModal     @ref="_NewContainerModal"   OnConfirm="OnNewContainerConfirmed"/>
<NewPortalNodeModal        @ref="_NewPortalModal"      OnConfirm="OnNewPortalConfirmed"/>
<LogicPortalNodeModal      @ref="_LogicPortalModal"    OnConfirm="OnLogicPortalConfirmed"/>
<LocalizationKeyPickerModal @ref="_LocalizationPicker" OnConfirm="OnLocalizationPicked"/>
<IconPickerModal           @ref="_IconPicker"          OnConfirm="OnIconPicked"/>
<VariablePickerModal       @ref="_VariablePicker"      OnConfirm="OnVariablePicked"/>
<GetVariableModal          @ref="_GetVariableModal"    OnConfirm="OnGetVariableConfirmed"/>
<ConstantVariableModal     @ref="_ConstantVariableModal" OnConfirm="OnConstantVariableConfirmed"/>
<ConstantStringModal       @ref="_ConstantStringModal"   OnConfirm="OnConstantStringConfirmed"/>
<RandomizedInstructionModal @ref="_RandomizedInstructionModal" OnConfirm="OnRandomizedInstructionConfirmed"/>
<RegisterVariableModal     @ref="_RegisterVariableModal" Logic="_CurrentLogicNode" OnConfirm="OnRegisterVariableConfirmed"/>
<SetVariableModal          @ref="_SetVariableModal"      Logic="_CurrentLogicNode" OnConfirm="OnSetVariableConfirmed"/>
<UnregisterVariablePickerModal @ref="_UnregisterPicker"  OnConfirm="OnUnregisterPicked"/>
<SetExternalVariableModal  @ref="_SetExternalVariableModal" OnConfirm="OnSetExternalVariableConfirmed"/>
<ExitNodeModal             @ref="_ExitNodeModal"            OnConfirm="OnExitNodeConfirmed"/>
<ConditionFlowModal        @ref="_ConditionFlowModal"       OnConfirm="OnConditionFlowConfirmed"/>
<NewCommentNodeModal       @ref="_NewCommentNodeModal"      OnConfirm="OnCommentConfirmed"/>
<FlowTextOptionsModal      @ref="_FlowTextOptionsModal"     OnConfirm="OnFlowTextConfirmed"/>
<SmartFormatOptionsModal   @ref="_SmartFormatOptionsModal"  OnConfirm="OnSmartFormatConfirmed"/>
<BlueprintPickerModal      @ref="_BlueprintPicker"          OnSelect="OnBlueprintPicked"/>
<FunctionSignatureModal    @ref="_FunctionSignatureModal"   OnConfirm="OnSignatureConfirmed"/>

@code {
    private EditorMode        _Mode = EditorMode.Edit;
    private EditorRail.Tool   _ActiveTool = EditorRail.Tool.Graph;
    private EditorRail?        _Rail;

    // Editing a blueprint definition runs in its own breadcrumb trail (starting at the blueprint), separate from the
    // story trail. The story trail is stashed here and restored when the user returns via the Story graph rail button.
    private bool               _EditingBlueprint;
    private List<EditorCrumb>  _StoryCrumbs = [];
    private Guid              _SelectedId;

    private EditorGraph? _GraphRef; // the live graph (present only in Edit mode)

    // Viewport memory. We remember the pan/zoom of the graph currently shown (_ViewCurrent) and of exactly one
    // graph before it (_ViewPrev). So toggling between two graphs (or Edit/Preview of the same graph) restores each,
    // but stepping to a third graph and back to the older one reopens it at the default view — only the last-opened
    // graph is remembered. A brand-new graph opens at DefaultViewport.
    private static readonly GraphViewport DefaultViewport = new(24, 28, 1);

    private Guid           _ViewGraphId = Guid.Empty;  // graph _ViewCurrent belongs to
    private GraphViewport  _ViewCurrent = DefaultViewport;
    private Guid           _ViewPrevId  = Guid.Empty;   // the one remembered previous graph
    private GraphViewport? _ViewPrev;
    private List<EditorCrumb> _Crumbs = [];
    private List<EdNode>      _Nodes  = [];
    private List<EdEdge>      _Edges  = [];

    private NodePaletteModal?          _NodePalette;
    private NewLogicNodeModal?         _NewLogicNodeModal;
    private NewContainerNodeModal?     _NewContainerModal;
    private NewPortalNodeModal?        _NewPortalModal;
    private LogicPortalNodeModal?      _LogicPortalModal;
    private LocalizationKeyPickerModal? _LocalizationPicker;
    private IconPickerModal?           _IconPicker;
    private VariablePickerModal?       _VariablePicker;
    private GetVariableModal?          _GetVariableModal;
    private ConstantVariableModal?     _ConstantVariableModal;
    private ConstantStringModal?       _ConstantStringModal;
    private RandomizedInstructionModal? _RandomizedInstructionModal;
    private RegisterVariableModal?     _RegisterVariableModal;
    private SetVariableModal?          _SetVariableModal;
    private UnregisterVariablePickerModal? _UnregisterPicker;
    private SetExternalVariableModal?  _SetExternalVariableModal;
    private ExitNodeModal?             _ExitNodeModal;
    private ConditionFlowModal?        _ConditionFlowModal;
    private NewCommentNodeModal?       _NewCommentNodeModal;
    private FlowTextOptionsModal?      _FlowTextOptionsModal;
    private SmartFormatOptionsModal?   _SmartFormatOptionsModal;
    private BlueprintPickerModal?      _BlueprintPicker;
    private FunctionSignatureModal?    _FunctionSignatureModal;

    // Where the next created node is placed — the right-clicked canvas point (or a staggered default).
    private double _PendingX;
    private double _PendingY;

    // Transient External Variable values driving the logic-node preview (variable id → value). Reset on each
    // entry into Preview so a fresh render starts from the variables' defaults; shared with the inspector panel.
    private Dictionary<Guid, string> _PreviewVars = new();

    // Which preview is showing (false = App, true = Gamebook), and a transient notice for App continue clicks
    // that don't navigate (reaches End / an unwired exit).
    private bool    _PreviewGamebook;
    private string? _PreviewNotice;

    // The Gamebook section a "go to section" click asked to scroll to (cleared once the preview has scrolled there).
    private string? _GbpScrollKey;

    private EdNode? _SelectedNode => _Nodes.Find(n => n.Id == _SelectedId);

    private StoryProject Project => _ProjectState.CurrentProject!;

    // ── Current location (derived from the last breadcrumb) ─────────────────
    private EditorScope _Scope     => _Crumbs.Count > 0 ? _Crumbs[^1].Scope : EditorScope.Container;
    private Guid        _CurrentId => _Crumbs.Count > 0 ? _Crumbs[^1].Id    : Project.Metadata.RootStoryContainerNodeId;
    private bool        _InLogic   => _Scope == EditorScope.Logic;

    /// <summary>The logic node whose inner graph is currently open, or null when a container is open.</summary>
    private StoryLogicNode? _CurrentLogicNode =>
        _InLogic && Project.LogicNodes.TryGetValue(_CurrentId, out StoryLogicNode? logic) ? logic : null;

    // ── Preview session ────────────────────────────────────────────────────
    // A preview runs against ONE project for its whole life, and everything it shows — the rendered node, the variables
    // panel, the flow it follows on continue — reads that same one. Mixing them silently breaks: the expander remaps
    // ids per instance, so a value the panel seeds under an authoring id is invisible to a renderer reading a clone.

    /// <summary>The id of the previewed node <b>within <see cref="_PreviewProject"/></b> — not necessarily an authoring id.</summary>
    private Guid _PreviewNodeId;

    /// <summary>
    /// Which space this preview session is playing in. <b>true</b> = the blueprint-flattened project: the real story,
    /// walked from Start, where each instance is its own clone. <b>false</b> = the authoring project with functions
    /// inlined, used when previewing a blueprint definition on its own — it is out of tree, so it has no clone to play.
    /// </summary>
    private bool _PreviewExpanded;

    private StoryProject _PreviewProject =>
        _PreviewExpanded ? _ProjectState.GetExpandedProject() : _ProjectState.GetFunctionExpanded().Project;

    /// <summary>The node being previewed, resolved in its own space.</summary>
    private StoryLogicNode? _PreviewLogic =>
        _PreviewProject.LogicNodes.TryGetValue(_PreviewNodeId, out StoryLogicNode? logic) ? logic : null;

    protected override void OnInitialized()
    {
        if (!_ProjectState.HasProject)
        {
            // Opened /editor directly with nothing loaded — send the user back to pick a project.
            _Nav.NavigateTo(_Nav.BaseUri);
            return;
        }

        Guid root = Project.Metadata.RootStoryContainerNodeId;
        _Crumbs   = [new EditorCrumb(root, RootName())];
        RebuildNodes();

        // An Undo/Redo (from the toolbar or a keyboard shortcut) reverts the model out-of-band — rebuild the view.
        _ProjectState.HistoryApplied += OnHistoryApplied;
    }

    public void Dispose() => _ProjectState.HistoryApplied -= OnHistoryApplied;

    private void OnUndo() => _ProjectState.Undo();
    private void OnRedo() => _ProjectState.Redo();

    /// <summary>The model was reverted by Undo/Redo — drop any breadcrumbs / selection that no longer exist and rebuild.</summary>
    private void OnHistoryApplied()
    {
        // Walk back out of any container/logic node that the reverted action removed (always keep the Root crumb).
        while (_Crumbs.Count > 1)
        {
            EditorCrumb tail  = _Crumbs[^1];
            bool        alive = tail.Scope == EditorScope.Logic
                ? Project.LogicNodes.ContainsKey(tail.Id)
                : Project.ContainerNodes.ContainsKey(tail.Id);
            if (alive) break;
            _Crumbs.RemoveAt(_Crumbs.Count - 1);
        }

        RebuildNodes();
        if (_Nodes.All(n => n.Id != _SelectedId)) _SelectedId = Guid.Empty;
        InvokeAsync(StateHasChanged);
    }

    private string RootName() =>
        Project.ContainerNodes.TryGetValue(Project.Metadata.RootStoryContainerNodeId, out StoryContainerNode? root)
            ? root.Name : Loc.T(Localization.Editor.Page.rootFallbackName);

    private bool IsRootContainer => _CurrentId == Project.Metadata.RootStoryContainerNodeId;

    /// <summary>Re-projects the current location (a container's graph or a logic node's inner graph) into view models.</summary>
    private void RebuildNodes()
    {
        SyncViewportOnNavigation();

        if (_Scope == EditorScope.Logic)
        {
            if (Project.LogicNodes.TryGetValue(_CurrentId, out StoryLogicNode? logic))
            {
                _Nodes = EditorProjection.BuildLogicNodes(Project, logic, _ProjectState.CurrentLocalization);
                _Edges = EditorProjection.BuildLogicEdges(logic);
            }
            else
            {
                _Nodes = [];
                _Edges = [];
            }
            return;
        }

        if (!Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? container))
        {
            _Nodes = [];
            _Edges = [];
            return;
        }
        _Nodes = EditorProjection.BuildNodes(Project, container, IsRootContainer);
        _Edges = EditorProjection.BuildEdges(container);
    }

    private void OnModeChanged(EditorMode mode)
    {
        // Remember where the graph was panned/zoomed before it is swapped out, so returning to Edit reopens there.
        CaptureViewport();

        // Entering preview starts the External Variable tweaks fresh (panel re-seeds them to the defaults).
        if (mode == EditorMode.Preview)
        {
            // The tab always previews what is open right now — a session started earlier may have walked the flow far
            // from here, and its node must not linger. With a container open there is nothing to preview, so the id is
            // cleared and the pane falls back to its play-mode placeholder.
            if (_CurrentLogicNode is StoryLogicNode current)
            {
                _PreviewNodeId   = current.Id;
                _PreviewExpanded = PreviewIsExpanded(current);
            }
            else _PreviewNodeId = Guid.Empty;

            _PreviewVars     = new Dictionary<Guid, string>();
            _PreviewGamebook = false;
            _PreviewNotice   = null;
            _GbpScrollKey    = null;
        }
        _Mode = mode;
    }

    /// <summary>Switch the preview between the App screen and the printed Gamebook sections.</summary>
    private void SetPreviewKind(bool gamebook)
    {
        _PreviewGamebook = gamebook;
        _PreviewNotice   = null;
        _GbpScrollKey    = null;
    }

    /// <summary>
    /// App-preview "continue" — follow the clicked exit to the next logic node and preview it. Reaching the story
    /// End or an unwired exit shows a transient notice instead of navigating.
    /// </summary>
    private void OnPreviewContinue(StoryLogicRenderer.RenderedChoice choice)
    {
        // Everything here resolves in the session's own space — the clicked choice belongs to the node being rendered.
        StoryProject proj = _PreviewProject;
        StoryLogicNode? owner = proj.LogicNodes.Values.FirstOrDefault(l => l.Choices.Any(c => c.Id == choice.ChoiceId));

        // A Single-path node has no per-choice exit: every choice leaves by the one shared VFlow output (the choice
        // only pins which variable values ride along it), so the per-choice port is unwired by design — following it
        // would report a connected exit as dangling.
        Guid fromPoint = owner is { ExitMode: StoryLogicExitMode.SinglePath } ? owner.VFlowOut.Id : choice.OuterFlowOut;

        StoryFlowNavigator.NextLogicResult result = StoryFlowNavigator.ResolveNextLogic(proj, fromPoint);
        switch (result.Kind)
        {
            case StoryFlowNavigator.NextKind.Logic when result.Logic is not null:
                _PreviewVars = new Dictionary<Guid, string>();
                // If the next node reads this SinglePath node's variables, pin this choice's values for the preview.
                if (owner is { ExitMode: StoryLogicExitMode.SinglePath }
                    && StorySelectionResolver.SourceNode(proj, result.Logic) is StoryLogicNode src && src.Id == owner.Id
                    && owner.Choices.Find(c => c.Id == choice.ChoiceId) is StoryChoice picked)
                    _PreviewVars = StorySelectionResolver.ValuesForChoice(owner, picked);
                EnterPreview(result.Logic, _PreviewExpanded, replaceCrumb: true);
                _PreviewNotice = null;
                RebuildNodes();
                break;

            case StoryFlowNavigator.NextKind.End:
                _PreviewNotice = Loc.T(Localization.Editor.Page.previewNoticeReachedEnd);
                break;

            default:
                _PreviewNotice = Loc.T(Localization.Editor.Page.previewNoticeExitNotConnected);
                break;
        }
    }

    /// <summary>
    /// Gamebook-preview "go to section" click — switch the preview to the line's target logic node (replacing the last
    /// breadcrumb, as the App continue does) and ask the preview to scroll that specific section to the top of the view.
    /// </summary>
    private void OnGamebookNavigate(GamebookNavRequest request)
    {
        // The section's target id comes from the preview's own project, so it is resolved there — a flattened clone is
        // not in the authoring dictionary at all.
        if (request.LogicId == Guid.Empty || !_PreviewProject.LogicNodes.TryGetValue(request.LogicId, out StoryLogicNode? target))
            return;

        if (request.LogicId != _PreviewNodeId)
        {
            bool gamebook = _PreviewGamebook;
            EnterPreview(target, _PreviewExpanded, replaceCrumb: true);
            _PreviewGamebook = gamebook; // EnterPreview starts a session on the App tab; this navigation stays in Gamebook.
            RebuildNodes();
        }
        _GbpScrollKey = request.SectionKey;
    }

    /// <summary>Rail tool picked — swap the centre panel. Only Media has its own panel; the rest keep the graph.</summary>
    private void OnToolSelected(EditorRail.Tool tool)
    {
        // Some rail tools take over the whole centre and unmount the graph — save its viewport first.
        CaptureViewport();

        // The Story graph button leaves blueprint-editing mode and restores the story trail where the user left it.
        if (tool == EditorRail.Tool.Graph && _EditingBlueprint)
        {
            _EditingBlueprint = false;
            _Crumbs           = _StoryCrumbs;
            _SelectedId       = Guid.Empty;
            _Mode             = EditorMode.Edit;
            RebuildNodes();
        }

        _ActiveTool = tool;
    }

    /// <summary>Snapshots the live graph's pan/zoom so a later re-mount of the same graph (e.g. an Edit/Preview round-trip) reopens where it was left.</summary>
    private void CaptureViewport()
    {
        if (_GraphRef is not null) _ViewCurrent = _GraphRef.CurrentViewport;
    }

    /// <summary>
    /// Called after a navigation may have changed which graph is shown. If it did, remember the graph we just left as
    /// the single "previous" slot, then open the new graph where it was last left (only if it is that previous graph)
    /// or at the default view. Reading <see cref="EditorGraph.CurrentViewport"/> first captures the outgoing graph's
    /// latest pan (the graph card is still mounted at this point — the re-render happens after this returns).
    /// </summary>
    private void SyncViewportOnNavigation()
    {
        if (_CurrentId == _ViewGraphId) return; // same graph (an edit, not a navigation) — keep its viewport
        if (_GraphRef is not null) _ViewCurrent = _GraphRef.CurrentViewport;

        GraphViewport incoming = _CurrentId == _ViewPrevId && _ViewPrev is { } prev ? prev : DefaultViewport;
        _ViewPrevId  = _ViewGraphId;
        _ViewPrev    = _ViewCurrent;
        _ViewGraphId = _CurrentId;
        _ViewCurrent = incoming;
    }

    private void OnSelect(Guid id) => _SelectedId = id;

    private void OnCrumbClicked(int index)
    {
        // Drill back up to the clicked step (container or logic node).
        if (index < _Crumbs.Count - 1)
        {
            _Crumbs     = _Crumbs.GetRange(0, index + 1);
            _SelectedId = Guid.Empty;
            _Mode       = EditorMode.Edit;
            RebuildNodes();
        }
    }

    // ── Drill-down / connections ───────────────────────────────────────────

    /// <summary>Double-click a node: a container opens its inner graph; a logic node opens its content graph.</summary>
    private void OnNodeActivated(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Container:
                if (!Project.ContainerNodes.TryGetValue(node.Id, out StoryContainerNode? child)) return;
                _Crumbs.Add(new EditorCrumb(child.Id, child.Name, EditorScope.Container));
                break;

            case StoryNodeKind.Logic:
                if (!Project.LogicNodes.TryGetValue(node.Id, out StoryLogicNode? logic)) return;
                _Crumbs.Add(new EditorCrumb(logic.Id, logic.Name, EditorScope.Logic));
                break;

            case StoryNodeKind.BlueprintInstance:
                // Drill into the shared definition — edits here apply to every instance — in its own breadcrumb trail.
                if (!Project.BlueprintInstances.TryGetValue(node.Id, out StoryBlueprintInstanceNode? bpInst)) return;
                if (!Project.Blueprints.TryGetValue(bpInst.BlueprintId, out StoryBlueprint? bpDef)) return;
                BeginBlueprintTrail(bpDef.DefinitionNodeId, bpDef.Name,
                    bpDef.Kind == StoryBlueprintKind.Container ? EditorScope.Container : EditorScope.Logic);
                RebuildNodes();
                return;

            case StoryNodeKind.FunctionInstance:
                if (_CurrentLogicNode?.FunctionInstanceNodes.Find(n => n.Id == node.Id) is not StoryFunctionInstanceNode fnInst) return;
                if (!Project.Blueprints.TryGetValue(fnInst.BlueprintId, out StoryBlueprint? fnDef)) return;
                BeginBlueprintTrail(fnDef.DefinitionNodeId, fnDef.Name, EditorScope.Logic);
                RebuildNodes();
                return;

            default:
                return;
        }

        _SelectedId = Guid.Empty;
        _Mode       = EditorMode.Edit;
        RebuildNodes();
    }

    /// <summary>
    /// Context-menu "Preview": a logic node previews itself; a container or the Root's Start follows the flow inward to
    /// the first logic node it reaches and previews that.
    /// </summary>
    private void OnNodePreview(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Logic when Project.LogicNodes.TryGetValue(node.Id, out StoryLogicNode? logic):
                PreviewLogicNode(logic);
                break;

            // A container node's entry points are its input ports; Start is itself an entry point (Id == point id).
            case StoryNodeKind.Container:
                PreviewFromEntry(node.Inputs.Count > 0 ? node.Inputs[0].Id : Guid.Empty);
                break;

            case StoryNodeKind.Start:
                PreviewFromEntry(node.Id);
                break;

            // An instance previews as itself, not as the shared definition: a Logic one plays this instance's own clone
            // (so its upstream resolves to what *this* instance is wired to), a Container one follows its first entry in.
            case StoryNodeKind.BlueprintInstance
                when Project.BlueprintInstances.TryGetValue(node.Id, out StoryBlueprintInstanceNode? inst)
                  && Project.Blueprints.TryGetValue(inst.BlueprintId, out StoryBlueprint? bp):
                if (bp.Kind == StoryBlueprintKind.Logic && CloneOf(inst.Id, bp.DefinitionNodeId) is StoryLogicNode clone)
                {
                    _PreviewVars = new Dictionary<Guid, string>();
                    EnterPreview(clone, expanded: true, replaceCrumb: false);
                    RebuildNodes();
                }
                else if (bp.Kind == StoryBlueprintKind.Container && node.Inputs.Count > 0)
                    PreviewFromEntry(node.Inputs[0].Id);
                break;
        }
    }

    /// <summary>
    /// Resolves the first logic node reached from an entry/Start point and, if any, opens it in Preview. The flattened
    /// project is the story as played, so it is tried first; only an entry that exists nowhere in it — a blueprint
    /// definition's own boundary, reached by previewing the definition on its own — falls back to authoring space.
    /// </summary>
    private void PreviewFromEntry(Guid entryPointId)
    {
        StoryFlowNavigator.NextLogicResult result = StoryFlowNavigator.ResolveNextLogicFromEntry(_ProjectState.GetExpandedProject(), entryPointId);
        bool expanded = true;

        if (result.Kind == StoryFlowNavigator.NextKind.Dangling)
        {
            result   = StoryFlowNavigator.ResolveNextLogicFromEntry(_ProjectState.GetFunctionExpanded().Project, entryPointId);
            expanded = false;
        }

        if (result is { Kind: StoryFlowNavigator.NextKind.Logic, Logic: not null })
        {
            _PreviewVars = new Dictionary<Guid, string>();
            EnterPreview(result.Logic, expanded, replaceCrumb: false);
            RebuildNodes();
        }
    }

    /// <summary>
    /// Previews an <b>authoring</b> node: a story node plays as its flattened self, while a blueprint definition — which
    /// has no clone to play — previews in authoring space with its functions inlined.
    /// </summary>
    private void PreviewLogicNode(StoryLogicNode logic)
    {
        _PreviewVars = new Dictionary<Guid, string>();
        EnterPreview(logic, PreviewIsExpanded(logic), replaceCrumb: false);
        RebuildNodes();
    }

    /// <summary>
    /// Which space an <b>authoring</b> node previews in: expanded when the played story reaches it (expansion keeps a
    /// story node's id, so the same id names it there), otherwise authoring space with functions inlined — a blueprint
    /// definition is out of tree and so has no clone to play.
    /// </summary>
    private bool PreviewIsExpanded(StoryLogicNode logic) =>
        _ProjectState.GetExpandedProject().LogicNodes.ContainsKey(logic.Id);

    /// <summary>
    /// Starts (or advances) a preview session on <paramref name="logic"/>, a node of the <paramref name="expanded"/>
    /// space. The graph behind the preview still shows an authoring node — a clone has nothing to open — so the
    /// breadcrumb follows the node it was cloned from, landing where a double-click on the instance would.
    /// </summary>
    private void EnterPreview(StoryLogicNode logic, bool expanded, bool replaceCrumb)
    {
        _PreviewNodeId   = logic.Id;
        _PreviewExpanded = expanded;

        StoryLogicNode crumb = AuthoringNodeFor(logic) ?? logic;
        if (crumb.ParentContainer == Guid.Empty && BlueprintOf(crumb.Id) is StoryBlueprint bp)
            BeginBlueprintTrail(bp.DefinitionNodeId, bp.Name, EditorScope.Logic);
        else if (replaceCrumb) _Crumbs[^1] = new EditorCrumb(crumb.Id, crumb.Name, EditorScope.Logic);
        else _Crumbs.Add(new EditorCrumb(crumb.Id, crumb.Name, EditorScope.Logic));

        _SelectedId      = Guid.Empty;
        _PreviewGamebook = false;
        _PreviewNotice   = null;
        _GbpScrollKey    = null;
        _Mode            = EditorMode.Preview;
    }

    /// <summary>The flattened clone <paramref name="instanceId"/> contributed for <paramref name="definitionNodeId"/>, if any.</summary>
    private StoryLogicNode? CloneOf(Guid instanceId, Guid definitionNodeId)
    {
        StoryBlueprintExpander.ExpandResult expanded = _ProjectState.GetExpanded();
        foreach (KeyValuePair<Guid, (Guid InstanceId, Guid DefinitionNodeId)> kv in expanded.Origin)
            if (kv.Value.InstanceId == instanceId && kv.Value.DefinitionNodeId == definitionNodeId
                && expanded.Project.LogicNodes.TryGetValue(kv.Key, out StoryLogicNode? clone))
                return clone;
        return null;
    }

    /// <summary>The blueprint whose definition body is <paramref name="definitionNodeId"/>, or null when it is a story node.</summary>
    private StoryBlueprint? BlueprintOf(Guid definitionNodeId) =>
        Project.Blueprints.Values.FirstOrDefault(b => b.DefinitionNodeId == definitionNodeId);

    /// <summary>
    /// The authoring node behind <paramref name="node"/> — itself when it is one, otherwise the shared definition its
    /// per-instance clone was made from. Used for breadcrumbs only: the preview itself never leaves its own space.
    /// </summary>
    private StoryLogicNode? AuthoringNodeFor(StoryLogicNode node)
    {
        if (Project.LogicNodes.TryGetValue(node.Id, out StoryLogicNode? own)) return own;
        return _ProjectState.GetExpanded().Origin.TryGetValue(node.Id, out (Guid InstanceId, Guid DefinitionNodeId) origin)
            && Project.LogicNodes.TryGetValue(origin.DefinitionNodeId, out StoryLogicNode? definition)
                ? definition
                : null;
    }


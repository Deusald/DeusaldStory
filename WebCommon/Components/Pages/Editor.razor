@page "/editor"
@layout EmptyLayout
@namespace DeusaldStoryWeb.Components.Pages
@inject UiLocalizationService Loc
@inject ProjectStateService _ProjectState
@inject NavigationManager   _Nav
@implements IDisposable

@if (!_ProjectState.HasProject)
{
    return;
}

<div class="ed-page">

    <EditorTopBar Mode="_Mode"
                  ModeChanged="OnModeChanged"
                  Crumbs="_Crumbs"
                  CrumbClicked="OnCrumbClicked"
                  InLogicNode="_InLogic"
                  OnRefreshLocalization="OnRefreshLocalization"/>

    <div class="ed-body">

        <EditorRail @ref="_Rail" OnToolSelected="OnToolSelected"/>

        @if (_ActiveTool == EditorRail.Tool.Media)
        {
            @* The images library spans the whole centre (graph + inspector); only the rail stays. *@
            <ImagesPanel/>
        }
        else if (_ActiveTool == EditorRail.Tool.Localization)
        {
            @* The localization browser spans the whole centre; refresh re-projects the graph behind it. *@
            <LocalizationPanel OnRefresh="OnRefreshLocalization"/>
        }
        else if (_ActiveTool == EditorRail.Tool.Variables)
        {
            @* The variables editor spans the whole centre (list + edit); only the rail stays. *@
            <VariablesPanel/>
        }
        else if (_ActiveTool == EditorRail.Tool.Problems)
        {
            @* The problems list spans the whole centre; clicking a row navigates the graph behind it. *@
            <ProblemsPanel OnNavigate="OnProblemNavigate"/>
        }
        else
        {
            <div class="ed-stage">
                @if (_Mode == EditorMode.Edit)
                {
                    <EditorGraph @ref="_GraphRef"
                                 Nodes="_Nodes"
                                 Edges="_Edges"
                                 GraphId="_CurrentId"
                                 InitialViewport="_ViewCurrent"
                                 SelectedId="_SelectedId"
                                 SelectedChanged="OnSelect"
                                 OnAddNode="OnAddNode"
                                 OnNodesMoved="OnNodesMoved"
                                 OnNodeActivated="OnNodeActivated"
                                 OnConnect="OnConnect"
                                 OnDisconnect="OnDisconnect"
                                 OnCanvasContextMenu="OnCanvasContextMenu"
                                 OnNodePreview="OnNodePreview"
                                 OnNodeDelete="OnNodeDelete"
                                 OnNodesDelete="OnNodesDelete"
                                 OnNodesCopy="OnNodesCopy"
                                 OnPaste="OnPaste"
                                 OnNodeAddPortalIn="OnNodeAddPortalIn"
                                 OnNodeReparent="OnNodeReparent"
                                 OnNodeMoveToParent="OnNodeMoveToParent"
                                 OnUndo="OnUndo"
                                 OnRedo="OnRedo"
                                 CanMoveToParent="@(!_InLogic && !IsRootContainer)"
                                 CanPaste="@CanPaste"/>
                }
                else if (_Mode == EditorMode.Preview && _PreviewLogic is StoryLogicNode previewLogic)
                {
                    <div class="ed-preview">
                        <div class="ed-preview-switch">
                            <button class="ed-preview-tab @(_PreviewGamebook ? "" : "active")" @onclick="() => SetPreviewKind(false)">
                                <i class="bi bi-phone"></i> @Loc.T(Localization.Editor.Page.previewTabApp)
                            </button>
                            <button class="ed-preview-tab @(_PreviewGamebook ? "active" : "")" @onclick="() => SetPreviewKind(true)">
                                <i class="bi bi-book"></i> @Loc.T(Localization.Editor.Page.previewTabGamebook)
                            </button>
                        </div>
                        @if (_PreviewNotice is not null)
                        {
                            <div class="ed-preview-notice">@_PreviewNotice</div>
                        }
                        <div class="ed-preview-body">
                            @if (_PreviewGamebook)
                            {
                                <GamebookPreview Logic="previewLogic"
                                                 Project="_PreviewProject"
                                                 OnNavigate="OnGamebookNavigate"
                                                 ScrollToKey="@_GbpScrollKey"/>
                            }
                            else
                            {
                                <LogicPreview Logic="previewLogic" Project="_PreviewProject" Values="_PreviewVars" OnContinue="OnPreviewContinue"/>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="ed-play">
                        <div class="ed-play-inner">
                            <i class="bi bi-play-circle"></i>
                            <div class="ed-play-title">@Loc.T(Localization.Editor.Page.playModeTitle)</div>
                            <div class="ed-play-sub">@Loc.T(Localization.Editor.Page.playModeSubtitle)</div>
                        </div>
                    </div>
                }
            </div>

            <div class="ed-inspector">
                @if (_Mode == EditorMode.Preview && _PreviewLogic is StoryLogicNode inspectLogic)
                {
                    @* In App preview the inspector becomes the variables tweak panel; in Gamebook it shows a read-only note. *@
                    @* Project is the session's own — seeding must key values exactly as the renderer reads them. *@
                    <PreviewVariablesPanel Logic="inspectLogic" Project="_PreviewProject" Values="_PreviewVars" ValuesChanged="StateHasChanged" Gamebook="_PreviewGamebook"/>
                }
                else
                {
                    @* Everything a node exposes is edited here, applied live — there are no per-node modals. *@
                    <EditorInspector Node="_SelectedNode"
                                     Logic="@(_InLogic ? _CurrentLogicNode : null)"
                                     OwnerId="_CurrentId"
                                     OnChanged="OnInspectorChanged"
                                     OnPickKey="OpenKeyPicker"
                                     OnPickIcon="OpenIconPicker"/>
                }
            </div>
        }

    </div>
</div>

<NodePaletteModal           @ref="_NodePalette"        OnSelect="OnPaletteSelect"/>
<LocalizationKeyPickerModal @ref="_LocalizationPicker" OnConfirm="OnLocalizationPicked"/>
<IconPickerModal            @ref="_IconPicker"         OnConfirm="OnIconPicked"/>

@code {
    private EditorMode        _Mode = EditorMode.Edit;
    private EditorRail.Tool   _ActiveTool = EditorRail.Tool.Graph;
    private EditorRail?        _Rail;

    private Guid              _SelectedId;

    private EditorGraph? _GraphRef; // the live graph (present only in Edit mode)

    // Viewport memory. We remember the pan/zoom of the graph currently shown (_ViewCurrent) and of exactly one
    // graph before it (_ViewPrev). So toggling between two graphs (or Edit/Preview of the same graph) restores each,
    // but stepping to a third graph and back to the older one reopens it at the default view — only the last-opened
    // graph is remembered. A brand-new graph opens at DefaultViewport.
    private static readonly GraphViewport DefaultViewport = new(24, 28, 1);

    private Guid           _ViewGraphId = Guid.Empty;  // graph _ViewCurrent belongs to
    private GraphViewport  _ViewCurrent = DefaultViewport;
    private Guid           _ViewPrevId  = Guid.Empty;   // the one remembered previous graph
    private GraphViewport? _ViewPrev;
    private List<EditorCrumb> _Crumbs = [];
    private List<EdNode>      _Nodes  = [];
    private List<EdEdge>      _Edges  = [];

    private NodePaletteModal?           _NodePalette;
    private LocalizationKeyPickerModal? _LocalizationPicker;
    private IconPickerModal?            _IconPicker;

    // Where the next created node is placed — the right-clicked canvas point (or a staggered default).
    private double _PendingX;
    private double _PendingY;

    // Transient External Variable values driving the logic-node preview (variable id → value). Reset on each
    // entry into Preview so a fresh render starts from the variables' defaults; shared with the inspector panel.
    private Dictionary<Guid, string> _PreviewVars = new();

    // Which preview is showing (false = App, true = Gamebook), and a transient notice for App continue clicks
    // that don't navigate (reaches End / an unwired exit).
    private bool    _PreviewGamebook;
    private string? _PreviewNotice;

    // The Gamebook section a "go to section" click asked to scroll to (cleared once the preview has scrolled there).
    private string? _GbpScrollKey;

    private EdNode? _SelectedNode => _Nodes.Find(n => n.Id == _SelectedId);

    private StoryProject Project => _ProjectState.CurrentProject!;

    // ── Current location (derived from the last breadcrumb) ─────────────────
    private EditorScope _Scope     => _Crumbs.Count > 0 ? _Crumbs[^1].Scope : EditorScope.Container;
    private Guid        _CurrentId => _Crumbs.Count > 0 ? _Crumbs[^1].Id    : Project.Metadata.RootStoryContainerNodeId;
    private bool        _InLogic   => _Scope == EditorScope.Logic;

    /// <summary>The logic node whose inner graph is currently open, or null when a container is open.</summary>
    private StoryLogicNode? _CurrentLogicNode =>
        _InLogic && Project.LogicNodes.TryGetValue(_CurrentId, out StoryLogicNode? logic) ? logic : null;

    // ── Preview session ────────────────────────────────────────────────────

    /// <summary>The id of the previewed node.</summary>
    private Guid _PreviewNodeId;

    private StoryProject _PreviewProject => Project;

    /// <summary>The node being previewed, resolved in its own space.</summary>
    private StoryLogicNode? _PreviewLogic =>
        _PreviewProject.LogicNodes.TryGetValue(_PreviewNodeId, out StoryLogicNode? logic) ? logic : null;

    protected override void OnInitialized()
    {
        if (!_ProjectState.HasProject)
        {
            // Opened /editor directly with nothing loaded — send the user back to pick a project.
            _Nav.NavigateTo(_Nav.BaseUri);
            return;
        }

        Guid root = Project.Metadata.RootStoryContainerNodeId;
        _Crumbs   = [new EditorCrumb(root, RootName())];
        RebuildNodes();

        // An Undo/Redo (from the toolbar or a keyboard shortcut) reverts the model out-of-band — rebuild the view.
        _ProjectState.HistoryApplied += OnHistoryApplied;
    }

    public void Dispose() => _ProjectState.HistoryApplied -= OnHistoryApplied;

    private void OnUndo() => _ProjectState.Undo();
    private void OnRedo() => _ProjectState.Redo();

    /// <summary>The model was reverted by Undo/Redo — drop any breadcrumbs / selection that no longer exist and rebuild.</summary>
    private void OnHistoryApplied()
    {
        // Walk back out of any container/logic node that the reverted action removed (always keep the Root crumb).
        while (_Crumbs.Count > 1)
        {
            EditorCrumb tail  = _Crumbs[^1];
            bool        alive = tail.Scope == EditorScope.Logic
                ? Project.LogicNodes.ContainsKey(tail.Id)
                : Project.ContainerNodes.ContainsKey(tail.Id);
            if (alive) break;
            _Crumbs.RemoveAt(_Crumbs.Count - 1);
        }

        RebuildNodes();
        if (_Nodes.All(n => n.Id != _SelectedId)) _SelectedId = Guid.Empty;
        InvokeAsync(StateHasChanged);
    }

    private string RootName() =>
        Project.ContainerNodes.TryGetValue(Project.Metadata.RootStoryContainerNodeId, out StoryContainerNode? root)
            ? root.Name : Loc.T(Localization.Editor.Page.rootFallbackName);

    private bool IsRootContainer => _CurrentId == Project.Metadata.RootStoryContainerNodeId;

    /// <summary>Re-projects the current location (a container's graph or a logic node's inner graph) into view models.</summary>
    private void RebuildNodes()
    {
        SyncViewportOnNavigation();

        if (_Scope == EditorScope.Logic)
        {
            if (Project.LogicNodes.TryGetValue(_CurrentId, out StoryLogicNode? logic))
            {
                _Nodes = EditorProjection.BuildLogicNodes(Project, logic, _ProjectState.CurrentLocalization);
                _Edges = EditorProjection.BuildLogicEdges(logic);
            }
            else
            {
                _Nodes = [];
                _Edges = [];
            }
            return;
        }

        if (!Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? container))
        {
            _Nodes = [];
            _Edges = [];
            return;
        }
        _Nodes = EditorProjection.BuildNodes(Project, container, IsRootContainer);
        _Edges = EditorProjection.BuildEdges(container);
    }

    private void OnModeChanged(EditorMode mode)
    {
        // Remember where the graph was panned/zoomed before it is swapped out, so returning to Edit reopens there.
        CaptureViewport();

        // Entering preview starts the External Variable tweaks fresh (panel re-seeds them to the defaults).
        if (mode == EditorMode.Preview)
        {
            // The tab always previews what is open right now — a session started earlier may have walked the flow far
            // from here, and its node must not linger. With a container open there is nothing to preview, so the id is
            // cleared and the pane falls back to its play-mode placeholder.
            _PreviewNodeId = _CurrentLogicNode is StoryLogicNode current ? current.Id : Guid.Empty;

            _PreviewVars     = new Dictionary<Guid, string>();
            _PreviewGamebook = false;
            _PreviewNotice   = null;
            _GbpScrollKey    = null;
        }
        _Mode = mode;
    }

    /// <summary>Switch the preview between the App screen and the printed Gamebook sections.</summary>
    private void SetPreviewKind(bool gamebook)
    {
        _PreviewGamebook = gamebook;
        _PreviewNotice   = null;
        _GbpScrollKey    = null;
    }

    /// <summary>
    /// App-preview "continue" — follow the clicked exit to the next logic node and preview it. Reaching the story
    /// End or an unwired exit shows a transient notice instead of navigating.
    /// </summary>
    private void OnPreviewContinue(StoryLogicRenderer.RenderedChoice choice)
    {
        // Everything here resolves in the session's own space — the clicked choice belongs to the node being rendered.
        StoryProject proj = _PreviewProject;
        StoryLogicNode? owner = proj.LogicNodes.Values.FirstOrDefault(l => l.Choices.Any(c => c.Id == choice.ChoiceId));

        // A Single-path node has no per-choice exit: every continuation leaves by the one shared output (the choice
        // only pins which variable values ride along it), so a per-choice port is unwired by design — following it
        // would report a connected exit as dangling.
        Guid fromPoint = owner is { ExitMode: StoryLogicExitMode.SinglePath } ? owner.SingleOut.Id : choice.OuterFlowOut;

        StoryFlowNavigator.NextLogicResult result = StoryFlowNavigator.ResolveNextLogic(proj, fromPoint);
        switch (result.Kind)
        {
            case StoryFlowNavigator.NextKind.Logic when result.Logic is not null:
                // The continuation carries the values its choice pinned, so the next node previews against exactly
                // what the player just chose.
                _PreviewVars = new Dictionary<Guid, string>(choice.Pins);
                EnterPreview(result.Logic, replaceCrumb: true);
                _PreviewNotice = null;
                RebuildNodes();
                break;

            case StoryFlowNavigator.NextKind.End:
                _PreviewNotice = Loc.T(Localization.Editor.Page.previewNoticeReachedEnd);
                break;

            default:
                _PreviewNotice = Loc.T(Localization.Editor.Page.previewNoticeExitNotConnected);
                break;
        }
    }

    /// <summary>
    /// Gamebook-preview "go to section" click — switch the preview to the line's target logic node (replacing the last
    /// breadcrumb, as the App continue does) and ask the preview to scroll that specific section to the top of the view.
    /// </summary>
    private void OnGamebookNavigate(GamebookNavRequest request)
    {
        // The section's target id comes from the preview's own project, so it is resolved there — a flattened clone is
        // not in the authoring dictionary at all.
        if (request.LogicId == Guid.Empty || !_PreviewProject.LogicNodes.TryGetValue(request.LogicId, out StoryLogicNode? target))
            return;

        if (request.LogicId != _PreviewNodeId)
        {
            bool gamebook = _PreviewGamebook;
            EnterPreview(target, replaceCrumb: true);
            _PreviewGamebook = gamebook; // EnterPreview starts a session on the App tab; this navigation stays in Gamebook.
            RebuildNodes();
        }
        _GbpScrollKey = request.SectionKey;
    }

    /// <summary>Rail tool picked — swap the centre panel. Only Media has its own panel; the rest keep the graph.</summary>
    private void OnToolSelected(EditorRail.Tool tool)
    {
        // Some rail tools take over the whole centre and unmount the graph — save its viewport first.
        CaptureViewport();

        _ActiveTool = tool;
    }

    /// <summary>Snapshots the live graph's pan/zoom so a later re-mount of the same graph (e.g. an Edit/Preview round-trip) reopens where it was left.</summary>
    private void CaptureViewport()
    {
        if (_GraphRef is not null) _ViewCurrent = _GraphRef.CurrentViewport;
    }

    /// <summary>
    /// Called after a navigation may have changed which graph is shown. If it did, remember the graph we just left as
    /// the single "previous" slot, then open the new graph where it was last left (only if it is that previous graph)
    /// or at the default view. Reading <see cref="EditorGraph.CurrentViewport"/> first captures the outgoing graph's
    /// latest pan (the graph card is still mounted at this point — the re-render happens after this returns).
    /// </summary>
    private void SyncViewportOnNavigation()
    {
        if (_CurrentId == _ViewGraphId) return; // same graph (an edit, not a navigation) — keep its viewport
        if (_GraphRef is not null) _ViewCurrent = _GraphRef.CurrentViewport;

        GraphViewport incoming = _CurrentId == _ViewPrevId && _ViewPrev is { } prev ? prev : DefaultViewport;
        _ViewPrevId  = _ViewGraphId;
        _ViewPrev    = _ViewCurrent;
        _ViewGraphId = _CurrentId;
        _ViewCurrent = incoming;
    }

    private void OnSelect(Guid id) => _SelectedId = id;

    private void OnCrumbClicked(int index)
    {
        // Drill back up to the clicked step (container or logic node).
        if (index < _Crumbs.Count - 1)
        {
            _Crumbs     = _Crumbs.GetRange(0, index + 1);
            _SelectedId = Guid.Empty;
            _Mode       = EditorMode.Edit;
            RebuildNodes();
        }
    }

    // ── Drill-down / connections ───────────────────────────────────────────

    /// <summary>Double-click a node: a container opens its inner graph; a logic node opens its content graph.</summary>
    private void OnNodeActivated(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Container:
                if (!Project.ContainerNodes.TryGetValue(node.Id, out StoryContainerNode? child)) return;
                _Crumbs.Add(new EditorCrumb(child.Id, child.Name, EditorScope.Container));
                break;

            case StoryNodeKind.Logic:
                if (!Project.LogicNodes.TryGetValue(node.Id, out StoryLogicNode? logic)) return;
                _Crumbs.Add(new EditorCrumb(logic.Id, logic.Name, EditorScope.Logic));
                break;

            default:
                return;
        }

        _SelectedId = Guid.Empty;
        _Mode       = EditorMode.Edit;
        RebuildNodes();
    }

    /// <summary>
    /// Context-menu "Preview": a logic node previews itself; a container or the Root's Start follows the flow inward to
    /// the first logic node it reaches and previews that.
    /// </summary>
    private void OnNodePreview(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Logic when Project.LogicNodes.TryGetValue(node.Id, out StoryLogicNode? logic):
                PreviewLogicNode(logic);
                break;

            // A container node's entry points are its input ports; Start is itself an entry point (Id == point id).
            case StoryNodeKind.Container:
                PreviewFromEntry(node.Inputs.Count > 0 ? node.Inputs[0].Id : Guid.Empty);
                break;

            case StoryNodeKind.Start:
                PreviewFromEntry(node.Id);
                break;
        }
    }

    /// <summary>Resolves the first logic node reached from an entry/Start point and, if any, opens it in Preview.</summary>
    private void PreviewFromEntry(Guid entryPointId)
    {
        StoryFlowNavigator.NextLogicResult result = StoryFlowNavigator.ResolveNextLogicFromEntry(Project, entryPointId);

        if (result is { Kind: StoryFlowNavigator.NextKind.Logic, Logic: not null })
        {
            _PreviewVars = new Dictionary<Guid, string>();
            EnterPreview(result.Logic, replaceCrumb: false);
            RebuildNodes();
        }
    }

    /// <summary>Opens <paramref name="logic"/> in Preview.</summary>
    private void PreviewLogicNode(StoryLogicNode logic)
    {
        _PreviewVars = new Dictionary<Guid, string>();
        EnterPreview(logic, replaceCrumb: false);
        RebuildNodes();
    }

    /// <summary>Starts (or advances) a preview session on <paramref name="logic"/>.</summary>
    private void EnterPreview(StoryLogicNode logic, bool replaceCrumb)
    {
        _PreviewNodeId = logic.Id;

        if (replaceCrumb) _Crumbs[^1] = new EditorCrumb(logic.Id, logic.Name, EditorScope.Logic);
        else _Crumbs.Add(new EditorCrumb(logic.Id, logic.Name, EditorScope.Logic));

        _SelectedId      = Guid.Empty;
        _PreviewGamebook = false;
        _PreviewNotice   = null;
        _GbpScrollKey    = null;
        _Mode            = EditorMode.Preview;
    }

    /// <summary>Wire an output port to an input port in the current graph (container or logic content).</summary>
    private void OnConnect(EdConnectRequest request)
    {
        if (_InLogic) _ProjectState.ConnectContent(_CurrentId, request.FromPoint, request.ToPoint);
        else          _ProjectState.Connect(_CurrentId, request.FromPoint, request.ToPoint);
        RebuildNodes();
    }

    /// <summary>Remove a connection from the current graph.</summary>
    private void OnDisconnect(Guid connectionId)
    {
        if (_InLogic) _ProjectState.DisconnectContent(_CurrentId, connectionId);
        else          _ProjectState.Disconnect(_CurrentId, connectionId);
        RebuildNodes();
    }

    /// <summary>Re-read the linked localization project so new keys appear; refresh node titles.</summary>
    private async Task OnRefreshLocalization()
    {
        await _ProjectState.RefreshLocalizationAsync();
        RebuildNodes();
    }

    // ── Add node (palette → detail modal) ──────────────────────────────────

    /// <summary>Toolbar "Add node" — the graph supplies the current view centre; drop the node there.</summary>
    private async Task OnAddNode(CanvasPoint point)
    {
        (_PendingX, _PendingY) = await ClampDrop(point.X, point.Y, _DROP_FOOTPRINT_W, _DROP_FOOTPRINT_H);
        _NodePalette?.Show(PaletteItems());
    }

    /// <summary>Right-click on empty canvas — open the palette and remember where to drop the node.</summary>
    private async Task OnCanvasContextMenu(CanvasPoint point)
    {
        // Reaching the palette means the author chose "Add node" over "Paste" (or the clipboard was already empty), so
        // drop the clipboard — the next right-click then opens the palette straight away instead of the paste menu.
        _Clipboard.Clear();
        (_PendingX, _PendingY) = await ClampDrop(point.X, point.Y, _DROP_FOOTPRINT_W, _DROP_FOOTPRINT_H);
        _NodePalette?.Show(PaletteItems());
    }

    // Footprint used when clamping a new node into view. Wide/tall enough to also contain a portal *pair* (in + out,
    // separated by the portal gap) so a created portal's far point can never fall off-screen.
    private const double _DROP_FOOTPRINT_W = 540;
    private const double _DROP_FOOTPRINT_H = 120;

    /// <summary>
    /// Keeps a freshly created / pasted node inside the current view: returns (<paramref name="x"/>, <paramref name="y"/>)
    /// when a node of the given footprint dropped there fits fully in the visible canvas, otherwise the view centre
    /// (footprint-adjusted). Prevents nodes / portals from landing off-screen when the view is panned far away.
    /// </summary>
    private async Task<(double X, double Y)> ClampDrop(double x, double y, double footprintW, double footprintH)
    {
        if (_GraphRef is null) return (x, y);
        double[] v = await _GraphRef.VisibleWorldRectAsync(); // [x, y, width, height] in world coords
        const double margin = 20;
        bool fits = x >= v[0] + margin && x + footprintW <= v[0] + v[2] - margin
                 && y >= v[1] + margin && y + footprintH <= v[1] + v[3] - margin;
        if (fits) return (x, y);
        return (v[0] + (v[2] - footprintW) / 2, v[1] + (v[3] - footprintH) / 2);
    }

    /// <summary>
    /// The node kinds that can be added in the current context. Inside a container that means container, logic
    /// and portal nodes; inside a logic node's inner graph it means Localization and Icon content nodes.
    /// </summary>
    private List<NodePaletteItem> PaletteItems() =>
        _InLogic
            ?
            [
                new NodePaletteItem(StoryNodeKind.Text,                  "bi-text-paragraph", Loc.T(Localization.Editor.Palette.Items.flowTextLabel),              Loc.T(Localization.Editor.Palette.Items.flowTextDesc)),
                new NodePaletteItem(StoryNodeKind.SetVariable,           "bi-pencil-square",  Loc.T(Localization.Editor.Palette.Items.setVariableLabel),           Loc.T(Localization.Editor.Palette.Items.setVariableDesc)),
                new NodePaletteItem(StoryNodeKind.ConstantVariable,      "bi-braces",         Loc.T(Localization.Editor.Palette.Items.constantVariableLabel),      Loc.T(Localization.Editor.Palette.Items.constantVariableDesc)),
                new NodePaletteItem(StoryNodeKind.RandomizedInstruction, "bi-dice-5",         Loc.T(Localization.Editor.Palette.Items.randomizedInstructionLabel), Loc.T(Localization.Editor.Palette.Items.randomizedInstructionDesc)),
                new NodePaletteItem(StoryNodeKind.ConditionFlow,         "bi-signpost-split", Loc.T(Localization.Editor.Palette.Items.conditionLabel),             Loc.T(Localization.Editor.Palette.Items.conditionDesc)),
                new NodePaletteItem(StoryNodeKind.SplitForApp,           "bi-scissors",       Loc.T(Localization.Editor.Palette.Items.splitForAppLabel),           Loc.T(Localization.Editor.Palette.Items.splitForAppDesc)),
                new NodePaletteItem(StoryNodeKind.Comment,               "bi-chat-left-text", Loc.T(Localization.Editor.Palette.Items.commentLabel),               Loc.T(Localization.Editor.Palette.Items.commentDesc))
            ]
            :
            [
                new NodePaletteItem(StoryNodeKind.Logic,     "bi-diamond-half",       Loc.T(Localization.Editor.Palette.Items.logicLabel),     Loc.T(Localization.Editor.Palette.Items.logicDesc)),
                new NodePaletteItem(StoryNodeKind.Container, "bi-collection",         Loc.T(Localization.Editor.Palette.Items.containerLabel), Loc.T(Localization.Editor.Palette.Items.containerDesc)),
                new NodePaletteItem(StoryNodeKind.PortalIn,  "bi-box-arrow-in-right", Loc.T(Localization.Editor.Palette.Items.portalLabel),    Loc.T(Localization.Editor.Palette.Items.portalDesc)),
                new NodePaletteItem(StoryNodeKind.Comment,   "bi-chat-left-text",     Loc.T(Localization.Editor.Palette.Items.commentLabel),   Loc.T(Localization.Editor.Palette.Items.commentDesc))
            ];

    /// <summary>
    /// Creates the picked node kind with default values at the click position and selects it — everything about it
    /// is then configured in the inspector, so there is no creation dialog.
    /// </summary>
    private void OnPaletteSelect(NodePaletteItem item)
    {
        Guid created = item.Kind switch
        {
            StoryNodeKind.Logic     => _ProjectState.AddLogicNode(_CurrentId, Loc.T(Localization.Editor.Nodes.Labels.logic), "", new StoryConnectionPoint { Name = "In" }, _PendingX, _PendingY).Id,
            StoryNodeKind.Container => AddContainerWithBoundary(),
            StoryNodeKind.PortalIn  => _ProjectState.AddPortalNode(_CurrentId, Loc.T(Localization.Editor.Nodes.Labels.portalIn), "", _PendingX, _PendingY)?.InPoints[0].Id ?? Guid.Empty,

            StoryNodeKind.Text                  => _ProjectState.AddTextNode(_CurrentId, _PendingX, _PendingY)?.Id                  ?? Guid.Empty,
            StoryNodeKind.SetVariable           => _ProjectState.AddSetVariableNode(_CurrentId, _PendingX, _PendingY)?.Id           ?? Guid.Empty,
            StoryNodeKind.ConstantVariable      => _ProjectState.AddConstantVariableNode(_CurrentId, _PendingX, _PendingY)?.Id      ?? Guid.Empty,
            StoryNodeKind.RandomizedInstruction => _ProjectState.AddRandomizedInstructionNode(_CurrentId, _PendingX, _PendingY)?.Id ?? Guid.Empty,
            StoryNodeKind.SplitForApp           => _ProjectState.AddSplitForAppNode(_CurrentId, _PendingX, _PendingY)?.Id           ?? Guid.Empty,
            StoryNodeKind.ConditionFlow         => _ProjectState.AddConditionFlowNode(_CurrentId, _PendingX, _PendingY)?.Id         ?? Guid.Empty,
            StoryNodeKind.Comment               => _ProjectState.AddCommentNode(_CurrentId, "", _PendingX, _PendingY)?.Id           ?? Guid.Empty,

            _ => Guid.Empty
        };

        if (created != Guid.Empty) _SelectedId = created;
        RebuildNodes();
    }

    /// <summary>Creates a child container seeded with one entry and one exit, so it can be wired straight away.</summary>
    private Guid AddContainerWithBoundary()
    {
        using (_ProjectState.BeginBatch())
        {
            StoryContainerNode container = _ProjectState.AddContainerNode(
                _CurrentId, Loc.T(Localization.Editor.Nodes.Labels.container), "",
                [new StoryConnectionPoint { Name = "In" }], [new StoryConnectionPoint { Name = "Out" }],
                _PendingX, _PendingY);
            return container.Id;
        }
    }

    /// <summary>An inspector edit landed — the canvas cards show names/summaries, so they need rebuilding.</summary>
    private void OnInspectorChanged()
    {
        RebuildNodes();
        StateHasChanged();
    }

    // ── Pickers opened from the inspector ──────────────────────────────────

    // Which text/icon slot the open picker is filling; the inspector hands us a setter to apply the pick to.
    private Action<Guid>? _PendingPick;

    /// <summary>Opens the localization-key picker for an inspector field, applying the pick through <paramref name="apply"/>.</summary>
    private void OpenKeyPicker((Guid Current, Action<Guid> Apply) request)
    {
        _PendingPick = request.Apply;
        _LocalizationPicker?.Show(Guid.Empty, request.Current);
    }

    /// <summary>Opens the icon picker for an inspector slot, applying the pick through <paramref name="apply"/>.</summary>
    private void OpenIconPicker((Guid Current, Action<Guid> Apply) request)
    {
        _PendingPick = request.Apply;
        _IconPicker?.Show(Guid.Empty, request.Current);
    }

    private void OnLocalizationPicked(LocalizationKeyPickerModal.LocalizationPickResult result)
    {
        _PendingPick?.Invoke(result.KeyId);
        _PendingPick = null;
        RebuildNodes();
    }

    private void OnIconPicked(IconPickerModal.IconPickResult result)
    {
        _PendingPick?.Invoke(result.ImageId);
        _PendingPick = null;
        RebuildNodes();
    }

    /// <summary>Navigate to the graph location a validation problem points at (open its container, drill into the
    /// logic node if it's an inner-graph issue, and select the offending node).</summary>
    private void OnProblemNavigate(StoryProblem problem)
    {
        // Rebuild the full breadcrumb path: Root / …containers… / (logic node). The Root crumb must always be
        // present so the user can walk back up, matching how normal drill-down keeps Root as the first crumb.
        Guid                     rootId = Project.Metadata.RootStoryContainerNodeId;
        List<EditorCrumb>        crumbs = [new EditorCrumb(rootId, RootName())];
        List<StoryContainerNode> chain  = new();
        Guid                     cur    = problem.ContainerId;
        int                      guard  = 0;
        while (cur != Guid.Empty
               && cur != rootId
               && Project.ContainerNodes.TryGetValue(cur, out StoryContainerNode? c)
               && guard++ < 64)
        {
            chain.Add(c);
            cur = c.ParentContainer;
        }
        chain.Reverse();
        foreach (StoryContainerNode c in chain)
            crumbs.Add(new EditorCrumb(c.Id, c.Name, EditorScope.Container));

        if (problem.LogicNodeId != Guid.Empty && problem.InnerNodeId != Guid.Empty
            && Project.LogicNodes.TryGetValue(problem.LogicNodeId, out StoryLogicNode? lg))
        {
            crumbs.Add(new EditorCrumb(lg.Id, lg.Name, EditorScope.Logic));
            _SelectedId = problem.InnerNodeId;
        }
        else if (problem.LogicNodeId != Guid.Empty)
        {
            _SelectedId = problem.LogicNodeId;
        }
        else
        {
            _SelectedId = Guid.Empty;
        }

        _Crumbs     = crumbs;
        _ActiveTool = EditorRail.Tool.Graph;
        _Mode       = EditorMode.Edit;
        RebuildNodes();
    }

    /// <summary>The comment note with <paramref name="id"/> in the current graph (container graph or logic inner graph).</summary>
    private StoryCommentNode? FindComment(Guid id) =>
        _InLogic
            ? _CurrentLogicNode?.CommentNodes.Find(n => n.Id == id)
            : Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? c) ? c.Comments.Find(n => n.Id == id) : null;

    // ── Node context menu (delete) ─────────────────────────────────────────

    /// <summary>Delete from a node's context menu. Deleting a container removes everything nested inside it.</summary>
    private void OnNodeDelete(EdNode node)
    {
        DeleteOne(node);
        if (_SelectedId == node.Id) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>Delete every node in <paramref name="nodes"/> (a multi-selection) as one atomic, undoable step.</summary>
    private void OnNodesDelete(IReadOnlyList<EdNode> nodes)
    {
        using (_ProjectState.BeginBatch())
            foreach (EdNode node in nodes)
                DeleteOne(node);

        if (nodes.Any(n => n.Id == _SelectedId)) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>Removes one node from the model, dispatched by kind. Does not touch selection / rebuild (the caller does).</summary>
    private void DeleteOne(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Logic:     _ProjectState.DeleteLogicNode(_CurrentId, node.Id);     break;
            case StoryNodeKind.Container: _ProjectState.DeleteContainerNode(_CurrentId, node.Id); break;
            case StoryNodeKind.PortalIn:  _ProjectState.DeletePortalIn(_CurrentId, node.Id);      break;
            case StoryNodeKind.PortalOut:
                if (_ProjectState.FindPortalByPoint(node.Id) is StoryPortalNode portal)
                    _ProjectState.DeletePortal(_CurrentId, portal.Id);
                break;

            case StoryNodeKind.Text:                  _ProjectState.DeleteTextNode(_CurrentId, node.Id);                  break;
            case StoryNodeKind.SetVariable:           _ProjectState.DeleteSetVariableNode(_CurrentId, node.Id);           break;
            case StoryNodeKind.ConstantVariable:      _ProjectState.DeleteConstantVariableNode(_CurrentId, node.Id);      break;
            case StoryNodeKind.RandomizedInstruction: _ProjectState.DeleteRandomizedInstructionNode(_CurrentId, node.Id); break;
            case StoryNodeKind.SplitForApp:           _ProjectState.DeleteSplitForAppNode(_CurrentId, node.Id);           break;

            // Either half of a Condition pair deletes the whole pair.
            case StoryNodeKind.ConditionFlow:
            case StoryNodeKind.EndConditionFlow:      _ProjectState.DeleteConditionFlowNode(_CurrentId, node.Id);         break;

            case StoryNodeKind.Comment:               _ProjectState.DeleteCommentNode(_CurrentId, node.Id);               break;
        }
    }

    // ── Copy / paste ────────────────────────────────────────────────────────

    // The copy buffer: the canvas node ids that were copied, and the scope they came from (a container's graph or a
    // logic node's inner graph). Paste only pastes into a matching scope. Ids are resolved against the live project at
    // paste time, so a copy carries no snapshot — deleting the originals before pasting simply yields nothing.
    private List<Guid>  _Clipboard        = [];
    private EditorScope _ClipboardScope   = EditorScope.Container;
    private Guid        _ClipboardOwnerId = Guid.Empty; // the graph (container / logic node) the copy was taken from — inner nodes only resolve against their owner

    /// <summary>Whether the clipboard holds something that can be pasted into the current graph (same scope) — drives the canvas Paste option.</summary>
    private bool CanPaste => _Clipboard.Count > 0 && _ClipboardScope == _Scope;

    /// <summary>Copy the selected nodes to the clipboard (Ctrl/Cmd+C).</summary>
    private void OnNodesCopy(IReadOnlyList<EdNode> nodes)
    {
        // Boundary/built-in nodes (Start/End/Entry/Exit, logic Entry/Exit, Prev Exit) can't be copied — skip them.
        _Clipboard        = nodes.Where(n => n.Deletable).Select(n => n.Id).ToList();
        _ClipboardScope   = _Scope;
        _ClipboardOwnerId = _CurrentId;
    }

    /// <summary>Paste the clipboard into the current graph, offset from the originals (Ctrl/Cmd+V).</summary>
    private void OnPaste()
    {
        if (_Clipboard.Count == 0 || _ClipboardScope != _Scope) return;

        List<Guid> pasted = _InLogic
            ? _ProjectState.PasteLogicInnerNodes(_ClipboardOwnerId, _CurrentId, _Clipboard, _PASTE_OFFSET, _PASTE_OFFSET)
            : _ProjectState.PasteContainerNodes(_CurrentId, _Clipboard, _PASTE_OFFSET, _PASTE_OFFSET);

        // Select every pasted node so the author can drag the whole group at once (a single node stays the primary
        // selection so the inspector fills in; two or more become a multi-selection like a marquee).
        _SelectedId = pasted.Count == 1 ? pasted[0] : Guid.Empty;
        RebuildNodes();
        _GraphRef?.SelectGroup(pasted);
    }

    private const double _PASTE_OFFSET = 40;

    /// <summary>Add another portal-in to the pair the right-clicked portal node belongs to.</summary>
    private async Task OnNodeAddPortalIn(EdNode node)
    {
        if (node.Kind is not (StoryNodeKind.PortalIn or StoryNodeKind.PortalOut)) return;
        (double x, double y) = await ClampDrop(node.X, node.Y + 90, _NODE_W_APPROX, _NODE_H_APPROX);
        _ProjectState.AddPortalIn(node.Id, x, y);
        RebuildNodes();
    }

    private const double _NODE_W_APPROX = 216;
    private const double _NODE_H_APPROX = 82;

    // ── Reparent (drag onto a container / push up to parent) ────────────────

    /// <summary>A logic/container node was dropped onto a container — move it inside that container.</summary>
    private void OnNodeReparent(EdNodeReparent request)
    {
        if (!Project.ContainerNodes.TryGetValue(request.TargetContainerId, out StoryContainerNode? target)) return;
        (double x, double y) = DropSpot(target);
        _ProjectState.ReparentNode(_CurrentId, request.NodeId, request.TargetContainerId, x, y);

        // The node has left this graph — drop the selection so the inspector doesn't dangle.
        if (_SelectedId == request.NodeId) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>"Move to parent" — push a logic/container node up one level (never above the Root).</summary>
    private void OnNodeMoveToParent(EdNode node)
    {
        if (IsRootContainer) return;
        if (!Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? current)) return;
        if (!Project.ContainerNodes.TryGetValue(current.ParentContainer, out StoryContainerNode? parent)) return;

        (double x, double y) = DropSpot(parent);
        _ProjectState.ReparentNode(_CurrentId, node.Id, parent.Id, x, y);

        if (_SelectedId == node.Id) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>A staggered canvas position for a node arriving in <paramref name="container"/>, so drops don't stack.</summary>
    private static (double X, double Y) DropSpot(StoryContainerNode container)
    {
        int count = container.Containers.Count + container.Logic.Count;
        return (320 + count % 6 * 30, 140 + count % 6 * 26);
    }

    // ── Persist a drag ─────────────────────────────────────────────────────

    /// <summary>Persist a drag. The whole (possibly multi-selection) group is one atomic, undoable step.</summary>
    private void OnNodesMoved(IReadOnlyList<EdNode> moved)
    {
        using (_ProjectState.BeginBatch())
            foreach (EdNode node in moved)
                PersistMove(node);
    }

    private void PersistMove(EdNode moved)
    {
        // A comment note lives in either graph (container or logic inner); resolve it against the current owner.
        if (moved.Kind == StoryNodeKind.Comment)
        {
            _ProjectState.MoveCommentNode(_CurrentId, moved.Id, moved.X, moved.Y);
            return;
        }

        // Inside a logic node's inner graph — the Entry/Exit points or a content node moved.
        if (_InLogic)
        {
            _ProjectState.MoveLogicNode(_CurrentId, moved.Id, moved.X, moved.Y);
            return;
        }

        // A logic node moved.
        if (Project.LogicNodes.TryGetValue(moved.Id, out StoryLogicNode? logic))
        {
            logic.X = moved.X;
            logic.Y = moved.Y;
            _ProjectState.MarkKeyDirty(logic.Id);
            return;
        }

        // A child container moved.
        if (Project.ContainerNodes.TryGetValue(moved.Id, out StoryContainerNode? child))
        {
            child.X = moved.X;
            child.Y = moved.Y;
            _ProjectState.MarkKeyDirty(child.Id);
            return;
        }

        // A portal in/out node moved (its position lives on the portal's connection point).
        if (_ProjectState.FindPortalByPoint(moved.Id) is StoryPortalNode portal)
        {
            StoryConnectionPoint? point = portal.OutPoint.Id == moved.Id
                ? portal.OutPoint
                : portal.InPoints.Find(p => p.Id == moved.Id);
            if (point is not null)
            {
                point.X = moved.X;
                point.Y = moved.Y;
                _ProjectState.MarkKeyDirty(portal.Id);
            }
            return;
        }

        // A connection point (Start/End/Entry/Exit) of the current container moved.
        if (Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? container))
        {
            StoryConnectionPoint? point = container.EntryPoints.Find(p => p.Id == moved.Id)
                                       ?? container.ExitPoints.Find(p => p.Id == moved.Id);
            if (point is not null)
            {
                point.X = moved.X;
                point.Y = moved.Y;
                _ProjectState.MarkKeyDirty(container.Id);
            }
        }
    }
}

    /// <summary>
    /// Enters blueprint-editing mode: stash the story breadcrumb trail (once) and start a fresh trail rooted at the
    /// blueprint definition, so editing a blueprint shows just the blueprint — not the story path that reached it.
    /// </summary>
    private void BeginBlueprintTrail(Guid definitionNodeId, string name, EditorScope scope)
    {
        if (!_EditingBlueprint)
        {
            _StoryCrumbs      = _Crumbs;
            _EditingBlueprint = true;
        }
        _Crumbs     = [new EditorCrumb(definitionNodeId, name, scope)];
        _ActiveTool = EditorRail.Tool.Graph;
        _Mode       = EditorMode.Edit;
        _SelectedId = Guid.Empty;
        _Rail?.SetActive(EditorRail.Tool.Graph);
    }


    private void OnNewLogicNodeConfirmed(NewLogicNodeModal.NewLogicNodeArgs args)
    {
        if (args.EditId != Guid.Empty)
        {
            // Use the node's real parent (Empty for an out-of-tree blueprint definition), not the current graph.
            Guid parent = Project.LogicNodes.TryGetValue(args.EditId, out StoryLogicNode? l) ? l.ParentContainer : _CurrentId;
            _ProjectState.UpdateLogicNode(
                parent, args.EditId, args.Name, args.Description,
                args.GamebookInstructions, args.ExitMode, args.AcceptVariables, args.DeclaredVariables, args.ExpectedVariables);
            RebuildNodes();
            _SelectedId = args.EditId;
            return;
        }

        StoryConnectionPoint entry = new() { Name = Loc.T(Localization.Editor.Page.defaultEntryPointName) };
        StoryLogicNode node = _ProjectState.AddLogicNode(
            _CurrentId, args.Name, args.Description, entry, _PendingX, _PendingY,
            args.GamebookInstructions, args.ExitMode, args.AcceptVariables);
        // Declared variables (SinglePath) are reconciled through the update path.
        _ProjectState.UpdateLogicNode(
            _CurrentId, node.Id, args.Name, args.Description,
            args.GamebookInstructions, args.ExitMode, args.AcceptVariables, args.DeclaredVariables);

        RebuildNodes();
        _SelectedId = node.Id;
    }

    private void OnNewContainerConfirmed(NewContainerNodeModal.NewContainerNodeArgs args)
    {
        if (args.EditId != Guid.Empty)
        {
            // Use the node's real parent (Empty for an out-of-tree blueprint definition), not the current graph.
            Guid parent = Project.ContainerNodes.TryGetValue(args.EditId, out StoryContainerNode? c) ? c.ParentContainer : _CurrentId;
            _ProjectState.UpdateContainerNode(
                parent, args.EditId, args.Name, args.Description, args.Entries, args.Exits);
            RebuildNodes();
            _SelectedId = args.EditId;
            return;
        }

        List<StoryConnectionPoint> entries = args.Entries.Select(e => new StoryConnectionPoint { Name = e.Name, FlowKind = e.Flow }).ToList();
        List<StoryConnectionPoint> exits   = args.Exits.Select(e => new StoryConnectionPoint { Name = e.Name, FlowKind = e.Flow }).ToList();

        StoryContainerNode node = _ProjectState.AddContainerNode(
            _CurrentId, args.Name, args.Description, entries, exits, _PendingX, _PendingY);

        RebuildNodes();
        _SelectedId = node.Id;
    }


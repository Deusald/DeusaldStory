    /// <summary>Opens the properties editor for a Container/Logic blueprint definition (name, ports/flow types, exit mode, options).</summary>
    private void OnEditBlueprintProperties(Guid blueprintId)
    {
        if (!Project.Blueprints.TryGetValue(blueprintId, out StoryBlueprint? bp)) return;

        if (bp.Kind == StoryBlueprintKind.Container
         && Project.ContainerNodes.TryGetValue(bp.DefinitionNodeId, out StoryContainerNode? cdef))
        {
            _NewContainerModal?.ShowEdit(cdef.Id, cdef.Name, cdef.Description,
                cdef.EntryPoints.Select(p => (p.Id, p.Name, p.FlowKind)),
                cdef.ExitPoints.Select(p => (p.Id, p.Name, p.FlowKind)));
        }
        else if (bp.Kind == StoryBlueprintKind.Logic
              && Project.LogicNodes.TryGetValue(bp.DefinitionNodeId, out StoryLogicNode? ldef))
        {
            _NewLogicNodeModal?.ShowEdit(ldef.Id, ldef.Name, ldef.Description,
                ldef.GamebookInstructions, ldef.ExitMode, ldef.AcceptVariables,
                ldef.DeclaredVariables.Select(d => (d.Id, d.Name, d.PossibleValues)),
                ldef.ExpectedVariables.Select(d => (d.Id, d.Name, d.PossibleValues)));
        }
    }


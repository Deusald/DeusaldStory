@page "/editor"
@layout EmptyLayout
@namespace DeusaldStoryWeb.Components.Pages
@inject ProjectStateService _ProjectState
@inject NavigationManager   _Nav

@if (!_ProjectState.HasProject)
{
    return;
}

<div class="ed-page">

    <EditorTopBar Mode="_Mode"
                  ModeChanged="OnModeChanged"
                  Crumbs="_Crumbs"
                  CrumbClicked="OnCrumbClicked"
                  InLogicNode="_InLogic"
                  OnRefreshLocalization="OnRefreshLocalization"/>

    <div class="ed-body">

        <EditorRail OnToolSelected="OnToolSelected"/>

        @if (_ActiveTool == EditorRail.Tool.Media)
        {
            @* The images library spans the whole centre (graph + inspector); only the rail stays. *@
            <ImagesPanel/>
        }
        else if (_ActiveTool == EditorRail.Tool.Localization)
        {
            @* The localization browser spans the whole centre; refresh re-projects the graph behind it. *@
            <LocalizationPanel OnRefresh="OnRefreshLocalization"/>
        }
        else if (_ActiveTool == EditorRail.Tool.Variables)
        {
            @* The variables editor spans the whole centre (list + edit); only the rail stays. *@
            <VariablesPanel/>
        }
        else if (_ActiveTool == EditorRail.Tool.Problems)
        {
            @* The problems list spans the whole centre; clicking a row navigates the graph behind it. *@
            <ProblemsPanel OnNavigate="OnProblemNavigate"/>
        }
        else
        {
            <div class="ed-stage">
                @if (_Mode == EditorMode.Edit)
                {
                    <EditorGraph Nodes="_Nodes"
                                 Edges="_Edges"
                                 SelectedId="_SelectedId"
                                 SelectedChanged="OnSelect"
                                 OnAddNode="OnAddNode"
                                 OnNodeMoved="OnNodeMoved"
                                 OnNodeActivated="OnNodeActivated"
                                 OnConnect="OnConnect"
                                 OnDisconnect="OnDisconnect"
                                 OnCanvasContextMenu="OnCanvasContextMenu"
                                 OnNodeEdit="OnNodeEdit"
                                 OnNodeDelete="OnNodeDelete"
                                 OnNodeAddPortalIn="OnNodeAddPortalIn"
                                 OnNodeReparent="OnNodeReparent"
                                 OnNodeMoveToParent="OnNodeMoveToParent"
                                 CanMoveToParent="@(!_InLogic && !IsRootContainer)"/>
                }
                else if (_Mode == EditorMode.Preview && _CurrentLogicNode is StoryLogicNode previewLogic)
                {
                    <div class="ed-preview">
                        <div class="ed-preview-switch">
                            <button class="ed-preview-tab @(_PreviewGamebook ? "" : "active")" @onclick="() => SetPreviewKind(false)">
                                <i class="bi bi-phone"></i> App
                            </button>
                            <button class="ed-preview-tab @(_PreviewGamebook ? "active" : "")" @onclick="() => SetPreviewKind(true)">
                                <i class="bi bi-book"></i> Gamebook
                            </button>
                        </div>
                        @if (_PreviewNotice is not null)
                        {
                            <div class="ed-preview-notice">@_PreviewNotice</div>
                        }
                        <div class="ed-preview-body">
                            @if (_PreviewGamebook)
                            {
                                <GamebookPreview Logic="previewLogic"/>
                            }
                            else
                            {
                                <LogicPreview Logic="previewLogic" Values="_PreviewVars" OnContinue="OnPreviewContinue"/>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="ed-play">
                        <div class="ed-play-inner">
                            <i class="bi bi-play-circle"></i>
                            <div class="ed-play-title">Play mode</div>
                            <div class="ed-play-sub">Step through the story from the start node. Runtime playback is coming next.</div>
                        </div>
                    </div>
                }
            </div>

            <div class="ed-inspector">
                @if (_Mode == EditorMode.Preview && _CurrentLogicNode is StoryLogicNode inspectLogic)
                {
                    @* In App preview the inspector becomes the variables tweak panel; in Gamebook it shows a read-only note. *@
                    <PreviewVariablesPanel Logic="inspectLogic" Values="_PreviewVars" ValuesChanged="StateHasChanged" Gamebook="_PreviewGamebook"/>
                }
                else if (_SelectedNode?.Kind == StoryNodeKind.End)
                {
                    @* The story End node: choose which whole-story storage variables are released here. *@
                    <EndUnregisterEditor/>
                }
                else if (_InLogic && _SelectedNode?.Kind is StoryNodeKind.RegisterVariable or StoryNodeKind.SetVariable or StoryNodeKind.UnregisterVariable)
                {
                    @* A storage-variable node: show its full configuration. *@
                    <VariableNodeInspector Logic="_CurrentLogicNode" NodeId="_SelectedId"/>
                }
                else
                {
                    <EditorInspector Node="_SelectedNode"/>
                }
            </div>
        }

    </div>
</div>

<NodePaletteModal          @ref="_NodePalette"         OnSelect="OnPaletteSelect"/>
<NewLogicNodeModal         @ref="_NewLogicNodeModal"   OnConfirm="OnNewLogicNodeConfirmed"/>
<NewContainerNodeModal     @ref="_NewContainerModal"   OnConfirm="OnNewContainerConfirmed"/>
<NewPortalNodeModal        @ref="_NewPortalModal"      OnConfirm="OnNewPortalConfirmed"/>
<LocalizationKeyPickerModal @ref="_LocalizationPicker" OnConfirm="OnLocalizationPicked"/>
<IconPickerModal           @ref="_IconPicker"          OnConfirm="OnIconPicked"/>
<VariablePickerModal       @ref="_VariablePicker"      OnConfirm="OnVariablePicked"/>
<RegisterVariableModal     @ref="_RegisterVariableModal" OnConfirm="OnRegisterVariableConfirmed"/>
<SetVariableModal          @ref="_SetVariableModal"      OnConfirm="OnSetVariableConfirmed"/>
<UnregisterVariablePickerModal @ref="_UnregisterPicker"  OnConfirm="OnUnregisterPicked"/>
<SetExternalVariableModal  @ref="_SetExternalVariableModal" OnConfirm="OnSetExternalVariableConfirmed"/>
<NewChoiceNodeModal        @ref="_NewChoiceNodeModal"       OnConfirm="OnChoiceConfirmed"/>
<PrevExitVariableModal     @ref="_PrevExitVariableModal"    OnConfirm="OnPrevExitVariableConfirmed"/>

@code {
    private EditorMode        _Mode = EditorMode.Edit;
    private EditorRail.Tool   _ActiveTool = EditorRail.Tool.Graph;
    private Guid              _SelectedId;
    private List<EditorCrumb> _Crumbs = [];
    private List<EdNode>      _Nodes  = [];
    private List<EdEdge>      _Edges  = [];

    private NodePaletteModal?          _NodePalette;
    private NewLogicNodeModal?         _NewLogicNodeModal;
    private NewContainerNodeModal?     _NewContainerModal;
    private NewPortalNodeModal?        _NewPortalModal;
    private LocalizationKeyPickerModal? _LocalizationPicker;
    private IconPickerModal?           _IconPicker;
    private VariablePickerModal?       _VariablePicker;
    private RegisterVariableModal?     _RegisterVariableModal;
    private SetVariableModal?          _SetVariableModal;
    private UnregisterVariablePickerModal? _UnregisterPicker;
    private SetExternalVariableModal?  _SetExternalVariableModal;
    private NewChoiceNodeModal?        _NewChoiceNodeModal;
    private PrevExitVariableModal?     _PrevExitVariableModal;

    // Where the next created node is placed — the right-clicked canvas point (or a staggered default).
    private double _PendingX;
    private double _PendingY;

    // Transient External Variable values driving the logic-node preview (variable id → value). Reset on each
    // entry into Preview so a fresh render starts from the variables' defaults; shared with the inspector panel.
    private Dictionary<Guid, string> _PreviewVars = new();

    // Which preview is showing (false = App, true = Gamebook), and a transient notice for App continue clicks
    // that don't navigate (reaches End / an unwired exit).
    private bool    _PreviewGamebook;
    private string? _PreviewNotice;

    private EdNode? _SelectedNode => _Nodes.Find(n => n.Id == _SelectedId);

    private StoryProject Project => _ProjectState.CurrentProject!;

    // ── Current location (derived from the last breadcrumb) ─────────────────
    private EditorScope _Scope     => _Crumbs.Count > 0 ? _Crumbs[^1].Scope : EditorScope.Container;
    private Guid        _CurrentId => _Crumbs.Count > 0 ? _Crumbs[^1].Id    : Project.Metadata.RootStoryContainerNodeId;
    private bool        _InLogic   => _Scope == EditorScope.Logic;

    /// <summary>The logic node whose inner graph is currently open, or null when a container is open.</summary>
    private StoryLogicNode? _CurrentLogicNode =>
        _InLogic && Project.LogicNodes.TryGetValue(_CurrentId, out StoryLogicNode? logic) ? logic : null;

    protected override void OnInitialized()
    {
        if (!_ProjectState.HasProject)
        {
            // Opened /editor directly with nothing loaded — send the user back to pick a project.
            _Nav.NavigateTo(_Nav.BaseUri);
            return;
        }

        Guid root = Project.Metadata.RootStoryContainerNodeId;
        _Crumbs   = [new EditorCrumb(root, RootName())];
        RebuildNodes();
    }

    private string RootName() =>
        Project.ContainerNodes.TryGetValue(Project.Metadata.RootStoryContainerNodeId, out StoryContainerNode? root)
            ? root.Name : "Root";

    private bool IsRootContainer => _CurrentId == Project.Metadata.RootStoryContainerNodeId;

    /// <summary>Re-projects the current location (a container's graph or a logic node's inner graph) into view models.</summary>
    private void RebuildNodes()
    {
        if (_Scope == EditorScope.Logic)
        {
            if (Project.LogicNodes.TryGetValue(_CurrentId, out StoryLogicNode? logic))
            {
                _Nodes = EditorProjection.BuildLogicNodes(Project, logic, _ProjectState.CurrentLocalization);
                _Edges = EditorProjection.BuildLogicEdges(logic);
            }
            else
            {
                _Nodes = [];
                _Edges = [];
            }
            return;
        }

        if (!Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? container))
        {
            _Nodes = [];
            _Edges = [];
            return;
        }
        _Nodes = EditorProjection.BuildNodes(Project, container, IsRootContainer);
        _Edges = EditorProjection.BuildEdges(container);
    }

    private void OnModeChanged(EditorMode mode)
    {
        // Entering preview starts the External Variable tweaks fresh (panel re-seeds them to the defaults).
        if (mode == EditorMode.Preview)
        {
            _PreviewVars     = new Dictionary<Guid, string>();
            _PreviewGamebook = false;
            _PreviewNotice   = null;
        }
        _Mode = mode;
    }

    /// <summary>Switch the preview between the App screen and the printed Gamebook sections.</summary>
    private void SetPreviewKind(bool gamebook)
    {
        _PreviewGamebook = gamebook;
        _PreviewNotice   = null;
    }

    /// <summary>
    /// App-preview "continue" — follow the clicked exit to the next logic node and preview it. Reaching the story
    /// End or an unwired exit shows a transient notice instead of navigating.
    /// </summary>
    private void OnPreviewContinue(Guid exitPointId)
    {
        // A single-selection node funnels every branch through its one Selection flow-out; follow that instead of the
        // internal exit, and carry the chosen exit's (remapped) value so the receiver reads it as its Selection.
        StoryLogicNode? owner = Project.LogicNodes.Values.FirstOrDefault(l => l.ExitPoints.Any(e => e.Id == exitPointId));
        bool singleSelect     = owner is { ExitMode: StoryLogicExitMode.SingleSelection };
        Guid followId         = singleSelect ? owner!.SelectionFlowOut.Id : exitPointId;

        StoryFlowNavigator.NextLogicResult result = StoryFlowNavigator.ResolveNextLogic(Project, followId);
        switch (result.Kind)
        {
            case StoryFlowNavigator.NextKind.Logic when result.Logic is not null:
                _Crumbs[^1]    = new EditorCrumb(result.Logic.Id, result.Logic.Name, EditorScope.Logic);
                _PreviewVars   = new Dictionary<Guid, string>();
                if (singleSelect && result.Logic.AcceptExitVariable
                    && owner!.ExitPoints.Find(e => e.Id == exitPointId) is StoryConnectionPoint chosenExit)
                    _PreviewVars[result.Logic.PrevExitVariable.Id] = StorySelectionResolver.ValueFor(result.Logic.PrevExitVariable, chosenExit);
                _PreviewNotice = null;
                RebuildNodes();
                break;

            case StoryFlowNavigator.NextKind.End:
                _PreviewNotice = "This branch reaches The End.";
                break;

            default:
                _PreviewNotice = "This exit isn't connected — wire it to the next node.";
                break;
        }
    }

    /// <summary>Rail tool picked — swap the centre panel. Only Media has its own panel; the rest keep the graph.</summary>
    private void OnToolSelected(EditorRail.Tool tool) => _ActiveTool = tool;

    private void OnSelect(Guid id) => _SelectedId = id;

    private void OnCrumbClicked(int index)
    {
        // Drill back up to the clicked step (container or logic node).
        if (index < _Crumbs.Count - 1)
        {
            _Crumbs     = _Crumbs.GetRange(0, index + 1);
            _SelectedId = Guid.Empty;
            _Mode       = EditorMode.Edit;
            RebuildNodes();
        }
    }

    // ── Drill-down / connections ───────────────────────────────────────────

    /// <summary>Double-click a node: a container opens its inner graph; a logic node opens its content graph.</summary>
    private void OnNodeActivated(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Container:
                if (!Project.ContainerNodes.TryGetValue(node.Id, out StoryContainerNode? child)) return;
                _Crumbs.Add(new EditorCrumb(child.Id, child.Name, EditorScope.Container));
                break;

            case StoryNodeKind.Logic:
                if (!Project.LogicNodes.TryGetValue(node.Id, out StoryLogicNode? logic)) return;
                _Crumbs.Add(new EditorCrumb(logic.Id, logic.Name, EditorScope.Logic));
                break;

            default:
                return;
        }

        _SelectedId = Guid.Empty;
        _Mode       = EditorMode.Edit;
        RebuildNodes();
    }

    /// <summary>Wire an output port to an input port in the current graph (container or logic content).</summary>
    private void OnConnect(EdConnectRequest request)
    {
        if (_InLogic) _ProjectState.ConnectContent(_CurrentId, request.FromPoint, request.ToPoint);
        else          _ProjectState.Connect(_CurrentId, request.FromPoint, request.ToPoint);
        RebuildNodes();
    }

    /// <summary>Remove a connection from the current graph.</summary>
    private void OnDisconnect(Guid connectionId)
    {
        if (_InLogic) _ProjectState.DisconnectContent(_CurrentId, connectionId);
        else          _ProjectState.Disconnect(_CurrentId, connectionId);
        RebuildNodes();
    }

    /// <summary>Re-read the linked localization project so new keys appear; refresh node titles.</summary>
    private async Task OnRefreshLocalization()
    {
        await _ProjectState.RefreshLocalizationAsync();
        RebuildNodes();
    }

    // ── Add node (palette → detail modal) ──────────────────────────────────

    /// <summary>Toolbar "Add node" — no cursor position, so stagger a default spot, then open the palette.</summary>
    private void OnAddNode()
    {
        int count = _Nodes.Count;
        _PendingX = 320 + count % 6 * 30;
        _PendingY = 140 + count % 6 * 26;
        _NodePalette?.Show(PaletteItems());
    }

    /// <summary>Right-click on empty canvas — open the palette and remember where to drop the node.</summary>
    private void OnCanvasContextMenu(CanvasPoint point)
    {
        _PendingX = point.X;
        _PendingY = point.Y;
        _NodePalette?.Show(PaletteItems());
    }

    /// <summary>
    /// The node kinds that can be added in the current context. Inside a container that means container, logic
    /// and portal nodes; inside a logic node's inner graph it means Localization and Icon content nodes.
    /// </summary>
    private List<NodePaletteItem> PaletteItems() =>
        _InLogic
            ?
            [
                new NodePaletteItem(StoryNodeKind.Localization,     "bi-translate",       "Localization node",     "Picks a localization key that supplies this logic node's title text."),
                new NodePaletteItem(StoryNodeKind.Icon,             "bi-emoji-smile",     "Icon node",             "Picks a project icon to show alongside this logic node's content."),
                new NodePaletteItem(StoryNodeKind.LightDarkSwitch,  "bi-circle-half",     "Light/Dark switch",     "Outputs one of two icons depending on the render theme (dark or paper/light)."),
                new NodePaletteItem(StoryNodeKind.SmartFormat,      "bi-braces-asterisk", "SmartFormat node",      "Formats a text with SmartFormat, substituting connected External Variable values."),
                new NodePaletteItem(StoryNodeKind.ExternalVariable, "bi-braces",          "External Variable node", "Feeds a story variable's value into a SmartFormat node."),
                new NodePaletteItem(StoryNodeKind.FlowText,         "bi-text-paragraph",  "FlowText node",         "On the flow spine — renders a connected text block, then continues to the next flow node."),
                new NodePaletteItem(StoryNodeKind.RegisterVariable,   "bi-box-seam",        "Register variable",     "On the flow spine — claims a physical storage slot for a new variable."),
                new NodePaletteItem(StoryNodeKind.SetVariable,        "bi-pencil-square",   "Set variable",          "On the flow spine — assigns a value to an already-registered variable."),
                new NodePaletteItem(StoryNodeKind.UnregisterVariable, "bi-box-arrow-up",    "Unregister variable",   "On the flow spine — releases a registered variable and frees its slot."),
                new NodePaletteItem(StoryNodeKind.SetExternalVariable, "bi-sliders",        "Set external variable", "On the flow spine — assigns a value to a story-wide external variable (App only; no Gamebook instruction)."),
                new NodePaletteItem(StoryNodeKind.Choice,             "bi-signpost-split",  "Choice node",           "On the flow spine — offers the player a set of choices, each branching out to an exit."),
                new NodePaletteItem(StoryNodeKind.AppGamebookTextSplitter, "bi-fonts",       "App/Gamebook text splitter", "Emits its App text when rendering the app and its Gamebook text when rendering the printed gamebook (either may be empty)."),
                new NodePaletteItem(StoryNodeKind.AppGamebookFlowSplitter, "bi-signpost-2",  "App/Gamebook flow splitter", "On the flow spine — routes flow down its App branch for the app and its Gamebook branch for the printed gamebook.")
            ]
            :
            [
                new NodePaletteItem(StoryNodeKind.Logic,     "bi-diamond-half",       "Logic node",     "A stop point that generates content and runs calculations on variables."),
                new NodePaletteItem(StoryNodeKind.Container, "bi-collection",         "Container node", "Groups other nodes into a nested sub-graph with its own entries and exits."),
                new NodePaletteItem(StoryNodeKind.PortalIn,  "bi-box-arrow-in-right", "Portal node",    "A linked in/out pair that teleports flow across the graph to keep it clean.")
            ];

    private void OnPaletteSelect(NodePaletteItem item)
    {
        switch (item.Kind)
        {
            case StoryNodeKind.Logic:        _NewLogicNodeModal?.Show();               break;
            case StoryNodeKind.Container:    _NewContainerModal?.Show();               break;
            case StoryNodeKind.PortalIn:     _NewPortalModal?.Show();                  break;
            case StoryNodeKind.Localization: _LocalizationPicker?.Show(Guid.Empty, Guid.Empty); break;
            case StoryNodeKind.Icon:         _IconPicker?.Show(Guid.Empty, Guid.Empty);         break;
            case StoryNodeKind.LightDarkSwitch:
                // No config — create it straight away at the pending position.
                if (_ProjectState.AddLightDarkSwitchNode(_CurrentId, _PendingX, _PendingY) is StoryLightDarkSwitchNode lds)
                    _SelectedId = lds.Id;
                RebuildNodes();
                break;
            case StoryNodeKind.SmartFormat:
                // No config — create it straight away at the pending position.
                if (_ProjectState.AddSmartFormatNode(_CurrentId, _PendingX, _PendingY) is StorySmartFormatNode sf)
                    _SelectedId = sf.Id;
                RebuildNodes();
                break;
            case StoryNodeKind.ExternalVariable: _VariablePicker?.Show(Guid.Empty, Guid.Empty); break;
            case StoryNodeKind.FlowText:
                // No config — create it straight away at the pending position.
                if (_ProjectState.AddFlowTextNode(_CurrentId, _PendingX, _PendingY) is StoryFlowTextNode ft)
                    _SelectedId = ft.Id;
                RebuildNodes();
                break;
            case StoryNodeKind.RegisterVariable:   _RegisterVariableModal?.Show(ComputeFreeSlots()); break;
            case StoryNodeKind.SetVariable:        _SetVariableModal?.Show();                break;
            case StoryNodeKind.UnregisterVariable: _UnregisterPicker?.Show(Guid.Empty, Guid.Empty); break;
            case StoryNodeKind.SetExternalVariable: _SetExternalVariableModal?.Show();        break;
            case StoryNodeKind.Choice:              _NewChoiceNodeModal?.Show();              break;
            case StoryNodeKind.AppGamebookTextSplitter:
                // No config — the branch is chosen by the render target, so create it straight away.
                if (_ProjectState.AddAppGamebookTextSplitterNode(_CurrentId, _PendingX, _PendingY) is StoryAppGamebookTextSplitterNode ags)
                    _SelectedId = ags.Id;
                RebuildNodes();
                break;
            case StoryNodeKind.AppGamebookFlowSplitter:
                // No config — the branch is chosen by the render target, so create it straight away.
                if (_ProjectState.AddAppGamebookFlowSplitterNode(_CurrentId, _PendingX, _PendingY) is StoryAppGamebookFlowSplitterNode agf)
                    _SelectedId = agf.Id;
                RebuildNodes();
                break;
        }
    }

    // ── Localization / Icon content-node pickers ───────────────────────────

    private void OnLocalizationPicked(LocalizationKeyPickerModal.LocalizationPickResult result)
    {
        if (result.EditNodeId != Guid.Empty)
        {
            _ProjectState.UpdateLocalizationNode(_CurrentId, result.EditNodeId, result.KeyId);
        }
        else if (_ProjectState.AddLocalizationNode(_CurrentId, result.KeyId, _PendingX, _PendingY) is StoryLocalizationNode node)
        {
            _SelectedId = node.Id;
        }
        RebuildNodes();
    }

    private void OnIconPicked(IconPickerModal.IconPickResult result)
    {
        if (result.EditNodeId != Guid.Empty)
        {
            _ProjectState.UpdateIconNode(_CurrentId, result.EditNodeId, result.ImageId);
        }
        else if (_ProjectState.AddIconNode(_CurrentId, result.ImageId, _PendingX, _PendingY) is StoryIconNode node)
        {
            _SelectedId = node.Id;
        }
        RebuildNodes();
    }

    private void OnVariablePicked(VariablePickerModal.VariablePickResult result)
    {
        if (result.EditNodeId != Guid.Empty)
        {
            _ProjectState.UpdateExternalVariableNode(_CurrentId, result.EditNodeId, result.VariableId);
        }
        else if (_ProjectState.AddExternalVariableNode(_CurrentId, result.VariableId, _PendingX, _PendingY) is StoryExternalVariableNode node)
        {
            _SelectedId = node.Id;
        }
        RebuildNodes();
    }

    /// <summary>The free storage slots per type on entry to the logic node being edited, so the Register modal only
    /// offers slots that aren't already claimed on the path here. Null when not inside a logic node.</summary>
    private IReadOnlyDictionary<StorageVariableType, IReadOnlyList<int>>? ComputeFreeSlots()
    {
        if (!_InLogic) return null;

        StoryValidationResult result = StoryGraphValidator.Validate(Project);
        Dictionary<StorageVariableType, IReadOnlyList<int>> dict = new();
        foreach (StorageVariableType type in Enum.GetValues<StorageVariableType>())
            if (result.FreeSlots(_CurrentId, type) is IReadOnlyList<int> free)
                dict[type] = free;
        return dict.Count > 0 ? dict : null;
    }

    /// <summary>Navigate to the graph location a validation problem points at (open its container, drill into the
    /// logic node if it's an inner-graph issue, and select the offending node).</summary>
    private void OnProblemNavigate(StoryProblem problem)
    {
        // Rebuild the full breadcrumb path: Root / …containers… / (logic node). The Root crumb must always be
        // present so the user can walk back up, matching how normal drill-down keeps Root as the first crumb.
        Guid                     rootId = Project.Metadata.RootStoryContainerNodeId;
        List<EditorCrumb>        crumbs = [new EditorCrumb(rootId, RootName())];
        List<StoryContainerNode> chain  = new();
        Guid                     cur    = problem.ContainerId;
        int                      guard  = 0;
        while (cur != Guid.Empty
               && cur != rootId
               && Project.ContainerNodes.TryGetValue(cur, out StoryContainerNode? c)
               && guard++ < 64)
        {
            chain.Add(c);
            cur = c.ParentContainer;
        }
        chain.Reverse();
        foreach (StoryContainerNode c in chain)
            crumbs.Add(new EditorCrumb(c.Id, c.Name, EditorScope.Container));

        if (problem.LogicNodeId != Guid.Empty && problem.InnerNodeId != Guid.Empty
            && Project.LogicNodes.TryGetValue(problem.LogicNodeId, out StoryLogicNode? lg))
        {
            crumbs.Add(new EditorCrumb(lg.Id, lg.Name, EditorScope.Logic));
            _SelectedId = problem.InnerNodeId;
        }
        else if (problem.LogicNodeId != Guid.Empty)
        {
            _SelectedId = problem.LogicNodeId;
        }
        else
        {
            _SelectedId = Guid.Empty;
        }

        _Crumbs     = crumbs;
        _ActiveTool = EditorRail.Tool.Graph;
        _Mode       = EditorMode.Edit;
        RebuildNodes();
    }

    private void OnRegisterVariableConfirmed(RegisterVariableModal.RegisterVariableArgs args)
    {
        Guid nodeId = args.EditNodeId;
        if (nodeId == Guid.Empty)
        {
            if (_ProjectState.AddRegisterVariableNode(_CurrentId, _PendingX, _PendingY) is not StoryRegisterVariableNode created) return;
            nodeId      = created.Id;
            _SelectedId = created.Id;
        }
        _ProjectState.UpdateRegisterVariableNode(
            _CurrentId, nodeId, args.Name, args.Description, args.Type, args.SlotIndex,
            args.Mode, args.ValueCount, args.Secret, args.Assignment, args.SpecificValue, args.ConditionKeyId);
        RebuildNodes();
    }

    private void OnSetVariableConfirmed(SetVariableModal.SetVariableArgs args)
    {
        Guid nodeId = args.EditNodeId;
        if (nodeId == Guid.Empty)
        {
            if (_ProjectState.AddSetVariableNode(_CurrentId, _PendingX, _PendingY) is not StorySetVariableNode created) return;
            nodeId      = created.Id;
            _SelectedId = created.Id;
        }
        _ProjectState.UpdateSetVariableNode(
            _CurrentId, nodeId, args.RegisteredVariableId, args.Assignment, args.Secret, args.SpecificValue);
        RebuildNodes();
    }

    private void OnSetExternalVariableConfirmed(SetExternalVariableModal.SetExternalVariableArgs args)
    {
        Guid nodeId = args.EditNodeId;
        if (nodeId == Guid.Empty)
        {
            if (_ProjectState.AddSetExternalVariableNode(_CurrentId, _PendingX, _PendingY) is not StorySetExternalVariableNode created) return;
            nodeId      = created.Id;
            _SelectedId = created.Id;
        }
        _ProjectState.UpdateSetExternalVariableNode(_CurrentId, nodeId, args.SelectedVariableId, args.Value);
        RebuildNodes();
    }

    private void OnChoiceConfirmed(NewChoiceNodeModal.ChoiceArgs args)
    {
        Guid nodeId = args.EditNodeId;
        if (nodeId == Guid.Empty)
        {
            if (_ProjectState.AddChoiceNode(_CurrentId, _PendingX, _PendingY) is not StoryChoiceNode created) return;
            nodeId      = created.Id;
            _SelectedId = created.Id;
        }
        _ProjectState.UpdateChoiceNode(_CurrentId, nodeId,
            args.Options.Select(o => (o.Id, o.Name)).ToList());
        RebuildNodes();
    }

    private void OnUnregisterPicked(UnregisterVariablePickerModal.UnregisterPickResult result)
    {
        if (result.EditNodeId != Guid.Empty)
        {
            _ProjectState.UpdateUnregisterVariableNode(_CurrentId, result.EditNodeId, result.RegisteredVariableId);
        }
        else if (_ProjectState.AddUnregisterVariableNode(_CurrentId, _PendingX, _PendingY) is StoryUnregisterVariableNode node)
        {
            _ProjectState.UpdateUnregisterVariableNode(_CurrentId, node.Id, result.RegisteredVariableId);
            _SelectedId = node.Id;
        }
        RebuildNodes();
    }

    private void OnNewLogicNodeConfirmed(NewLogicNodeModal.NewLogicNodeArgs args)
    {
        if (args.EditId != Guid.Empty)
        {
            _ProjectState.UpdateLogicNode(
                _CurrentId, args.EditId, args.Name, args.Description, args.EntryName, args.Exits,
                args.GamebookInstructions, args.ExitMode, args.AcceptExitVariable);
            RebuildNodes();
            _SelectedId = args.EditId;
            return;
        }

        StoryConnectionPoint entry = new() { Name = args.EntryName };
        List<StoryConnectionPoint> exits = args.Exits
                                               .Select(e => new StoryConnectionPoint { Name = e.Name })
                                               .ToList();

        StoryLogicNode node = _ProjectState.AddLogicNode(
            _CurrentId, args.Name, args.Description, entry, exits, _PendingX, _PendingY,
            args.GamebookInstructions, args.ExitMode, args.AcceptExitVariable);

        RebuildNodes();
        _SelectedId = node.Id;
    }

    private void OnNewContainerConfirmed(NewContainerNodeModal.NewContainerNodeArgs args)
    {
        if (args.EditId != Guid.Empty)
        {
            _ProjectState.UpdateContainerNode(
                _CurrentId, args.EditId, args.Name, args.Description, args.Entries, args.Exits);
            RebuildNodes();
            _SelectedId = args.EditId;
            return;
        }

        List<StoryConnectionPoint> entries = args.Entries.Select(e => new StoryConnectionPoint { Name = e.Name }).ToList();
        List<StoryConnectionPoint> exits   = args.Exits.Select(e => new StoryConnectionPoint { Name = e.Name }).ToList();

        StoryContainerNode node = _ProjectState.AddContainerNode(
            _CurrentId, args.Name, args.Description, entries, exits, _PendingX, _PendingY);

        RebuildNodes();
        _SelectedId = node.Id;
    }

    private void OnNewPortalConfirmed(NewPortalNodeModal.NewPortalNodeArgs args)
    {
        if (args.EditId != Guid.Empty)
        {
            _ProjectState.UpdatePortalNode(args.EditId, args.Name, args.Description);
            RebuildNodes();
            return;
        }

        _ProjectState.AddPortalNode(_CurrentId, args.Name, args.Description, _PendingX, _PendingY);
        RebuildNodes();
    }

    // ── Node context menu (edit / delete / add portal in) ──────────────────

    /// <summary>Edit from a node's context menu — reopen its create modal, pre-filled and in edit mode.</summary>
    private void OnNodeEdit(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Logic:
                if (Project.LogicNodes.TryGetValue(node.Id, out StoryLogicNode? logic))
                    _NewLogicNodeModal?.ShowEdit(
                        logic.Id, logic.Name, logic.Description, logic.EntryPoint.Name,
                        logic.ExitPoints.Select(p => (p.Id, p.Name)), logic.GamebookInstructions,
                        logic.ExitMode, logic.AcceptExitVariable);
                break;

            case StoryNodeKind.Container:
                if (Project.ContainerNodes.TryGetValue(node.Id, out StoryContainerNode? child))
                    _NewContainerModal?.ShowEdit(
                        child.Id, child.Name, child.Description,
                        child.EntryPoints.Select(p => (p.Id, p.Name)),
                        child.ExitPoints.Select(p => (p.Id, p.Name)));
                break;

            case StoryNodeKind.PortalIn:
            case StoryNodeKind.PortalOut:
                if (_ProjectState.FindPortalByPoint(node.Id) is StoryPortalNode portal)
                    _NewPortalModal?.ShowEdit(portal.Id, portal.Name, portal.Description);
                break;

            case StoryNodeKind.Localization:
                if (_CurrentLogicNode?.LocalizationNodes.Find(n => n.Id == node.Id) is StoryLocalizationNode loc)
                    _LocalizationPicker?.Show(loc.Id, loc.SelectedKeyId);
                break;

            case StoryNodeKind.Icon:
                if (_CurrentLogicNode?.IconNodes.Find(n => n.Id == node.Id) is StoryIconNode ico)
                    _IconPicker?.Show(ico.Id, ico.SelectedImageId);
                break;

            case StoryNodeKind.ExternalVariable:
                if (_CurrentLogicNode?.ExternalVariableNodes.Find(n => n.Id == node.Id) is StoryExternalVariableNode ev)
                    _VariablePicker?.Show(ev.Id, ev.SelectedVariableId);
                break;

            case StoryNodeKind.RegisterVariable:
                if (_CurrentLogicNode?.RegisterVariableNodes.Find(n => n.Id == node.Id) is StoryRegisterVariableNode reg)
                    _RegisterVariableModal?.ShowEdit(reg, ComputeFreeSlots());
                break;

            case StoryNodeKind.SetVariable:
                if (_CurrentLogicNode?.SetVariableNodes.Find(n => n.Id == node.Id) is StorySetVariableNode setNode)
                    _SetVariableModal?.ShowEdit(setNode);
                break;

            case StoryNodeKind.UnregisterVariable:
                if (_CurrentLogicNode?.UnregisterVariableNodes.Find(n => n.Id == node.Id) is StoryUnregisterVariableNode unreg)
                    _UnregisterPicker?.Show(unreg.Id, unreg.RegisteredVariableId);
                break;

            case StoryNodeKind.SetExternalVariable:
                if (_CurrentLogicNode?.SetExternalVariableNodes.Find(n => n.Id == node.Id) is StorySetExternalVariableNode setExt)
                    _SetExternalVariableModal?.ShowEdit(setExt);
                break;

            case StoryNodeKind.Choice:
                if (_CurrentLogicNode?.ChoiceNodes.Find(n => n.Id == node.Id) is StoryChoiceNode choice)
                    _NewChoiceNodeModal?.ShowEdit(choice);
                break;

            case StoryNodeKind.PrevExitVariable:
                if (_CurrentLogicNode is StoryLogicNode owner)
                {
                    List<StoryConnectionPoint>? sourceExits = EditorProjection.ResolveExitVariableSource(Project, owner);
                    _PrevExitVariableModal?.ShowEdit(
                        owner.PrevExitVariable,
                        (sourceExits ?? new List<StoryConnectionPoint>()).Select(p => (p.Id, p.Name)));
                }
                break;
        }
    }

    private void OnPrevExitVariableConfirmed(PrevExitVariableModal.PrevExitVariableArgs args)
    {
        if (_CurrentLogicNode is not StoryLogicNode owner) return;
        _ProjectState.UpdatePrevExitVariableNode(owner.Id, args.VariableName, args.RemapEnabled, args.Remaps);
        RebuildNodes();
        _SelectedId = owner.PrevExitVariable.Id;
    }

    /// <summary>Delete from a node's context menu. Deleting a container removes everything nested inside it.</summary>
    private void OnNodeDelete(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Logic:        _ProjectState.DeleteLogicNode(_CurrentId, node.Id);         break;
            case StoryNodeKind.Container:    _ProjectState.DeleteContainerNode(_CurrentId, node.Id);     break;
            case StoryNodeKind.PortalIn:     _ProjectState.DeletePortalIn(_CurrentId, node.Id);          break;
            case StoryNodeKind.PortalOut:
                if (_ProjectState.FindPortalByPoint(node.Id) is StoryPortalNode portal)
                    _ProjectState.DeletePortal(_CurrentId, portal.Id);
                break;
            case StoryNodeKind.Localization: _ProjectState.DeleteLocalizationNode(_CurrentId, node.Id);  break;
            case StoryNodeKind.Icon:         _ProjectState.DeleteIconNode(_CurrentId, node.Id);          break;
            case StoryNodeKind.LightDarkSwitch: _ProjectState.DeleteLightDarkSwitchNode(_CurrentId, node.Id); break;
            case StoryNodeKind.SmartFormat:     _ProjectState.DeleteSmartFormatNode(_CurrentId, node.Id);     break;
            case StoryNodeKind.ExternalVariable: _ProjectState.DeleteExternalVariableNode(_CurrentId, node.Id); break;
            case StoryNodeKind.FlowText:         _ProjectState.DeleteFlowTextNode(_CurrentId, node.Id);        break;
            case StoryNodeKind.RegisterVariable:   _ProjectState.DeleteRegisterVariableNode(_CurrentId, node.Id);   break;
            case StoryNodeKind.SetVariable:        _ProjectState.DeleteSetVariableNode(_CurrentId, node.Id);        break;
            case StoryNodeKind.UnregisterVariable: _ProjectState.DeleteUnregisterVariableNode(_CurrentId, node.Id); break;
            case StoryNodeKind.SetExternalVariable: _ProjectState.DeleteSetExternalVariableNode(_CurrentId, node.Id); break;
            case StoryNodeKind.Choice:              _ProjectState.DeleteChoiceNode(_CurrentId, node.Id);             break;
            case StoryNodeKind.AppGamebookTextSplitter: _ProjectState.DeleteAppGamebookTextSplitterNode(_CurrentId, node.Id); break;
            case StoryNodeKind.AppGamebookFlowSplitter: _ProjectState.DeleteAppGamebookFlowSplitterNode(_CurrentId, node.Id); break;
            default: return;
        }

        if (_SelectedId == node.Id) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>Add another portal-in to the pair the right-clicked portal node belongs to.</summary>
    private void OnNodeAddPortalIn(EdNode node)
    {
        if (node.Kind is not (StoryNodeKind.PortalIn or StoryNodeKind.PortalOut)) return;
        _ProjectState.AddPortalIn(node.Id);
        RebuildNodes();
    }

    // ── Reparent (drag onto a container / push up to parent) ────────────────

    /// <summary>A logic/container node was dropped onto a container — move it inside that container.</summary>
    private void OnNodeReparent(EdNodeReparent request)
    {
        if (!Project.ContainerNodes.TryGetValue(request.TargetContainerId, out StoryContainerNode? target)) return;
        (double x, double y) = DropSpot(target);
        _ProjectState.ReparentNode(_CurrentId, request.NodeId, request.TargetContainerId, x, y);

        // The node has left this graph — drop the selection so the inspector doesn't dangle.
        if (_SelectedId == request.NodeId) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>"Move to parent" — push a logic/container node up one level (never above the Root).</summary>
    private void OnNodeMoveToParent(EdNode node)
    {
        if (IsRootContainer) return;
        if (!Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? current)) return;
        if (!Project.ContainerNodes.TryGetValue(current.ParentContainer, out StoryContainerNode? parent)) return;

        (double x, double y) = DropSpot(parent);
        _ProjectState.ReparentNode(_CurrentId, node.Id, parent.Id, x, y);

        if (_SelectedId == node.Id) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>A staggered canvas position for a node arriving in <paramref name="container"/>, so drops don't stack.</summary>
    private static (double X, double Y) DropSpot(StoryContainerNode container)
    {
        int count = container.Containers.Count + container.Logic.Count;
        return (320 + count % 6 * 30, 140 + count % 6 * 26);
    }

    // ── Persist a drag ─────────────────────────────────────────────────────

    private void OnNodeMoved(EdNode moved)
    {
        // Inside a logic node's inner graph — the Entry/Exit points or a content node moved.
        if (_InLogic)
        {
            _ProjectState.MoveLogicNode(_CurrentId, moved.Id, moved.X, moved.Y);
            return;
        }

        // A logic node moved.
        if (Project.LogicNodes.TryGetValue(moved.Id, out StoryLogicNode? logic))
        {
            logic.X = moved.X;
            logic.Y = moved.Y;
            _ProjectState.MarkKeyDirty(logic.Id);
            return;
        }

        // A child container moved.
        if (Project.ContainerNodes.TryGetValue(moved.Id, out StoryContainerNode? child))
        {
            child.X = moved.X;
            child.Y = moved.Y;
            _ProjectState.MarkKeyDirty(child.Id);
            return;
        }

        // A portal in/out node moved (its position lives on the portal's connection point).
        if (_ProjectState.FindPortalByPoint(moved.Id) is StoryPortalNode portal)
        {
            StoryConnectionPoint? point = portal.OutPoint.Id == moved.Id
                ? portal.OutPoint
                : portal.InPoints.Find(p => p.Id == moved.Id);
            if (point is not null)
            {
                point.X = moved.X;
                point.Y = moved.Y;
                _ProjectState.MarkKeyDirty(portal.Id);
            }
            return;
        }

        // A connection point (Start/End/Entry/Exit) of the current container moved.
        if (Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? container))
        {
            StoryConnectionPoint? point = container.EntryPoints.Find(p => p.Id == moved.Id)
                                       ?? container.ExitPoints.Find(p => p.Id == moved.Id);
            if (point is not null)
            {
                point.X = moved.X;
                point.Y = moved.Y;
                _ProjectState.MarkKeyDirty(container.Id);
            }
        }
    }
}

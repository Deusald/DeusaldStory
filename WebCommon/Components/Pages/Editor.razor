    // ── Node context menu (edit / delete / add portal in) ──────────────────

    /// <summary>Edit from a node's context menu — reopen its create modal, pre-filled and in edit mode.</summary>
    private void OnNodeEdit(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Logic:
                if (Project.LogicNodes.TryGetValue(node.Id, out StoryLogicNode? logic))
                    _NewLogicNodeModal?.ShowEdit(
                        logic.Id, logic.Name, logic.Description,
                        logic.GamebookInstructions, logic.ExitMode, logic.AcceptVariables,
                        logic.DeclaredVariables.Select(d => (d.Id, d.Name, d.PossibleValues)),
                        logic.ExpectedVariables.Select(d => (d.Id, d.Name, d.PossibleValues)));
                break;

            case StoryNodeKind.Container:
                if (Project.ContainerNodes.TryGetValue(node.Id, out StoryContainerNode? child))
                    _NewContainerModal?.ShowEdit(
                        child.Id, child.Name, child.Description,
                        child.EntryPoints.Select(p => (p.Id, p.Name, p.FlowKind)),
                        child.ExitPoints.Select(p => (p.Id, p.Name, p.FlowKind)));
                break;

            case StoryNodeKind.PortalIn:
            case StoryNodeKind.PortalOut:
                if (_ProjectState.FindPortalByPoint(node.Id) is StoryPortalNode portal)
                    _NewPortalModal?.ShowEdit(portal.Id, portal.Name, portal.Description);
                break;

            case StoryNodeKind.LogicPortalIn:
            case StoryNodeKind.LogicPortalOut:
                if (_CurrentLogicNode is StoryLogicNode portalOwner
                 && _ProjectState.FindLogicPortalByPoint(portalOwner, node.Id) is StoryLogicPortalNode logicPortal)
                    _LogicPortalModal?.ShowEdit(node.Id, logicPortal.Name, logicPortal.Description);
                break;

            case StoryNodeKind.Localization:
                if (_CurrentLogicNode?.LocalizationNodes.Find(n => n.Id == node.Id) is StoryLocalizationNode loc)
                    _LocalizationPicker?.Show(loc.Id, loc.SelectedKeyId);
                break;

            case StoryNodeKind.Icon:
                if (_CurrentLogicNode?.IconNodes.Find(n => n.Id == node.Id) is StoryIconNode ico)
                    _IconPicker?.Show(ico.Id, ico.SelectedImageId);
                break;

            case StoryNodeKind.ExternalVariable:
                if (_CurrentLogicNode?.ExternalVariableNodes.Find(n => n.Id == node.Id) is StoryExternalVariableNode ev)
                    _VariablePicker?.Show(ev.Id, ev.SelectedVariableId);
                break;

            case StoryNodeKind.GetVariable:
                if (_CurrentLogicNode?.GetVariableNodes.Find(n => n.Id == node.Id) is StoryGetVariableNode gv)
                    _GetVariableModal?.ShowEdit(gv);
                break;

            case StoryNodeKind.ConstantVariable:
                if (_CurrentLogicNode?.ConstantVariableNodes.Find(n => n.Id == node.Id) is StoryConstantVariableNode cv)
                    _ConstantVariableModal?.ShowEdit(cv);
                break;

            case StoryNodeKind.ConstantString:
                if (_CurrentLogicNode?.ConstantStringNodes.Find(n => n.Id == node.Id) is StoryConstantStringNode cs)
                    _ConstantStringModal?.ShowEdit(cs);
                break;

            case StoryNodeKind.RandomizedInstruction:
                if (_CurrentLogicNode?.RandomizedInstructionNodes.Find(n => n.Id == node.Id) is StoryRandomizedInstructionNode ri)
                    _RandomizedInstructionModal?.ShowEdit(ri, _CurrentLogicNode);
                break;

            case StoryNodeKind.RegisterVariable:
                if (_CurrentLogicNode?.RegisterVariableNodes.Find(n => n.Id == node.Id) is StoryRegisterVariableNode reg)
                    _RegisterVariableModal?.ShowEdit(reg, ComputeFreeSlots());
                break;

            case StoryNodeKind.SetVariable:
                if (_CurrentLogicNode?.SetVariableNodes.Find(n => n.Id == node.Id) is StorySetVariableNode setNode)
                    _SetVariableModal?.ShowEdit(setNode);
                break;

            case StoryNodeKind.UnregisterVariable:
                if (_CurrentLogicNode?.UnregisterVariableNodes.Find(n => n.Id == node.Id) is StoryUnregisterVariableNode unreg)
                    _UnregisterPicker?.Show(unreg.Id, unreg.RegisteredVariableId, unreg.Placement);
                break;

            case StoryNodeKind.SetExternalVariable:
                if (_CurrentLogicNode?.SetExternalVariableNodes.Find(n => n.Id == node.Id) is StorySetExternalVariableNode setExt)
                    _SetExternalVariableModal?.ShowEdit(setExt);
                break;

            case StoryNodeKind.LogicExit:
                if (_CurrentLogicNode is StoryLogicNode exitOwner)
                    _ExitNodeModal?.ShowEdit(exitOwner, AvailableExitVariables(exitOwner));
                break;

            case StoryNodeKind.FlowText:
                if (_CurrentLogicNode?.FlowTextNodes.Find(n => n.Id == node.Id) is StoryFlowTextNode ftEdit)
                    _FlowTextOptionsModal?.ShowEdit(ftEdit);
                break;

            case StoryNodeKind.SmartFormat:
                if (_CurrentLogicNode?.SmartFormatNodes.Find(n => n.Id == node.Id) is StorySmartFormatNode sfEdit)
                    _SmartFormatOptionsModal?.ShowEdit(sfEdit);
                break;

            case StoryNodeKind.ConditionFlow:
                if (_CurrentLogicNode?.ConditionFlowNodes.Find(n => n.Id == node.Id) is StoryConditionFlowNode cf)
                    _ConditionFlowModal?.ShowEdit(cf, AvailableConditionVariables(_CurrentLogicNode, cf));
                break;

            case StoryNodeKind.Comment:
                if (FindComment(node.Id) is StoryCommentNode comment)
                    _NewCommentNodeModal?.ShowEdit(comment.Id, comment.Text);
                break;
        }
    }

    /// <summary>
    /// The <b>constant</b> variables wired into a Condition node's Variables input, as (output id, display name) for its
    /// condition builder. Only constant-typed sources are offered so the condition stays deterministically renderable.
    /// </summary>
    private List<(Guid Id, string Name)> AvailableConditionVariables(StoryLogicNode logic, StoryConditionFlowNode cf)
    {
        List<(Guid, string)> result = new();
        foreach (StoryConnection c in logic.ContentConnections.Where(c => c.ToPoint == cf.VariablesIn.Id))
        {
            if (EditorProjection.PortTypeOfOutput(Project, logic, logic.ResolvePortalSource(c.FromPoint)) != PortType.CVariable) continue;
            string name = EditorProjection.VariableSourceName(Project, logic, c.FromPoint);
            if (!string.IsNullOrWhiteSpace(name)) result.Add((c.FromPoint, name));
        }
        return result;
    }

    /// <summary>The variables wired into a node's Exit-node Variables input, as (output id, display name) for the auto-resolution condition builder.</summary>
    private List<(Guid Id, string Name)> AvailableExitVariables(StoryLogicNode logic) =>
        EditorProjection.WiredVariables(Project, logic, logic.ExitVariablesIn.Id);

    /// <summary>Delete from a node's context menu. Deleting a container removes everything nested inside it.</summary>
    private void OnNodeDelete(EdNode node)
    {
        DeleteOne(node);
        if (_SelectedId == node.Id) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>Delete every node in <paramref name="nodes"/> (a multi-selection) as one atomic, undoable step.</summary>
    private void OnNodesDelete(IReadOnlyList<EdNode> nodes)
    {
        using (_ProjectState.BeginBatch())
            foreach (EdNode node in nodes)
                DeleteOne(node);

        if (nodes.Any(n => n.Id == _SelectedId)) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>Removes one node from the model, dispatched by kind. Does not touch selection / rebuild (the caller does).</summary>
    private void DeleteOne(EdNode node)
    {
        switch (node.Kind)
        {
            case StoryNodeKind.Logic:        _ProjectState.DeleteLogicNode(_CurrentId, node.Id);         break;
            case StoryNodeKind.Container:    _ProjectState.DeleteContainerNode(_CurrentId, node.Id);     break;
            case StoryNodeKind.PortalIn:     _ProjectState.DeletePortalIn(_CurrentId, node.Id);          break;
            case StoryNodeKind.PortalOut:
                if (_ProjectState.FindPortalByPoint(node.Id) is StoryPortalNode portal)
                    _ProjectState.DeletePortal(_CurrentId, portal.Id);
                break;
            case StoryNodeKind.LogicPortalIn:  _ProjectState.DeleteLogicPortalByPoint(_CurrentId, node.Id); break;
            case StoryNodeKind.LogicPortalOut: _ProjectState.DeleteLogicPortalOut(_CurrentId, node.Id);      break;
            case StoryNodeKind.Localization: _ProjectState.DeleteLocalizationNode(_CurrentId, node.Id);  break;
            case StoryNodeKind.Icon:         _ProjectState.DeleteIconNode(_CurrentId, node.Id);          break;
            case StoryNodeKind.LightDarkSwitch: _ProjectState.DeleteLightDarkSwitchNode(_CurrentId, node.Id); break;
            case StoryNodeKind.SmartFormat:     _ProjectState.DeleteSmartFormatNode(_CurrentId, node.Id);     break;
            case StoryNodeKind.ExternalVariable: _ProjectState.DeleteExternalVariableNode(_CurrentId, node.Id); break;
            case StoryNodeKind.GetVariable:      _ProjectState.DeleteGetVariableNode(_CurrentId, node.Id);      break;
            case StoryNodeKind.ConstantVariable: _ProjectState.DeleteConstantVariableNode(_CurrentId, node.Id); break;
            case StoryNodeKind.ConstantString:   _ProjectState.DeleteConstantStringNode(_CurrentId, node.Id);   break;
            case StoryNodeKind.RandomizedInstruction: _ProjectState.DeleteRandomizedInstructionNode(_CurrentId, node.Id); break;
            case StoryNodeKind.FlowText:         _ProjectState.DeleteFlowTextNode(_CurrentId, node.Id);        break;
            case StoryNodeKind.SplitForApp:      _ProjectState.DeleteSplitForAppNode(_CurrentId, node.Id);     break;
            case StoryNodeKind.RegisterVariable:   _ProjectState.DeleteRegisterVariableNode(_CurrentId, node.Id);   break;
            case StoryNodeKind.SetVariable:        _ProjectState.DeleteSetVariableNode(_CurrentId, node.Id);        break;
            case StoryNodeKind.UnregisterVariable: _ProjectState.DeleteUnregisterVariableNode(_CurrentId, node.Id); break;
            case StoryNodeKind.SetExternalVariable: _ProjectState.DeleteSetExternalVariableNode(_CurrentId, node.Id); break;
            case StoryNodeKind.ConditionFlow:
            case StoryNodeKind.EndConditionFlow:    _ProjectState.DeleteConditionFlowNode(_CurrentId, node.Id);  break;
            case StoryNodeKind.Comment:                 _ProjectState.DeleteCommentNode(_CurrentId, node.Id);               break;
            case StoryNodeKind.BlueprintInstance:   _ProjectState.DeleteBlueprintInstance(_CurrentId, node.Id);  break;
            case StoryNodeKind.FunctionInstance:    _ProjectState.DeleteFunctionInstanceNode(_CurrentId, node.Id); break;
        }
    }

    // ── Copy / paste ────────────────────────────────────────────────────────

    // The copy buffer: the canvas node ids that were copied, and the scope they came from (a container's graph or a
    // logic node's inner graph). Paste only pastes into a matching scope. Ids are resolved against the live project at
    // paste time, so a copy carries no snapshot — deleting the originals before pasting simply yields nothing.
    private List<Guid>  _Clipboard        = [];
    private EditorScope _ClipboardScope   = EditorScope.Container;
    private Guid        _ClipboardOwnerId = Guid.Empty; // the graph (container / logic node) the copy was taken from — inner nodes only resolve against their owner

    /// <summary>Whether the clipboard holds something that can be pasted into the current graph (same scope) — drives the canvas Paste option.</summary>
    private bool CanPaste => _Clipboard.Count > 0 && _ClipboardScope == _Scope;

    /// <summary>Copy the selected nodes to the clipboard (Ctrl/Cmd+C).</summary>
    private void OnNodesCopy(IReadOnlyList<EdNode> nodes)
    {
        // Boundary/built-in nodes (Start/End/Entry/Exit, logic Entry/Exit, Prev Exit) can't be copied — skip them.
        _Clipboard        = nodes.Where(n => n.Deletable).Select(n => n.Id).ToList();
        _ClipboardScope   = _Scope;
        _ClipboardOwnerId = _CurrentId;
    }

    /// <summary>Paste the clipboard into the current graph, offset from the originals (Ctrl/Cmd+V).</summary>
    private void OnPaste()
    {
        if (_Clipboard.Count == 0 || _ClipboardScope != _Scope) return;

        List<Guid> pasted = _InLogic
            ? _ProjectState.PasteLogicInnerNodes(_ClipboardOwnerId, _CurrentId, _Clipboard, _PASTE_OFFSET, _PASTE_OFFSET)
            : _ProjectState.PasteContainerNodes(_CurrentId, _Clipboard, _PASTE_OFFSET, _PASTE_OFFSET);

        // Select every pasted node so the author can drag the whole group at once (a single node stays the primary
        // selection so the inspector fills in; two or more become a multi-selection like a marquee).
        _SelectedId = pasted.Count == 1 ? pasted[0] : Guid.Empty;
        RebuildNodes();
        _GraphRef?.SelectGroup(pasted);
    }

    private const double _PASTE_OFFSET = 40;

    /// <summary>Add another portal-in to the pair the right-clicked portal node belongs to.</summary>
    private async Task OnNodeAddPortalIn(EdNode node)
    {
        if (node.Kind is not (StoryNodeKind.PortalIn or StoryNodeKind.PortalOut)) return;
        (double x, double y) = await ClampDrop(node.X, node.Y + 90, _NODE_W_APPROX, _NODE_H_APPROX);
        _ProjectState.AddPortalIn(node.Id, x, y);
        RebuildNodes();
    }

    /// <summary>Add another portal-out to the logic portal the right-clicked node belongs to.</summary>
    private async Task OnNodeAddPortalOut(EdNode node)
    {
        if (node.Kind is not (StoryNodeKind.LogicPortalIn or StoryNodeKind.LogicPortalOut)) return;
        (double x, double y) = await ClampDrop(node.X, node.Y + 90, _NODE_W_APPROX, _NODE_H_APPROX);
        _ProjectState.AddLogicPortalOut(_CurrentId, node.Id, x, y);
        RebuildNodes();
    }

    private const double _NODE_W_APPROX = 216;
    private const double _NODE_H_APPROX = 82;

    // ── Reparent (drag onto a container / push up to parent) ────────────────

    /// <summary>A logic/container node was dropped onto a container — move it inside that container.</summary>
    private void OnNodeReparent(EdNodeReparent request)
    {
        if (!Project.ContainerNodes.TryGetValue(request.TargetContainerId, out StoryContainerNode? target)) return;
        (double x, double y) = DropSpot(target);
        _ProjectState.ReparentNode(_CurrentId, request.NodeId, request.TargetContainerId, x, y);

        // The node has left this graph — drop the selection so the inspector doesn't dangle.
        if (_SelectedId == request.NodeId) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>"Move to parent" — push a logic/container node up one level (never above the Root).</summary>
    private void OnNodeMoveToParent(EdNode node)
    {
        if (IsRootContainer) return;
        if (!Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? current)) return;
        if (!Project.ContainerNodes.TryGetValue(current.ParentContainer, out StoryContainerNode? parent)) return;

        (double x, double y) = DropSpot(parent);
        _ProjectState.ReparentNode(_CurrentId, node.Id, parent.Id, x, y);

        if (_SelectedId == node.Id) _SelectedId = Guid.Empty;
        RebuildNodes();
    }

    /// <summary>Context-menu "Make into blueprint" — extract the node into a new blueprint, replacing it with an instance in place.</summary>
    private void OnNodeMakeBlueprint(EdNode node)
    {
        if (_ProjectState.MakeIntoBlueprint(_CurrentId, node.Id) is StoryBlueprint bp)
            _SelectedId = Project.BlueprintInstances.Values.FirstOrDefault(i => i.BlueprintId == bp.Id)?.Id ?? Guid.Empty;
        RebuildNodes();
    }

    /// <summary>A staggered canvas position for a node arriving in <paramref name="container"/>, so drops don't stack.</summary>
    private static (double X, double Y) DropSpot(StoryContainerNode container)
    {
        int count = container.Containers.Count + container.Logic.Count;
        return (320 + count % 6 * 30, 140 + count % 6 * 26);
    }

    // ── Persist a drag ─────────────────────────────────────────────────────

    /// <summary>Persist a drag. The whole (possibly multi-selection) group is one atomic, undoable step.</summary>
    private void OnNodesMoved(IReadOnlyList<EdNode> moved)
    {
        using (_ProjectState.BeginBatch())
            foreach (EdNode node in moved)
                PersistMove(node);
    }

    private void PersistMove(EdNode moved)
    {
        // A comment note lives in either graph (container or logic inner); resolve it against the current owner.
        if (moved.Kind == StoryNodeKind.Comment)
        {
            _ProjectState.MoveCommentNode(_CurrentId, moved.Id, moved.X, moved.Y);
            return;
        }

        // Inside a logic node's inner graph — the Entry/Exit points or a content node moved.
        if (_InLogic)
        {
            _ProjectState.MoveLogicNode(_CurrentId, moved.Id, moved.X, moved.Y);
            return;
        }

        // A logic node moved.
        if (Project.LogicNodes.TryGetValue(moved.Id, out StoryLogicNode? logic))
        {
            logic.X = moved.X;
            logic.Y = moved.Y;
            _ProjectState.MarkKeyDirty(logic.Id);
            return;
        }

        // A child container moved.
        if (Project.ContainerNodes.TryGetValue(moved.Id, out StoryContainerNode? child))
        {
            child.X = moved.X;
            child.Y = moved.Y;
            _ProjectState.MarkKeyDirty(child.Id);
            return;
        }

        // A blueprint instance moved.
        if (Project.BlueprintInstances.TryGetValue(moved.Id, out StoryBlueprintInstanceNode? inst))
        {
            inst.X = moved.X;
            inst.Y = moved.Y;
            _ProjectState.MarkKeyDirty(inst.Id);
            return;
        }

        // A portal in/out node moved (its position lives on the portal's connection point).
        if (_ProjectState.FindPortalByPoint(moved.Id) is StoryPortalNode portal)
        {
            StoryConnectionPoint? point = portal.OutPoint.Id == moved.Id
                ? portal.OutPoint
                : portal.InPoints.Find(p => p.Id == moved.Id);
            if (point is not null)
            {
                point.X = moved.X;
                point.Y = moved.Y;
                _ProjectState.MarkKeyDirty(portal.Id);
            }
            return;
        }

        // A connection point (Start/End/Entry/Exit) of the current container moved.
        if (Project.ContainerNodes.TryGetValue(_CurrentId, out StoryContainerNode? container))
        {
            StoryConnectionPoint? point = container.EntryPoints.Find(p => p.Id == moved.Id)
                                       ?? container.ExitPoints.Find(p => p.Id == moved.Id);
            if (point is not null)
            {
                point.X = moved.X;
                point.Y = moved.Y;
                _ProjectState.MarkKeyDirty(container.Id);
            }
        }
    }

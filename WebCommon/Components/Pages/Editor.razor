    // Footprint used when clamping a new node into view. Wide/tall enough to also contain a portal *pair* (in + out,
    // separated by the portal gap) so a created portal's far point can never fall off-screen.
    private const double _DROP_FOOTPRINT_W = 540;
    private const double _DROP_FOOTPRINT_H = 120;

    /// <summary>
    /// Keeps a freshly created / pasted node inside the current view: returns (<paramref name="x"/>, <paramref name="y"/>)
    /// when a node of the given footprint dropped there fits fully in the visible canvas, otherwise the view centre
    /// (footprint-adjusted). Prevents nodes / portals from landing off-screen when the view is panned far away.
    /// </summary>
    private async Task<(double X, double Y)> ClampDrop(double x, double y, double footprintW, double footprintH)
    {
        if (_GraphRef is null) return (x, y);
        double[] v = await _GraphRef.VisibleWorldRectAsync(); // [x, y, width, height] in world coords
        const double margin = 20;
        bool fits = x >= v[0] + margin && x + footprintW <= v[0] + v[2] - margin
                 && y >= v[1] + margin && y + footprintH <= v[1] + v[3] - margin;
        if (fits) return (x, y);
        return (v[0] + (v[2] - footprintW) / 2, v[1] + (v[3] - footprintH) / 2);
    }

